@page "/ForgotPassword"

@using System.ComponentModel.DataAnnotations;
@using <# Project.Namespace#>.Blazor.Identity;
@using <# Project.Namespace#>.Blazor.Services;
@using <# Project.Namespace#>.Client.Data.Identity;
@using <# Project.Namespace#>.Client.Localisation;

@inject IAuthenticationService AuthenticationService
@inject IPasswordResetService PasswordResetService
@inject NavigationManager NavigationManager
@inject ILogger<ForgotPassword> Logger

<PageTitle>@UserLoc.ForgotPassword</PageTitle>

<EditForm Model="@Input" OnValidSubmit="@RequestResetCode">
<MudContainer MaxWidth="MaxWidth.Small" Class="px-0">
	<MudPaper Class="pa-6" Elevation="0">
		<MudStack Spacing="3">
			<MudText Typo="Typo.h4">@UserLoc.ForgotPassword</MudText>
			<DataAnnotationsValidator />
			<ValidationSummary />
			<MudTextField T="string"
					   Label="@UserLoc.EmailAddress"
					   Value="@Input.EMail"
					   ValueChanged="@((string value) => Input.EMail = value)"
					   InputType="InputType.Email"
					   Variant="Variant.Outlined" />
			<MudButton ButtonType="MudBlazor.ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">@UserLoc.SendResetCode</MudButton>
			<MudButton Variant="Variant.Text" Color="Color.Primary" Href="/Login">@UserLoc.Login</MudButton>
		</MudStack>
	</MudPaper>
</MudContainer>
</EditForm>

@code {
	private class InputModel
	{
		[Required]
		[EmailAddress]
		public string EMail { get; set; } = string.Empty;
	}

	private InputModel Input = new();

	[CascadingParameter(Name = "ErrorService")]
	protected IErrorService? ErrorService { get; set; }

	protected override async Task OnInitializedAsync()
	{
		ErrorService?.HideError();
		await AuthenticationService.LogoutAsync();
		await base.OnInitializedAsync();
	}

	private async Task RequestResetCode()
	{
		try
		{
			var result = await PasswordResetService.RequestPasswordReset(Input.EMail);

			if (!result.IsSuccess)
			{
				ErrorService?.ShowError(UserLoc.ForgotPassword, result.ErrorMessage);
				return;
			}

			ErrorService?.HideError();
			NavigationManager.NavigateTo($"/ResetPassword?email={System.Uri.EscapeDataString(Input.EMail.Trim())}");
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Error requesting password reset code.");
			ErrorService?.ShowError(UserLoc.ForgotPassword, ErrorLoc.ErrorCouldNotLoad);
		}
	}
}<#cs SetOutputPathAndSkipOtherDefinitions()#>