@page "/ResetPassword"

@using System.ComponentModel.DataAnnotations;
@using <# Project.Namespace#>.Blazor.Identity;
@using <# Project.Namespace#>.Blazor.Services;
@using <# Project.Namespace#>.Client.Data.Identity;
@using <# Project.Namespace#>.Client.Localisation;

@inject IAuthenticationService AuthenticationService
@inject IPasswordResetService PasswordResetService
@inject NavigationManager NavigationManager
@inject ILogger<ResetPassword> Logger

<PageTitle>@UserLoc.ResetPassword</PageTitle>

<EditForm Model="@Input" OnValidSubmit="@TryResetPassword">
<MudContainer MaxWidth="MaxWidth.Small" Class="px-0">
	<MudPaper Class="pa-6" Elevation="0">
		<MudStack Spacing="3">
			<MudText Typo="Typo.h4">@UserLoc.ResetPassword</MudText>
			<DataAnnotationsValidator />
			<ValidationSummary />
			<MudTextField T="string" Label="@UserLoc.EmailAddress" Value="@EMail" Disabled="true" Variant="Variant.Outlined" />
			<MudTextField T="string"
					   Label="@UserLoc.ResetCode"
					   Value="@Input.Code"
					   ValueChanged="@((string value) => Input.Code = value)"
					   Variant="Variant.Outlined" />
			<MudTextField T="string"
					   Label="@UserLoc.NewPassword"
					   Value="@Input.Password"
					   ValueChanged="@((string value) => Input.Password = value)"
					   InputType="InputType.Password"
					   Variant="Variant.Outlined" />
			<MudTextField T="string"
					   Label="@UserLoc.ConfirmNewPassword"
					   Value="@Input.PasswordConfirm"
					   ValueChanged="@((string value) => Input.PasswordConfirm = value)"
					   InputType="InputType.Password"
					   Variant="Variant.Outlined" />
			<MudButton ButtonType="MudBlazor.ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">@UserLoc.ResetPassword</MudButton>
			<MudButton Variant="Variant.Text" Color="Color.Primary" Href="/ForgotPassword">@UserLoc.ForgotPassword</MudButton>
		</MudStack>
	</MudPaper>
</MudContainer>
</EditForm>

@code {
	private class InputModel
	{
		[Required]
		public string Code { get; set; } = string.Empty;

		[Required]
		[DataType(DataType.Password)]
		[StringLength(30, MinimumLength = 8)]
		public string Password { get; set; } = string.Empty;

		[Required]
		[DataType(DataType.Password)]
		[StringLength(30, MinimumLength = 8)]
		public string PasswordConfirm { get; set; } = string.Empty;
	}

	private InputModel Input = new();
	private string EMail = string.Empty;

	[CascadingParameter(Name = "ErrorService")]
	protected IErrorService? ErrorService { get; set; }

	protected override async Task OnInitializedAsync()
	{
		ErrorService?.HideError();
		await AuthenticationService.LogoutAsync();
		await base.OnInitializedAsync();
	}

	protected override void OnParametersSet()
	{
		if (NavigationManager.TryGetQueryString("email", out string? email) && !string.IsNullOrWhiteSpace(email))
		{
			EMail = email;
		}

		if (string.IsNullOrWhiteSpace(EMail))
		{
			NavigationManager.NavigateTo("/ForgotPassword");
		}
	}

	private async Task TryResetPassword()
	{
		if (Input.Password != Input.PasswordConfirm)
		{
			ErrorService?.ShowError(UserLoc.ResetPassword, ErrorLoc.ErrorPasswordsDoNotMatch);
			Input.PasswordConfirm = string.Empty;
			return;
		}

		try
		{
			var result = await PasswordResetService.ResetPassword(EMail, Input.Code, Input.Password);

			if (!result.IsSuccess)
			{
				ErrorService?.ShowError(UserLoc.ResetPassword, result.ErrorMessage);
				Input.Code = string.Empty;
				return;
			}

			ErrorService?.HideError();
			NavigationManager.NavigateTo("/Login");
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Error resetting password.");
			ErrorService?.ShowError(UserLoc.ResetPassword, ErrorLoc.ErrorCouldNotSave);
		}
	}
}<#cs SetOutputPathAndSkipOtherDefinitions()#>