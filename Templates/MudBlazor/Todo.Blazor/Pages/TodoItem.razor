@code {
	[CascadingParameter(Name = "ErrorService")]
	protected IErrorService? ErrorService { get; set; }

	[Parameter]
	public Guid Id { get; set; }

	private bool isNew = false;
	private bool isDeleteRequested = false;
	private <# Definition.Name#>Model? Model;
	private readonly ChangeTracker _changeTracker = new();
	private SaveConfirmationDialog? _saveConfirmationDialog;
	private IDisposable? _locationChangingRegistration;
	private bool _ignoreLocationChanging;
	private bool _isSaveConfirmationVisible;

<#for entry in Entries
	.Where(e => e.IsReference)
	.Concat(Entries
		.Where(e => e.IsArray)
		.SelectMany(arrayEntry => Definitions.First(definition => definition.Name == arrayEntry.EntryType).Entries)
		.Where(childEntry => childEntry.IsReference))
	.DistinctBy(e => e.ReferenceType)
#>	private IEnumerable<<# entry.ReferenceType#>ListItemModel> _<# entry.ReferenceTypeLow#>s = [];
<#end#>
	private void NavigateToHistory()
	{
		if (Model is null || isNew)
		{
			return;
		}

		NavigationManager.NavigateTo($"/history/{Model.Id}?entityName=<# Definition.Name#>");
	}

	protected override void OnAfterRender(bool firstRender)
	{
		if (firstRender)
		{
			_locationChangingRegistration = NavigationManager.RegisterLocationChangingHandler(HandleLocationChangingAsync);
		}
	}

	private async ValueTask HandleLocationChangingAsync(LocationChangingContext context)
	{
		if (_ignoreLocationChanging)
		{
			_ignoreLocationChanging = false;
			return;
		}

		if (!await CanNavigateAsync())
		{
			context.PreventNavigation();
		}
	}

	private async Task<bool> CanNavigateAsync()
	{
		if (_isSaveConfirmationVisible || isDeleteRequested)
		{
			return false;
		}

		if (!_changeTracker.HasChanges || _saveConfirmationDialog is null)
		{
			return true;
		}

		_isSaveConfirmationVisible = true;

		try
		{
			var saveDialogResult = await _saveConfirmationDialog.ShouldSave();

			switch (saveDialogResult)
			{
				case SaveConfirmationDialog.SaveDialogResult.Save:
					return await TrySaveAsync(navigateAfterCreate: false);
				case SaveConfirmationDialog.SaveDialogResult.Discard:
					return true;
				default:
					return false;
			}
		}
		finally
		{
			_isSaveConfirmationVisible = false;
		}
	}

	private void NavigateWithoutSaveConfirmation(string url, bool forceLoad = false, bool replace = false)
	{
		_ignoreLocationChanging = true;
		NavigationManager.NavigateTo(url, forceLoad, replace);
	}

	protected override async Task OnInitializedAsync()
	{
		try
		{
			if (Id == Guid.Empty)
			{
				Model = <# Definition.Name#>Service.Create<# Definition.Name#>();
				isNew = true;
			}
			else
			{
				Model = await <# Definition.Name#>Service.GetItemAsync(Id);
			}

<#for entry in Entries
	.Where(e => e.IsReference)
	.Concat(Entries
		.Where(e => e.IsArray)
		.SelectMany(arrayEntry => Definitions.First(definition => definition.Name == arrayEntry.EntryType).Entries)
		.Where(childEntry => childEntry.IsReference))
	.DistinctBy(e => e.ReferenceType)
#>			var available<# entry.ReferenceType#>s = await <# entry.ReferenceType#>Service.GetItemsAsync();
			_<# entry.ReferenceTypeLow#>s = [new <# entry.ReferenceType#>ListItemModel { Id = Guid.Empty }, .. available<# entry.ReferenceType#>s];
<#end#>			<# Definition.Name#>Service.ItemUpdated += Handle;
			_changeTracker.StateChanged += () => InvokeAsync(StateHasChanged);

			await <# Definition.Name#>Service.StartEventListener();
		}
		catch (<# Project.Namespace#>.Client.Data.Identity.SessionUnavailableException)
		{
			var url = NavigationManager.BuildReturnUrl("/login");
			NavigateWithoutSaveConfirmation(url);
		}
		catch (Exception ex)
		{
			Log.LogError(ex, "Error loading <# Definition.Name#>.");
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorCouldNotLoad);
		}
	}

	private Task Save() => TrySaveAsync();

	private async Task<bool> TrySaveAsync(bool navigateAfterCreate = true)
	{
		if (Model is null)
		{
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorModelIsNullReload);
			return false;
		}

		try
		{
			if (isNew)
			{
				await <# Definition.Name#>Service.AddItemAsync(Model);
				Id = Model.Id;
				isNew = false;
				_changeTracker.Clear();

				if (navigateAfterCreate)
				{
					NavigateWithoutSaveConfirmation($"/<# Definition.Name#>/{Model.Id}", false, true);
				}
			}
			else
			{
				await <# Definition.Name#>Service.UpdateItemAsync(Model);
				_changeTracker.Clear();
			}

			ErrorService?.HideError();
			ErrorService?.ShowSuccess(CommonLoc.Save, CommonLoc.ChangesRecorded);

			return true;
		}
		catch (<# Project.Namespace#>.Client.Data.Identity.SessionUnavailableException)
		{
			var url = NavigationManager.BuildReturnUrl("/login");
			NavigateWithoutSaveConfirmation(url);
		}
		catch (Exception ex)
		{
			Log.LogError(ex, "Error saving <# Definition.Name#>.");
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorCouldNotSave);
		}

		return false;
	}

	private async Task Remove()
	{
		if (Model is null)
		{
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorModelIsNullReload);
			return;
		}

		try
		{
			if (!isNew)
			{
				await <# Definition.Name#>Service.DeleteItemAsync(Model.Id);
			}

			_changeTracker.Clear();
			NavigateWithoutSaveConfirmation(GetReturnToListUrl());
		}
		catch (<# Project.Namespace#>.Client.Data.Identity.SessionUnavailableException)
		{
			var url = NavigationManager.BuildReturnUrl("/login");
			NavigateWithoutSaveConfirmation(url);
		}
		catch (Exception ex)
		{
			Log.LogError(ex, "Error deleting <# Definition.Name#>.");
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorDeleting);
		}
	}

	private async Task Handle(object? sender, <# Definition.Name#>Updated message)
	{
		if (Model is null || Model.Id != message.Id)
		{
			return;
		}

		Map.From(message).To(Model);
		_changeTracker.Clear();

		await InvokeAsync(StateHasChanged);
	}

	private string GetReturnToListUrl()
	{
		if (NavigationManager.TryGetReturnUrl(out var returnUrl) && !string.IsNullOrWhiteSpace(returnUrl))
		{
			return "/" + returnUrl.TrimStart('/');
		}

		return "/<# Definition.Name#>s";
	}
<#for entry in Entries.Where(e => e.IsArray)
#>
	private void Add<# entry.Field#>Entry()
	{
		if (Model is null)
		{
			return;
		}

		var max = 0;

		if (Model.<# entry.Field#>.Count > 0)
		{
			max = Model.<# entry.Field#>.Max(e => e.Id) + 1;
		}

		var model = new <# entry.EntryType#>Model() { Id = max };

		Model.<# entry.Field#>.Add(model);

		_changeTracker.Track(
			nameof(Model.<# entry.Field#>),
			() => Model.<# entry.Field#>.Remove(model),
			() => Model.<# entry.Field#>.Add(model));
	}

	private void Remove<# entry.Field#>Entry(int id)
	{
		if (Model is null)
		{
			return;
		}

		var oldItem = Model.<# entry.Field#>.FirstOrDefault(i => i.Id == id);

		if (oldItem != null)
		{
			var index = Model.<# entry.Field#>.IndexOf(oldItem);

			if (index != -1)
			{
				Model.<# entry.Field#>.RemoveAt(index);

				_changeTracker.Track(
					nameof(Model.<# entry.Field#>),
					() => Model.<# entry.Field#>.Insert(index, oldItem),
					() => Model.<# entry.Field#>.Remove(oldItem));
			}
		}
	}
<#end#>
	public void Dispose()
	{
		<# Definition.Name#>Service.ItemUpdated -= Handle;
		_locationChangingRegistration?.Dispose();
	}
}<#cs SetOutputPath(Definition.IsOwnedType || Definition.IsEnumeration || Definition.IsArray)#>
