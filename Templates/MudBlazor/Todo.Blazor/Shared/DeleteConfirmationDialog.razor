@using <# Project.Namespace#>.Client.Localisation;

@if (IsVisible)
{
	<MudOverlay Visible="true" DarkBackground="true" AutoClose="false">
		<MudPaper Class="dialog-panel pa-6" Elevation="16">
			<MudStack Spacing="3">
				<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
					<MudText Typo="Typo.h6">@Title</MudText>
					<MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="@(_ => Cancel())" />
				</MudStack>
				<MudText Typo="Typo.body1">@Description</MudText>
				<MudStack Row="true" Justify="Justify.FlexEnd" Spacing="1">
					<MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="@(_ => RemoveExecute())">@CommonLoc.Delete</MudButton>
					<MudButton Variant="Variant.Text" Color="Color.Default" OnClick="@(_ => Cancel())">@CommonLoc.Cancel</MudButton>
				</MudStack>
			</MudStack>
		</MudPaper>
	</MudOverlay>
}

@code {
	[Parameter] public string Title { get; set; } = @CommonLoc.DeleteConfirmationTitle;
	[Parameter] public string Description { get; set; } = @CommonLoc.DeleteConfirmationDescription;

	[Parameter] public bool IsVisible { get; set; }
	[Parameter] public EventCallback<bool> IsVisibleChanged { get; set; }

	[Parameter] public EventCallback Remove { get; set; }

	private async Task RemoveExecute()
	{
		if (Remove.HasDelegate)
		{
			await Remove.InvokeAsync();
		}
	}

	private async Task Cancel()
	{
		IsVisible = false;
		await IsVisibleChanged.InvokeAsync(IsVisible);
		await InvokeAsync(StateHasChanged);
	}
}
<#cs SetOutputPathAndSkipOtherDefinitions()#>
