@using <# Project.Namespace#>.Client.Localisation;

@implements IDisposable

@if (_isVisible)
{
	<MudOverlay Visible="true" DarkBackground="true" AutoClose="false" Class="save-confirmation-overlay">
		<MudPaper Class="dialog-panel pa-6" Elevation="16">
			<MudStack Spacing="3">
				<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
					<MudText Typo="Typo.h6">@Title</MudText>
					<MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default" OnClick="@(_ => Cancel())" />
				</MudStack>
				<MudText Typo="Typo.body1">@Description</MudText>
				<MudStack Row="true" Justify="Justify.FlexEnd" Spacing="1">
					<MudButton @ref="_saveButton" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(_ => Save())" Disabled="@(!CanSave)">@CommonLoc.Save</MudButton>
					<MudButton Variant="Variant.Outlined" Color="Color.Warning" OnClick="@(_ => Discard())">@CommonLoc.Discard</MudButton>
					<MudButton Variant="Variant.Text" Color="Color.Default" OnClick="@(_ => Cancel())">@CommonLoc.Cancel</MudButton>
				</MudStack>
			</MudStack>
		</MudPaper>
	</MudOverlay>
}

@code {
	public enum SaveDialogResult
	{
		Save,
		Discard,
		Cancel
	}

	[Parameter] public string Title { get; set; } = @CommonLoc.SaveConfirmationTitle;
	[Parameter] public string Description { get; set; } = @CommonLoc.SaveConfirmationDescription;

	[Parameter] public bool CanSave { get; set; } = true;

	private bool _isVisible;
	private bool _focusSaveButton;
	private MudButton? _saveButton;
	private TaskCompletionSource<SaveDialogResult>? _saveDialogCompletion;

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (_focusSaveButton && _isVisible && CanSave && _saveButton is not null)
		{
			_focusSaveButton = false;
			await _saveButton.FocusAsync();
		}
	}

	public async Task<SaveDialogResult> ShouldSave()
	{
		_saveDialogCompletion = new TaskCompletionSource<SaveDialogResult>();
		_isVisible = true;
		_focusSaveButton = CanSave;
		await InvokeAsync(StateHasChanged);

		try
		{
			return await _saveDialogCompletion.Task;
		}
		catch (TaskCanceledException)
		{
			return SaveDialogResult.Cancel;
		}
		finally
		{
			_isVisible = false;
			StateHasChanged();
		}
	}

	private void Save()
	{
		_saveDialogCompletion?.TrySetResult(SaveDialogResult.Save);
	}

	private void Discard()
	{
		_saveDialogCompletion?.TrySetResult(SaveDialogResult.Discard);
	}

	private void Cancel()
	{
		_saveDialogCompletion?.TrySetResult(SaveDialogResult.Cancel);
	}

	public void Dispose()
	{
		_saveDialogCompletion?.TrySetCanceled();
	}
}
<#cs SetOutputPathAndSkipOtherDefinitions()#>
