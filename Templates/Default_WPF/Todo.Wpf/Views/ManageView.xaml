<UserControl x:Class="<#cs Write(Project.Namespace)#>.Wpf.Views.ManageView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:loc="clr-namespace:<#cs Write(Project.Namespace)#>.Client.Localisation;assembly=<#cs Write(Project.Namespace)#>.Client.Localisation"
			 xmlns:controls="clr-namespace:<#cs Write(Project.Namespace)#>.Wpf.Controls"
			 xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
			 mc:Ignorable="d"
			 d:DesignHeight="450" d:DesignWidth="800">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<Button Margin="5"
				HorizontalAlignment="Left"
				Command="{Binding NavigateBackCommand}">
			<Button.Content>
				<materialIcons:MaterialIcon Kind="ArrowLeft" Width="18" Height="18" />
			</Button.Content>
		</Button>

		<Border Grid.Row="1"
				MaxWidth="400"
				Padding="32"
				HorizontalAlignment="Center"
				VerticalAlignment="Center">
			<StackPanel>
				<TextBlock Margin="0,0,0,16"
						   HorizontalAlignment="Center"
						   FontSize="24"
						   FontWeight="Bold"
						   Foreground="{StaticResource BackgroundColor}"
						   Text="{x:Static loc:UserLoc.UserManagement}" />

				<!--  New Password  -->
				<StackPanel Margin="0,0,0,16">
					<TextBlock Margin="0,0,0,4" Text="{x:Static loc:UserLoc.NewPassword}" />
					<PasswordBox controls:PasswordBoxHelper.BindPassword="True"
								 controls:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, ValidatesOnNotifyDataErrors=True}" />
				</StackPanel>

				<!--  Confirm New Password  -->
				<StackPanel Margin="0,0,0,16">
					<TextBlock Margin="0,0,0,4" Text="{x:Static loc:UserLoc.ConfirmNewPassword}" />
					<PasswordBox controls:PasswordBoxHelper.BindPassword="True"
								 controls:PasswordBoxHelper.BoundPassword="{Binding PasswordConfirm, Mode=TwoWay, ValidatesOnNotifyDataErrors=True}" />
				</StackPanel>

				<!--  Save Button  -->
				<Button Margin="0,8,0,0"
						HorizontalAlignment="Stretch"
						HorizontalContentAlignment="Center"
						Command="{Binding SaveCommand}"
						Content="{x:Static loc:UserLoc.ChangePassword}" />
			</StackPanel>
		</Border>
	</Grid>
</UserControl><#cs SetOutputPathAndSkipOtherDefinitions()#>
