@page "/ResetPassword"

@using System.ComponentModel.DataAnnotations;
@using <# Project.Namespace#>.Blazor.Identity;
@using <# Project.Namespace#>.Blazor.Services;
@using <# Project.Namespace#>.Client.Data.Identity;
@using <# Project.Namespace#>.Client.Localisation;

@inject IAuthenticationService AuthenticationService
@inject IPasswordResetService PasswordResetService
@inject NavigationManager NavigationManager
@inject ILogger<ResetPassword> Logger

<PageTitle>@UserLoc.ResetPassword</PageTitle>

<EditForm Model="@Input" OnValidSubmit="@TryResetPassword">
	<section class="w-100 p-4 d-flex justify-content-center pb-4">
		<div>
			<h1>@UserLoc.ResetPassword</h1>
			<br />
			<DataAnnotationsValidator />
			<ValidationSummary />

			<div class="form-outline mb-4">
				<label class="form-label" for="EmailInput">@UserLoc.EmailAddress</label>
				<input type="email" id="EmailInput" class="form-control" value="@EMail" disabled />
			</div>

			<div class="form-outline mb-4">
				<label class="form-label" for="CodeInput">@UserLoc.ResetCode</label>
				<InputText type="text" id="CodeInput" class="form-control" @bind-Value="Input.Code" />
			</div>

			<div class="form-outline mb-4">
				<label class="form-label" for="PasswordInput">@UserLoc.NewPassword</label>
				<InputText type="password" id="PasswordInput" class="form-control" @bind-Value="Input.Password" />
			</div>

			<div class="form-outline mb-4">
				<label class="form-label" for="PasswordConfirmInput">@UserLoc.ConfirmNewPassword</label>
				<InputText type="password" id="PasswordConfirmInput" class="form-control" @bind-Value="Input.PasswordConfirm" />
			</div>

			<div class="form-outline mb-4">
				<button type="submit" class="btn btn-primary w-100">@UserLoc.ResetPassword</button>
			</div>

			<div class="form-outline mb-4">
				<a href="/ForgotPassword" class="btn btn-link w-100">@UserLoc.ForgotPassword</a>
			</div>
		</div>
	</section>
</EditForm>

@code {
	private class InputModel
	{
		[Required]
		public string Code { get; set; } = string.Empty;

		[Required]
		[DataType(DataType.Password)]
		[StringLength(30, MinimumLength = 8)]
		public string Password { get; set; } = string.Empty;

		[Required]
		[DataType(DataType.Password)]
		[StringLength(30, MinimumLength = 8)]
		public string PasswordConfirm { get; set; } = string.Empty;
	}

	private InputModel Input = new();
	private string EMail = string.Empty;

	[CascadingParameter(Name = "ErrorService")]
	protected IErrorService? ErrorService { get; set; }

	protected override async Task OnInitializedAsync()
	{
		ErrorService?.HideError();
		await AuthenticationService.LogoutAsync();
		await base.OnInitializedAsync();
	}

	protected override void OnParametersSet()
	{
		var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
		var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

		if (query.TryGetValue("email", out var email) && email.Any())
		{
			EMail = email.First() ?? string.Empty;
		}

		if (string.IsNullOrWhiteSpace(EMail))
		{
			NavigationManager.NavigateTo("/ForgotPassword");
		}
	}

	private async Task TryResetPassword()
	{
		if (Input.Password != Input.PasswordConfirm)
		{
			ErrorService?.ShowError(UserLoc.ResetPassword, ErrorLoc.ErrorPasswordsDoNotMatch);
			Input.PasswordConfirm = string.Empty;
			return;
		}

		try
		{
			var result = await PasswordResetService.ResetPassword(EMail, Input.Code, Input.Password);

			if (!result.IsSuccess)
			{
				ErrorService?.ShowError(UserLoc.ResetPassword, result.ErrorMessage);
				Input.Code = string.Empty;
				return;
			}

			ErrorService?.HideError();
			NavigationManager.NavigateTo("/Login");
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Error resetting password.");
			ErrorService?.ShowError(UserLoc.ResetPassword, ErrorLoc.ErrorCouldNotSave);
		}
	}
}<#cs SetOutputPathAndSkipOtherDefinitions()#>