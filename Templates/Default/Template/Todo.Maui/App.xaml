<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 xmlns:local="clr-namespace:<#cs Write(Project.Namespace)#>.Maui"
			 x:Class="<#cs Write(Project.Namespace)#>.Maui.App">
	<Application.Resources>
		<ResourceDictionary>
			<Color x:Key="BackgroundColor"><#cs Write(Project.PrimaryColor)#></Color>
			<Color x:Key="ForegroundColor"><#cs Write(Project.ForegroundColor)#></Color>
		</ResourceDictionary>
	</Application.Resources>
</Application><#cs SetOutputPathAndSkipOtherDefinitions()#>
