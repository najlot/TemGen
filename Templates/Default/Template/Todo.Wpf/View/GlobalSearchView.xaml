<UserControl x:Class="<#cs Write(Project.Namespace)#>.Wpf.View.GlobalSearchView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:controls="clr-namespace:<#cs Write(Project.Namespace)#>.Wpf.Controls"
			 xmlns:converter="clr-namespace:<#cs Write(Project.Namespace)#>.Wpf.Converter"
			 xmlns:loc="clr-namespace:<#cs Write(Project.Namespace)#>.Client.Localisation;assembly=<#cs Write(Project.Namespace)#>.Client.Localisation"
			 xmlns:local="clr-namespace:<#cs Write(Project.Namespace)#>.Wpf.View"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
			 d:DesignHeight="450"
			 d:DesignWidth="800"
			 mc:Ignorable="d">
	<DockPanel>
		<DockPanel DockPanel.Dock="Top">
			<Button Margin="5" DockPanel.Dock="Left" Command="{Binding NavigateBackCommand}">
				<Button.Content>
					<materialIcons:MaterialIcon Kind="ArrowLeft" Width="18" Height="18" />
				</Button.Content>
			</Button>

			<WrapPanel HorizontalAlignment="Right" DockPanel.Dock="Right">
				<Button Margin="5"
						Command="{Binding SearchCommand}"
						ToolTip="{x:Static loc:GlobalSearchLoc.Search}">
					<Button.Content>
						<materialIcons:MaterialIcon Kind="Magnify" Width="18" Height="18" />
					</Button.Content>
				</Button>
			</WrapPanel>

			<DockPanel DockPanel.Dock="Left">
				<Label VerticalAlignment="Center" Content="{x:Static loc:GlobalSearchLoc.Search}" />
				<TextBox Margin="5"
						 Width="260"
						 VerticalAlignment="Center"
						 Text="{Binding QueryText, UpdateSourceTrigger=PropertyChanged}" />
			</DockPanel>
		</DockPanel>

		<Grid>
			<TextBlock Margin="8"
					   Visibility="{Binding ShowSearchPrompt, Converter={x:Static converter:BooleanToVisibilityConverter.Instance}}"
					   Foreground="#FF666666"
					   Text="{x:Static loc:GlobalSearchLoc.SearchPrompt}" />

			<TextBlock Margin="8"
					   Visibility="{Binding ShowNoResults, Converter={x:Static converter:BooleanToVisibilityConverter.Instance}}"
					   Foreground="#FF666666"
					   Text="{x:Static loc:GlobalSearchLoc.NoResults}" />

			<ScrollViewer>
				<ItemsControl ItemsSource="{Binding Items}">
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Button Margin="6"
									Padding="0"
									Background="Transparent"
									BorderThickness="0"
									HorizontalContentAlignment="Stretch"
									Command="{Binding DataContext.OpenResultCommand, RelativeSource={RelativeSource AncestorType=local:GlobalSearchView}}"
									CommandParameter="{Binding .}">
								<Border Padding="10" CornerRadius="8" Background="#FFF6F6F6" BorderBrush="#FFE0E0E0" BorderThickness="1">
									<DockPanel>
										<TextBlock DockPanel.Dock="Right" Foreground="#FF666666" Text="{Binding TypeDisplay}" />
										<StackPanel>
											<controls:HighlightTextBlock FontWeight="SemiBold"
												Text="{Binding Title}"
												HighlightText="{Binding DataContext.ActiveQuery, RelativeSource={RelativeSource AncestorType=local:GlobalSearchView}}" />
											<controls:HighlightTextBlock Margin="0,4,0,0"
												Foreground="#FF444444"
												TextWrapping="Wrap"
												Text="{Binding Content}"
												HighlightText="{Binding DataContext.ActiveQuery, RelativeSource={RelativeSource AncestorType=local:GlobalSearchView}}" />
										</StackPanel>
									</DockPanel>
								</Border>
							</Button>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</ScrollViewer>
		</Grid>
	</DockPanel>
</UserControl>
<#cs SetOutputPathAndSkipOtherDefinitions()#>