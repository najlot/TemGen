<UserControl x:Class="<#cs Write(Project.Namespace)#>.Wpf.Views.HistoryView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:loc="clr-namespace:<#cs Write(Project.Namespace)#>.Client.Localisation;assembly=<#cs Write(Project.Namespace)#>.Client.Localisation"
			 xmlns:converter="clr-namespace:<#cs Write(Project.Namespace)#>.Wpf.Converters"
			 xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
			 mc:Ignorable="d"
			 d:DesignHeight="400" d:DesignWidth="500">
	<DockPanel>
		<DockPanel DockPanel.Dock="Top" Margin="5">
			<Button Margin="0,0,8,0"
					DockPanel.Dock="Left"
					Command="{Binding NavigateBackCommand}">
				<Button.Content>
					<materialIcons:MaterialIcon Kind="ArrowLeft" Width="18" Height="18" />
				</Button.Content>
			</Button>
			<StackPanel>
				<TextBlock FontSize="20" FontWeight="SemiBold" Text="{x:Static loc:CommonLoc.History}" />
				<TextBlock Foreground="Gray"
						   Text="{Binding EntityName}"
						   Visibility="{Binding HasEntityName, Converter={x:Static converter:BooleanToVisibilityCollapsedConverter.Instance}}" />
			</StackPanel>
		</DockPanel>
		<ScrollViewer>
			<StackPanel Margin="5">
			<TextBlock Margin="0,0,0,8"
					   Foreground="Gray"
					   Text="{x:Static loc:CommonLoc.Loading}"
					   Visibility="{Binding IsLoading, Converter={x:Static converter:BooleanToVisibilityConverter.Instance}}" />

			<TextBlock Margin="0,0,0,8"
					   Foreground="Gray"
					   Text="{x:Static loc:CommonLoc.NoHistoryEntries}"
					   Visibility="{Binding ShowNoHistory, Converter={x:Static converter:BooleanToVisibilityConverter.Instance}}" />

			<ItemsControl ItemsSource="{Binding Items}" HorizontalAlignment="Stretch">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Expander Margin="0,0,0,8" IsExpanded="True" HorizontalAlignment="Stretch">
							<Expander.Header>
								<StackPanel>
									<TextBlock FontWeight="SemiBold" Text="{Binding Username}" />
									<TextBlock Foreground="Gray" Text="{Binding TimeStampText}" />
									<TextBlock Foreground="Gray">
										<Run Text="{Binding ChangeCount, Mode=OneWay}" />
										<Run Text=" " />
										<Run Text="{x:Static loc:CommonLoc.ChangesRecorded}" />
									</TextBlock>
								</StackPanel>
							</Expander.Header>
							<StackPanel Margin="8,6,0,0">
								<Grid Margin="0,0,0,6">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="180" />
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="*" />
									</Grid.ColumnDefinitions>
									<TextBlock Grid.Column="0" FontWeight="SemiBold" Text="{x:Static loc:CommonLoc.Field}" />
									<TextBlock Grid.Column="1" FontWeight="SemiBold" Text="{x:Static loc:CommonLoc.Before}" />
									<TextBlock Grid.Column="2" FontWeight="SemiBold" Text="{x:Static loc:CommonLoc.After}" />
								</Grid>
								<ItemsControl ItemsSource="{Binding Changes}">
									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<Grid Margin="0,0,0,6">
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="180" />
													<ColumnDefinition Width="*" />
													<ColumnDefinition Width="*" />
												</Grid.ColumnDefinitions>
												<TextBlock Grid.Column="0" Margin="0,0,8,0" FontWeight="SemiBold" TextWrapping="Wrap" Text="{Binding Path}" />
												<TextBlock Grid.Column="1" Margin="0,0,8,0" TextWrapping="Wrap" Text="{Binding OldValue}" />
												<TextBlock Grid.Column="2" TextWrapping="Wrap" Text="{Binding NewValue}" />
											</Grid>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</StackPanel>
						</Expander>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
			</StackPanel>
		</ScrollViewer>
	</DockPanel>
</UserControl>
<#cs SetOutputPathAndSkipOtherDefinitions()#>