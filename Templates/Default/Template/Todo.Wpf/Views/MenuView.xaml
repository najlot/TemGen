<UserControl x:Class="<#cs Write(Project.Namespace)#>.Wpf.Views.MenuView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:local="clr-namespace:<#cs Write(Project.Namespace)#>.Wpf.Views"
			 xmlns:loc="clr-namespace:<#cs Write(Project.Namespace)#>.Client.Localisation;assembly=<#cs Write(Project.Namespace)#>.Client.Localisation"
			 xmlns:converter="clr-namespace:<#cs Write(Project.Namespace)#>.Wpf.Converters"
			 xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
			 mc:Ignorable="d"
			 d:DesignHeight="450" d:DesignWidth="800">
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<Border Grid.Column="0"
				Background="White"
				BorderBrush="#14000000"
				BorderThickness="0,0,1,0">
			<Border.Style>
				<Style TargetType="Border">
					<Setter Property="Width" Value="50" />
					<Style.Triggers>
						<DataTrigger Binding="{Binding IsDrawerOpen}" Value="True">
							<Setter Property="Width" Value="200" />
						</DataTrigger>
					</Style.Triggers>
				</Style>
			</Border.Style>
			<ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
				<StackPanel Margin="5">
					<Button Command="{Binding ToggleDrawerCommand}" Margin="0,0,0,12" HorizontalContentAlignment="Left" ToolTip="{x:Static loc:CommonLoc.Navigation}">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<materialIcons:MaterialIcon Kind="Menu" Width="18" Height="18" Margin="1,0" />
							<TextBlock Grid.Column="1"
									   VerticalAlignment="Center"
									   Margin="12,0,0,0"
									   Text="{x:Static loc:CommonLoc.Navigation}"
									   Visibility="{Binding IsDrawerOpen, Converter={x:Static converter:BooleanToVisibilityConverter.Instance}}" />
						</Grid>
					</Button>

					<!--  Navigation Items  -->
<#csfor definition in Definitions.Where(d => !d.IsOwnedType
&& !d.IsArray
&& !d.IsEnumeration
&& !d.Name.Equals("user", StringComparison.OrdinalIgnoreCase))
#>					<Button Command="{Binding NavigateTo<#cs Write(definition.Name)#>s}" Margin="0,0,0,8" HorizontalContentAlignment="Left" ToolTip="{x:Static loc:<#cs Write(definition.Name)#>Loc.<#cs Write(definition.Name)#>s}">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<materialIcons:MaterialIcon Width="18" Height="18" Margin="1,0" Kind="Note" />
							<TextBlock Grid.Column="1"
									   VerticalAlignment="Center"
									   Margin="12,0,0,0"
									   Text="{x:Static loc:<#cs Write(definition.Name)#>Loc.<#cs Write(definition.Name)#>s}"
									   Visibility="{Binding IsDrawerOpen, Converter={x:Static converter:BooleanToVisibilityConverter.Instance}}" />
						</Grid>
					</Button>
<#end
#>					<Button Command="{Binding NavigateToTrash}" Margin="0,0,0,8" HorizontalContentAlignment="Left" ToolTip="{x:Static loc:TrashLoc.Trash}">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<materialIcons:MaterialIcon Width="18" Height="18" Margin="1,0" Kind="Delete" />
							<TextBlock Grid.Column="1"
									   VerticalAlignment="Center"
									   Margin="12,0,0,0"
									   Text="{x:Static loc:TrashLoc.Trash}"
									   Visibility="{Binding IsDrawerOpen, Converter={x:Static converter:BooleanToVisibilityConverter.Instance}}" />
						</Grid>
					</Button>
				</StackPanel>
			</ScrollViewer>
		</Border>

		<Grid Grid.Column="1">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="12,8,12,0">
				<Button Command="{Binding NavigateToGlobalSearch}" ToolTip="{x:Static loc:GlobalSearchLoc.GlobalSearch}" Margin="5">
					<Button.Content>
						<materialIcons:MaterialIcon Kind="Magnify" Width="18" Height="18" />
					</Button.Content>
				</Button>
				<Button Command="{Binding ManageCommand}" ToolTip="Manage" Margin="5">
					<Button.Content>
						<materialIcons:MaterialIcon Kind="User" Width="18" Height="18" />
					</Button.Content>
				</Button>
				<Button Command="{Binding LogoutCommand}" ToolTip="Logout" Margin="5">
					<Button.Content>
						<materialIcons:MaterialIcon Kind="Logout" Width="18" Height="18" />
					</Button.Content>
				</Button>
			</StackPanel>
		</Grid>
	</Grid>
</UserControl><#cs SetOutputPathAndSkipOtherDefinitions()#>
