@using <# Project.Namespace#>.Client.Localisation
@using <# Project.Namespace#>.Contracts.<# Definition.Name#>s
@model <# Project.Namespace#>.Htmx.Pages.<# Definition.Name#>sModel

<div id="items-container"
	 hx-get="@($"{Context.Request.Path}{Context.Request.QueryString}")"
	 hx-select="#items-container"
	 hx-target="this"
	 hx-swap="outerHTML"
	 hx-on::before-request="const hasOtherRequestInFlight = document.querySelector('.htmx-request') && !this.classList.contains('htmx-request'); if (document.visibilityState !== 'visible' || hasOtherRequestInFlight) { document.body.dataset.liveRefreshPending = 'true'; event.preventDefault(); }"
	 hx-trigger="live-refresh-all from:body queue:last, sse:<# Definition.Name#>Created queue:last, sse:<# Definition.Name#>Updated queue:last, sse:<# Definition.Name#>Deleted queue:last, sse:FavoriteCreated queue:last, sse:FavoriteDeleted queue:last">
@if (Model.Items.Count == 0)
{
	<div class="alert border bg-body-tertiary text-body">@CommonLoc.NotFound</div>
}
else
{
	<div class="card shadow-sm border-0">
		<div class="table-responsive">
			<table class="table table-hover align-middle mb-0">
				<thead class="bg-body-tertiary">
					<tr>
						<th class="text-center" style="width: 1%;">
							<span class="material-symbols-sharp text-warning" title="Favorite" aria-label="Favorite">star</span>
						</th>
<#for entry in Definition.Entries.Where(e => !(e.IsKey || e.IsArray || e.IsReference || e.IsOwnedType)).Take(2)
#>						<th>@<# Definition.Name#>Loc.<# entry.Field#></th>
<#end
#>						<th class="text-end">@CommonLoc.Edit</th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in Model.Items)
					{
						<tr>
							<td class="text-center">
								@if (Model.FavoriteItemIds.Contains(item.Id))
								{
									<span class="material-symbols-sharp text-warning" title="Favorite" aria-label="Favorite">star</span>
								}
							</td>
<#for entry in Definition.Entries.Where(e => !(e.IsKey || e.IsArray || e.IsReference || e.IsOwnedType)).Take(2)
#><#if entry.EntryType.ToLower() == "string"
#>							<td class="text-break">@(item.<# entry.Field#>.Length > 75 ? item.<# entry.Field#>[..75] + "..." : item.<# entry.Field#>)</td>
<#else
#>							<td class="text-break">@item.<# entry.Field#></td>
<#end#><#end
#>							<td class="text-end">
								<a href="/<#cs Write(Definition.Name.ToLower())#>/@item.Id" class="btn btn-outline-primary btn-sm">@CommonLoc.Edit</a>
							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	</div>
}
</div>
<#cs SetOutputPath(Definition.IsOwnedType || Definition.IsEnumeration || Definition.IsArray)#>
