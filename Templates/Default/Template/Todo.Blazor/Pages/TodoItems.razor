@page "/<#cs 
if (!Definition.Name.EndsWith("entry"))
{
	Write(Definition.Name);
}
else
{
	Write(Definition.Name[0..^5] + "entrie");
}
#>s"
@using Humanizer
@using Microsoft.AspNetCore.Components
@using <# Project.Namespace#>.Blazor.Services
@using <# Project.Namespace#>.Client.Data
@using <# Project.Namespace#>.Client.Data.Filters
@using <# Project.Namespace#>.Client.Data.<# Definition.Name#>s
<#for definition in Entries.Where(e => e.IsReference).Select(e => e.ReferenceType).Distinct().Select(n => Definitions.First(d => d.Name == n))
#>@using <# Project.Namespace#>.Client.Data.<# definition.Name#>s
<#end#>@using <# Project.Namespace#>.Client.Localisation
@using <# Project.Namespace#>.Contracts.Filters
@using <# Project.Namespace#>.Contracts.Shared
@using <# Project.Namespace#>.Contracts.<# Definition.Name#>s

@inject ILogger<<# Definition.Name#>s> Log
@inject Najlot.Map.IMap Map
@inject I<# Definition.Name#>Service <# Definition.Name#>Service
<#for definition in Entries.Where(e => e.IsReference).Select(e => e.ReferenceType).Distinct().Select(n => Definitions.First(d => d.Name == n))
#>@inject I<# definition.Name#>Service <# definition.Name#>Service
<#end#>@inject NavigationManager NavigationManager

@attribute [Authorize]
@implements IDisposable

<PageTitle>@<# Definition.Name#>Loc.<# Definition.Name#>s</PageTitle>

<section class="d-grid gap-3">
	<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
		<h1 class="mb-0">@<# Definition.Name#>Loc.<# Definition.Name#>s</h1>
		<a href="/<# Definition.Name#>/@Guid.Empty" class="btn btn-success material-symbols-sharp">add</a>
	</div>

	<EntityFilterEditor @ref="filterEditor"
						AvailableFields="availableFilterFields"
						TargetType="ItemType.<# Definition.Name#>"
						IsBusy="isLoading"
						ApplyFilter="HandleFilterAppliedAsync" />

	@if (<# Definition.NameLow#>s is null)
	{
		<p><em>@CommonLoc.Loading...</em></p>
	}
	else
	{
		<div class="card shadow-sm border-0">
			<div class="table-responsive">
				<table class="table table-hover align-middle mb-0">
					<thead class="table-light">
						<tr>
<#for entry in Definition.Entries.Where(e => !(e.IsKey || e.IsArray || e.IsReference || e.IsOwnedType)).Take(2)
#>							<th>@<# Definition.Name#>Loc.<# entry.Field#></th>
<#end
#>							<th class="text-end">@CommonLoc.Edit</th>
						</tr>
					</thead>
					<tbody>
						@foreach (var <# Definition.NameLow#> in <# Definition.NameLow#>s)
						{
							<tr scope="row">
<#for entry in Definition.Entries.Where(e => !(e.IsKey || e.IsArray || e.IsReference || e.IsOwnedType)).Take(2)
#><#if entry.EntryType.ToLower() == "string"
#>								<td class="text-break">@<# Definition.NameLow#>.<# entry.Field#>.Truncate(75)</td>
<#else
#>								<td class="text-break">@<# Definition.NameLow#>.<# entry.Field#></td>
<#end#><#end
#>								<td class="text-end"><a href="/<# Definition.Name#>/@<# Definition.NameLow#>.Id" class="btn btn-outline-primary btn-sm">@CommonLoc.Edit</a></td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		</div>
	}
</section>

@code {
	[CascadingParameter(Name = "ErrorService")]
	protected IErrorService? ErrorService { get; set; }

	private EntityFilterEditor? filterEditor;
	private List<<# Definition.Name#>ListItemModel>? <# Definition.NameLow#>s;
	private IReadOnlyList<FilterFieldOption> availableFilterFields = [];
	private bool isLoading;
	private EntityFilter? _lastFilter;

	protected override async Task OnInitializedAsync()
	{
		try
		{
<#for definition in Entries.Where(e => e.IsReference).Select(e => e.ReferenceType).Distinct().Select(n => Definitions.First(d => d.Name == n))
#>			var <# definition.NameLow#>s = await <# definition.Name#>Service.GetItemsAsync();
<#end#>			availableFilterFields = BuildFilterFieldOptions(<#for definition in Entries.Where(e => e.IsReference).Select(e => e.ReferenceType).Distinct().Select(n => Definitions.First(d => d.Name == n))#><# definition.NameLow#>s<#if definition != Entries.Where(e => e.IsReference).Select(e => e.ReferenceType).Distinct().Select(n => Definitions.First(d => d.Name == n)).Last()#>, <#end#><#end#>);

			<# Definition.Name#>Service.ItemCreated += Handle;
			<# Definition.Name#>Service.ItemUpdated += Handle;
			<# Definition.Name#>Service.ItemDeleted += Handle;

			await <# Definition.Name#>Service.StartEventListener();
		}
		catch (<# Project.Namespace#>.Client.Data.Identity.SessionUnavailableException)
		{
			var url = NavigationManager.BuildReturnUrl("/login");
			NavigationManager.NavigateTo(url);
		}
		catch (Exception ex)
		{
			Log.LogError(ex, "Error loading <# Definition.Name#>s.");
			<# Definition.NameLow#>s = [];
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorCouldNotLoad);
		}
	}

	private Task HandleFilterAppliedAsync(EntityFilter filter)
		=> LoadItemsAsync(filter);

	private async Task RefreshAppliedFilterAsync()
	{
		if (filterEditor is null || isLoading)
		{
			return;
		}

		await filterEditor.RefreshAppliedFilterAsync();
	}

	private async Task LoadItemsAsync(EntityFilter filter)
	{
		try
		{
			isLoading = true;
			_lastFilter = filter;

			<# Definition.NameLow#>s = filter.Conditions.Count == 0
				? [.. await <# Definition.Name#>Service.GetItemsAsync().ConfigureAwait(false)]
				: [.. await <# Definition.Name#>Service.GetItemsAsync(filter).ConfigureAwait(false)];
		}
		catch (<# Project.Namespace#>.Client.Data.Identity.SessionUnavailableException)
		{
			var url = NavigationManager.BuildReturnUrl("/login");
			NavigationManager.NavigateTo(url);
		}
		catch (Exception ex)
		{
			Log.LogError(ex, "Error loading filtered <# Definition.Name#>s.");
			ErrorService?.ShowError(ErrorLoc.Error, ex.Message);
		}
		finally
		{
			isLoading = false;
		}

		await InvokeAsync(StateHasChanged);
	}

	private IReadOnlyList<FilterFieldOption> BuildFilterFieldOptions(<#for definition in Entries.Where(e => e.IsReference).Select(e => e.ReferenceType).Distinct().Select(n => Definitions.First(d => d.Name == n))#><# definition.Name#>ListItemModel[] <# definition.NameLow#>s<#if definition != Entries.Where(e => e.IsReference).Select(e => e.ReferenceType).Distinct().Select(n => Definitions.First(d => d.Name == n)).Last()#>, <#end#><#end#>)
	{
		return
		[
<#for entry in Entries.Where(e => !(e.IsKey || e.IsArray || e.IsOwnedType))
#>			new FilterFieldOption
			{
				Key = "<#cs Write(GetFieldPropertyName(entry.Field, entry.IsReference))#>",
				Label = <# Definition.Name#>Loc.<# entry.Field#>,
				Kind = FilterFieldKind.<#cs Write(GetFilterFieldKind(entry.EntryType, entry.IsReference, entry.IsEnumeration))#>,
				Operators = <#if entry.EntryType == "string"#>FilterOperatorCatalog.CreateTextOptions()<#elseif IsComparableType(entry.EntryType)#>FilterOperatorCatalog.CreateComparableOptions(<#cs Write(AllowsEmptyFilter(entry.IsNullable, entry.EntryType) ? "true" : "false")#>)<#else#>FilterOperatorCatalog.CreateEqualityOptions(<#cs Write(AllowsEmptyFilter(entry.IsNullable, entry.EntryType) ? "true" : "false")#>)<#end#>,
				Values = <#if entry.IsReference
#>[.. <# entry.ReferenceTypeLow#>s.Select(item => new FilterValueOption
				{
					Value = item.Id.ToString(),
					Label = Convert.ToString(item.<#cs Write(Definitions.First(d => d.Name == entry.ReferenceType).Entries.First(e => !(e.IsOwnedType || e.IsKey || e.IsArray || e.IsReference || e.IsEnumeration)).Field)#>) ?? CommonLoc.Untitled,
				})]<#elseif entry.IsEnumeration
#>[.. Enum.GetValues<<# entry.EntryType#>>().Select(value => new FilterValueOption
				{
					Value = value.ToString(),
					Label = value.ToString(),
				})]<#elseif entry.EntryType == "bool"
#>[new FilterValueOption { Value = bool.TrueString, Label = bool.TrueString }, new FilterValueOption { Value = bool.FalseString, Label = bool.FalseString }]<#else#>[]<#end#>,
			},
<#end#>		];
	}

	private async Task Handle(object? sender, <# Definition.Name#>Created message)
	{
		if (<# Definition.NameLow#>s is null || _lastFilter is { Conditions.Count: > 0 })
		{
			return;
		}

		var item = Map.From(message).To<<# Definition.Name#>ListItemModel>();

		<# Definition.NameLow#>s.Insert(0, item);

		await InvokeAsync(StateHasChanged);
	}

	private async Task Handle(object? sender, <# Definition.Name#>Updated message)
	{
		if (<# Definition.NameLow#>s is null)
		{
			return;
		}

		var entry = <# Definition.NameLow#>s.FirstOrDefault(t => t.Id == message.Id);

		if (entry is not null)
		{
			Map.From(message).To(entry);
		}

		await InvokeAsync(StateHasChanged);
	}

	private async Task Handle(object? sender, <# Definition.Name#>Deleted message)
	{
		if (<# Definition.NameLow#>s is null)
		{
			return;
		}

		var entry = <# Definition.NameLow#>s.FirstOrDefault(t => t.Id == message.Id);

		if (entry is null)
		{
			return;
		}

		<# Definition.NameLow#>s.Remove(entry);

		await InvokeAsync(StateHasChanged);
	}

	public void Dispose()
	{
		<# Definition.Name#>Service.ItemCreated -= Handle;
		<# Definition.Name#>Service.ItemUpdated -= Handle;
		<# Definition.Name#>Service.ItemDeleted -= Handle;
	}
}
<#cs SetOutputPath(Definition.IsOwnedType || Definition.IsEnumeration || Definition.IsArray)#>