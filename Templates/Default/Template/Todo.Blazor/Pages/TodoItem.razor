<#cs
foreach(var entry in Entries.Where(e => !e.IsArray))
{
	WriteLine($"				<!-- {entry.Field} input -->");
	WriteLine("				<div class=\"form-outline mb-2\">");
	WriteLine($"					<label class=\"form-label\" for=\"{entry.Field}Input\">@{Definition.Name}Loc.{entry.Field}</label>");

	switch (entry.EntryType.ToLower())
	{
		case "string":
			WriteLine($"					<InputText type=\"text\" id=\"{entry.Field}Input\" class=\"form-control\"");
			WriteLine($"							   Value=\"@Model.{entry.Field}\"");
			WriteLine($"							   ValueChanged=\"@((string v) => _changeTracker.TrackChange(Model, nameof(Model.{entry.Field}), Model.{entry.Field}, v))\"");
			WriteLine($"							   ValueExpression=\"@(() => Model.{entry.Field})\" />");
			break;
		case "datetime":
			WriteLine($"					<InputDate id=\"{entry.Field}Input\" class=\"form-control\"");
			WriteLine($"							   Value=\"@Model.{entry.Field}\"");
			WriteLine($"							   ValueChanged=\"@((DateTime v) => _changeTracker.TrackChange(Model, nameof(Model.{entry.Field}), Model.{entry.Field}, v))\"");
			WriteLine($"							   ValueExpression=\"@(() => Model.{entry.Field})\" ParsingErrorMessage=\"@ErrorLoc.ParsingErrorMustBeDate\" />");
			break;
		case "bool":
			WriteLine($"					<InputCheckbox id=\"{entry.Field}Input\" class=\"form-control\"");
			WriteLine($"								   Value=\"@Model.{entry.Field}\"");
			WriteLine($"								   ValueChanged=\"@((bool v) => _changeTracker.TrackChange(Model, nameof(Model.{entry.Field}), Model.{entry.Field}, v))\"");
			WriteLine($"								   ValueExpression=\"@(() => Model.{entry.Field})\" />");
			break;
		case "int":
		case "long":
		case "double":
			WriteLine($"					<InputNumber id=\"{entry.Field}Input\" class=\"form-control\"");
			WriteLine($"								 Value=\"@Model.{entry.Field}\"");
			WriteLine($"								 ValueChanged=\"@(({entry.EntryType} v) => _changeTracker.TrackChange(Model, nameof(Model.{entry.Field}), Model.{entry.Field}, v))\"");
			WriteLine($"								 ValueExpression=\"@(() => Model.{entry.Field})\" ParsingErrorMessage=\"@ErrorLoc.ParsingErrorMustBeNumber\" />");
			break;
		default:
			if (entry.IsEnumeration)
			{
				WriteLine($"					<InputSelect id=\"{entry.Field}Input\" class=\"form-control\"");
				WriteLine($"								 Value=\"@Model.{entry.Field}\"");
				WriteLine($"								 ValueChanged=\"@((Contracts.{entry.EntryType} v) => _changeTracker.TrackChange(Model, nameof(Model.{entry.Field}), Model.{entry.Field}, v))\"");
				WriteLine($"								 ValueExpression=\"@(() => Model.{entry.Field})\" >");
				WriteLine($"						@foreach (var value in Enum.GetValues(typeof(Contracts.{entry.EntryType})))");
				WriteLine("						{");
				WriteLine($"							<option value=\"@value\">@{entry.EntryType}Localizer[$\"{{@value}}\"]</option>");
				WriteLine("						}");
				WriteLine($"					</InputSelect>");
			}
			else if (entry.IsReference)
			{
				WriteLine($"					<InputSelect id=\"{entry.Field}Input\" class=\"form-control\"");
				WriteLine($"								 Value=\"@Model.{entry.Field}Id\"");
				WriteLine($"								 ValueChanged=\"@((Guid v) => _changeTracker.TrackChange(Model, nameof(Model.{entry.Field}Id), Model.{entry.Field}Id, v))\"");
				WriteLine($"								 ValueExpression=\"@(() => Model.{entry.Field}Id)\">");
				WriteLine($"						@foreach (var value in _{entry.ReferenceTypeLow}s)");
				WriteLine("						{");
				var referenceDefinition = Definitions.First(e => e.Name == entry.ReferenceType);
				var referenceEntry = referenceDefinition.Entries.First();
				WriteLine($"							<option value=\"@value.Id\">@value.{referenceEntry.Field}</option>");
				WriteLine("						}");
				WriteLine($"					</InputSelect>");
			}
			else
			{
				WriteLine(entry.EntryType + " ???");
			}
			break;
	}

	WriteLine("				</div>");
	WriteLine("");
}
Result = Result.TrimEnd(' ', '\r', '\n');
WriteLine("");
WriteLine("			</div>");
#>		</section>
<#cs
var arrays = Entries.Where(e => e.IsArray).ToArray();
if (arrays.Any())
{
	WriteLine("		<section>");
}

foreach(var entry in arrays)
{
	WriteLine("			<table class=\"table table-striped\">");
	WriteLine("				<thead>");
	WriteLine("					<tr>");

	var referenceDefinition = Definitions.First(e => e.Name == entry.EntryType);

	foreach(var e in referenceDefinition.Entries)
	{
		WriteLine($"						<th>@{entry.EntryType}Loc.{e.Field}</th>");
	}

	WriteLine("						<th>");
	WriteLine("							<IconButton Icon=\"Add\"");
	WriteLine("										ButtonClass=\"btn btn-success\"");
	WriteLine($"										Execute=\"Add{entry.Field}Entry\"");
	WriteLine("										Title=\"@CommonLoc.New\" />");
	WriteLine("						</th>");
	WriteLine("					</tr>");
	WriteLine("				</thead>");
	WriteLine("				<tbody>");
	WriteLine($"					@foreach (var entry in Model.{entry.Field})");
	WriteLine("					{");
	WriteLine("						<tr scope=\"row\">");
	foreach(var e in referenceDefinition.Entries)
	{
		switch (e.EntryType.ToLower())
		{
			case "bool":
				WriteLine($"							<td><input type=\"checkbox\" class=\"form-check-input\" checked=\"@entry.{e.Field}\" @onchange=\"@(ev => _changeTracker.TrackChange(entry, nameof(entry.{e.Field}), entry.{e.Field}, (bool)(ev.Value ?? false)))\" /></td>");
			break;
			default:
				WriteLine($"							<td><input type=\"text\" class=\"form-control\" value=\"@entry.{e.Field}\" @onchange=\"@(ev => _changeTracker.TrackChange(entry, nameof(entry.{e.Field}), entry.{e.Field}, ev.Value?.ToString() ?? string.Empty))\" /></td>");
				break;
		}
	}
	WriteLine("							<td>");
	WriteLine("								<IconButton Icon=\"Delete\"");
	WriteLine("											ButtonClass=\"btn btn-danger\"");
	WriteLine($"											Execute=\"() => Remove{entry.Field}Entry(entry.Id)\"");
	WriteLine("											Title=\"@CommonLoc.Delete\" />");
	WriteLine("							</td>");
	WriteLine("						</tr>");
	WriteLine("					}");
	WriteLine("				</tbody>");
	WriteLine("			</table>");
}

if (arrays.Any())
{
	WriteLine("		</section>");
}
#>	</EditForm>

	<DeleteConfirmationDialog @bind-IsVisible="isDeleteRequested" Remove="Remove" />
}

