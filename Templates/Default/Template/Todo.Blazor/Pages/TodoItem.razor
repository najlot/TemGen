@page "/<#cs Write(Definition.Name.ToLower())#>/{id:guid}"
@using Microsoft.Extensions.Localization;
@using <# Project.Namespace#>.Blazor.Identity;
@using <# Project.Namespace#>.Blazor.Services;
<#if Definitions.Any(d => d.IsArray)
#>@using <# Project.Namespace#>.Client.Data.Mappings;
<#end#>@using <# Project.Namespace#>.Client.Data.Models;
@using <# Project.Namespace#>.Client.Data.Services;
@using <# Project.Namespace#>.Client.Data;
@using <# Project.Namespace#>.Client.Localisation;
@using <# Project.Namespace#>.Contracts;
@using <# Project.Namespace#>.Contracts.Events;
@inject ILogger<<# Definition.Name#>> Log
@inject Najlot.Map.IMap Map;
@inject I<# Definition.Name#>Service <# Definition.Name#>Service<#if Entries.Any(e => e.IsReference)
#>
<#for entry in Entries.Where(e => e.IsReference)
#>@inject I<# entry.ReferenceType#>Service <# entry.ReferenceType#>Service
<#end#><#end#>
@inject NavigationManager NavigationManager
<#for entry in Entries.Where(e => e.IsEnumeration)
#>@inject IStringLocalizer<<# entry.EntryType#>Loc> <# entry.EntryType#>Localizer
<#end#>
@attribute [Authorize]
@implements IDisposable

@if (isNew)
{
	<PageTitle>@<# Definition.Name#>Loc.Create<# Definition.Name#></PageTitle>
}
else
{
	<PageTitle>@<# Definition.Name#>Loc.Edit<# Definition.Name#></PageTitle>
}

@if (Model == null)
{
	<p><em>@CommonLoc.Loading...</em></p>
}
else
{
	<section class="d-grid gap-4">
		<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3">
			<div>
				@if (isNew)
				{
					<h1 class="mb-1">@<# Definition.Name#>Loc.Create<# Definition.Name#></h1>
				}
				else
				{
					<h1 class="mb-1">@<# Definition.Name#>Loc.Edit<# Definition.Name#></h1>
				}
			</div>
			<div class="d-flex flex-wrap gap-2">
				<IconButton Icon="Undo"
							ButtonClass="btn btn-outline-secondary"
							CanExecute="() => _changeTracker.CanUndo"
							Execute="_changeTracker.Undo" />
				<IconButton Icon="Redo"
							ButtonClass="btn btn-outline-secondary"
							CanExecute="() => _changeTracker.CanRedo"
							Execute="_changeTracker.Redo" />
				<IconButton Icon="Save"
							ButtonClass="btn btn-success"
							CanExecute="() => _changeTracker.CanUndo"
							Execute="Save"
							Title="@CommonLoc.Save" />
				<IconButton Icon="Delete"
							ButtonClass="btn btn-danger"
							CanExecute="() => !isDeleteRequested"
							Execute="() => isDeleteRequested = true"
							Title="@CommonLoc.Delete" />
			</div>
		</div>

		<EditForm Model="@Model" OnValidSubmit="@Save">
			<div class="card shadow-sm border-0">
				<div class="card-body">
					<DataAnnotationsValidator />
					<ValidationSummary class="alert alert-danger mb-4" />
					<div class="row g-3">
<#for entry in Entries.Where(e => !e.IsArray)#>
						<!-- <# entry.Field#> input -->
						<div class="<#if entry.IsOwnedType
#>col-12<#elseif entry.EntryType.ToLower() == "bool"
#>col-12 col-md-6<#else
#>col-12 col-md-6<#end#>">
<#if entry.EntryType.ToLower() == "string"
#>							<label class="form-label" for="<# entry.Field#>Input">@<# Definition.Name#>Loc.<# entry.Field#></label>
							<InputText type="text" id="<# entry.Field#>Input" class="form-control"
							   Value="@Model.<# entry.Field#>"
							   ValueChanged="@((string v) => _changeTracker.TrackChange(Model, nameof(Model.<# entry.Field#>), Model.<# entry.Field#>, v))"
							   ValueExpression="@(() => Model.<# entry.Field#>)" />
<#elseif entry.EntryType.ToLower() == "datetime"
#>							<label class="form-label" for="<# entry.Field#>Input">@<# Definition.Name#>Loc.<# entry.Field#></label>
							<InputDate id="<# entry.Field#>Input" class="form-control"
							   Value="@Model.<# entry.Field#>"
							   ValueChanged="@((DateTime v) => _changeTracker.TrackChange(Model, nameof(Model.<# entry.Field#>), Model.<# entry.Field#>, v))"
							   ValueExpression="@(() => Model.<# entry.Field#>)" ParsingErrorMessage="@ErrorLoc.ParsingErrorMustBeDate" />
<#elseif entry.EntryType.ToLower() == "bool"
#>							<div class="form-check mt-md-4 pt-md-2">
								<InputCheckbox id="<# entry.Field#>Input" class="form-check-input"
								   Value="@Model.<# entry.Field#>"
								   ValueChanged="@((bool v) => _changeTracker.TrackChange(Model, nameof(Model.<# entry.Field#>), Model.<# entry.Field#>, v))"
								   ValueExpression="@(() => Model.<# entry.Field#>)" />
								<label class="form-check-label" for="<# entry.Field#>Input">@<# Definition.Name#>Loc.<# entry.Field#></label>
							</div>
<#elseif entry.EntryType.ToLower() == "int" || entry.EntryType.ToLower() == "long" || entry.EntryType.ToLower() == "double"
#>							<label class="form-label" for="<# entry.Field#>Input">@<# Definition.Name#>Loc.<# entry.Field#></label>
							<InputNumber id="<# entry.Field#>Input" class="form-control"
							 Value="@Model.<# entry.Field#>"
							 ValueChanged="@((<# entry.EntryType#> v) => _changeTracker.TrackChange(Model, nameof(Model.<# entry.Field#>), Model.<# entry.Field#>, v))"
							 ValueExpression="@(() => Model.<# entry.Field#>)" ParsingErrorMessage="@ErrorLoc.ParsingErrorMustBeNumber" />
<#elseif entry.IsOwnedType
#>							<div class="card bg-body-tertiary border-0 h-100">
								<div class="card-body">
									<h2 class="h5 mb-3">@<# Definition.Name#>Loc.<# entry.Field#></h2>
									@if (Model.<# entry.Field#> is not null)
									{
										<<# entry.EntryType#>Editor Model="@Model.<# entry.Field#>" ChangeTracker="_changeTracker" />
									}
								</div>
							</div>
<#elseif entry.IsEnumeration
#>							<label class="form-label" for="<# entry.Field#>Input">@<# Definition.Name#>Loc.<# entry.Field#></label>
							<InputSelect id="<# entry.Field#>Input" class="form-select"
								 Value="@Model.<# entry.Field#>"
								 ValueChanged="@((Contracts.<# entry.EntryType#> v) => _changeTracker.TrackChange(Model, nameof(Model.<# entry.Field#>), Model.<# entry.Field#>, v))"
								 ValueExpression="@(() => Model.<# entry.Field#>)" >
						@foreach (var value in Enum.GetValues(typeof(Contracts.<# entry.EntryType#>)))
						{
							<option value="@value">@<# entry.EntryType#>Localizer[$"{@value}"]</option>
						}
					</InputSelect>
<#elseif entry.IsReference
#>							<label class="form-label" for="<# entry.Field#>Input">@<# Definition.Name#>Loc.<# entry.Field#></label>
							<InputSelect id="<# entry.Field#>Input" class="form-select"
								 Value="@Model.<# entry.Field#>Id"
								 ValueChanged="@((Guid v) => _changeTracker.TrackChange(Model, nameof(Model.<# entry.Field#>Id), Model.<# entry.Field#>Id, v))"
								 ValueExpression="@(() => Model.<# entry.Field#>Id)">
						@foreach (var value in _<# entry.ReferenceTypeLow#>s)
						{
							<option value="@value.Id">@value.<#cs Write(Definitions.First(e => e.Name == entry.ReferenceType).Entries.First().Field)#></option>
						}
					</InputSelect>
<#else
#><# entry.EntryType;#> ???<#end
#>						</div>
<#end
#>					</div>
				</div>
			</div>
<#for entry in Entries.Where(e => e.IsArray)
#>			<div class="card shadow-sm border-0">
				<div class="card-header bg-body-tertiary d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
					<h2 class="h5 mb-0">@<# Definition.Name#>Loc.<# entry.Field#></h2>
					<IconButton Icon="Add"
								ButtonClass="btn btn-success"
								Execute="Add<# entry.Field#>Entry"
								Title="@CommonLoc.New" />
				</div>
				<div class="table-responsive">
					<table class="table table-striped align-middle mb-0">
						<thead class="table-light">
							<tr>
<#for e in Definitions.First(definition => definition.Name == entry.EntryType).Entries
#>								<th>@<# entry.EntryType#>Loc.<# e.Field#></th>
<#end#>								<th class="text-end">@CommonLoc.Delete</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var entry in Model.<# entry.Field#>)
							{
								<tr scope="row">
<#for e in Definitions.First(definition => definition.Name == entry.EntryType).Entries
#><#if e.EntryType.ToLower() == "bool"
#>									<td><input type="checkbox" class="form-check-input" checked="@entry.<# e.Field#>" @onchange="@(ev => _changeTracker.TrackChange(entry, nameof(entry.<# e.Field#>), entry.<# e.Field#>, (bool)(ev.Value ?? false)))" /></td>
<#else
#>									<td><input type="text" class="form-control" value="@entry.<# e.Field#>" @onchange="@(ev => _changeTracker.TrackChange(entry, nameof(entry.<# e.Field#>), entry.<# e.Field#>, ev.Value?.ToString() ?? string.Empty))" /></td>
<#end#><#end#>									<td class="text-end">
								<IconButton Icon="Delete"
											ButtonClass="btn btn-danger"
											Execute="() => Remove<# entry.Field#>Entry(entry.Id)"
											Title="@CommonLoc.Delete" />
							</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			</div>
<#end#>		</EditForm>
	</section>

	<DeleteConfirmationDialog @bind-IsVisible="isDeleteRequested" Remove="Remove" />
}

@code {
	[CascadingParameter(Name = "ErrorService")]
	protected IErrorService? ErrorService { get; set; }

	[Parameter]
	public Guid Id { get; set; }

	private bool isNew = false;
	private bool isDeleteRequested = false;
	private <# Definition.Name#>Model? Model;
	private readonly ChangeTracker _changeTracker = new();

<#for entry in Entries.Where(e => e.IsReference)
#>	private IEnumerable<<# entry.ReferenceType#>ListItemModel> _<# entry.ReferenceTypeLow#>s = [];
<#end#>
	protected override async Task OnInitializedAsync()
	{
		try
		{
			if (Id == Guid.Empty)
			{
				Model = <# Definition.Name#>Service.Create<# Definition.Name#>();
				isNew = true;
			}
			else
			{
				Model = await <# Definition.Name#>Service.GetItemAsync(Id);
			}

<#for entry in Entries.Where(e => e.IsReference)
#>			_<# entry.ReferenceTypeLow#>s = await <# entry.ReferenceType#>Service.GetItemsAsync();
<#end#>
			<# Definition.Name#>Service.ItemUpdated += Handle;
			_changeTracker.StateChanged += () => InvokeAsync(StateHasChanged);

			await <# Definition.Name#>Service.StartEventListener();
		}
		catch (System.Security.Authentication.AuthenticationException)
		{
			var url = NavigationManager.BuildReturnUrl("/login");
			NavigationManager.NavigateTo(url);
		}
		catch (Exception ex)
		{
			Log.LogError(ex, "Error loading <# Definition.Name#>.");
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorCouldNotLoad);
		}
	}

	private async Task Save()
	{
		if (Model is null)
		{
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorModelIsNullReload);
			return;
		}

		try
		{
			if (isNew)
			{
				await <# Definition.Name#>Service.AddItemAsync(Model);
				Id = Model.Id;
				NavigationManager.NavigateTo($"/<#cs
var name = Definition.Name.ToLower();
if (name.EndsWith("entry"))
{
	name = name[0..^5] + "entrie";
}
Write(name);
#>/{Model.Id}", false, true);
				isNew = false;
			}
			else
			{
				await <# Definition.Name#>Service.UpdateItemAsync(Model);
			}

			_changeTracker.Clear();
		}
		catch (System.Security.Authentication.AuthenticationException)
		{
			var url = NavigationManager.BuildReturnUrl("/login");
			NavigationManager.NavigateTo(url);
		}
		catch (Exception ex)
		{
			Log.LogError(ex, "Error saving <# Definition.Name#>.");
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorCouldNotSave);
		}
	}

	private async Task Remove()
	{
		if (Model is null)
		{
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorModelIsNullReload);
			return;
		}

		try
		{
			if (!isNew)
			{
				await <# Definition.Name#>Service.DeleteItemAsync(Model.Id);
			}

			_changeTracker.Clear();
			NavigationManager.NavigateTo("/<#cs
var name = Definition.Name.ToLower();
if (name.EndsWith("entry"))
{
	name = name[0..^5] + "entrie";
}
Write(name);
#>s");
		}
		catch (System.Security.Authentication.AuthenticationException)
		{
			var url = NavigationManager.BuildReturnUrl("/login");
			NavigationManager.NavigateTo(url);
		}
		catch (Exception ex)
		{
			Log.LogError(ex, "Error deleting <# Definition.Name#>.");
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorDeleting);
		}
	}

	private async Task Handle(object? sender, <# Definition.Name#>Updated message)
	{
		if (Model is null || Model.Id != message.Id)
		{
			return;
		}

		Map.From(message).To(Model);
		_changeTracker.Clear();

		await InvokeAsync(StateHasChanged);
	}
<#for entry in Entries.Where(e => e.IsArray)
#>
	private void Add<# entry.Field#>Entry()
	{
		if (Model is null)
		{
			return;
		}

		var max = 0;

		if (Model.<# entry.Field#>.Count > 0)
		{
			max = Model.<# entry.Field#>.Max(e => e.Id) + 1;
		}

		var model = new <# entry.EntryType#>Model() { Id = max };

		Model.<# entry.Field#>.Add(model);

		_changeTracker.Track(
			nameof(Model.<# entry.Field#>),
			() => Model.<# entry.Field#>.Remove(model),
			() => Model.<# entry.Field#>.Add(model));
	}

	private void Remove<# entry.Field#>Entry(int id)
	{
		if (Model is null)
		{
			return;
		}

		var oldItem = Model.<# entry.Field#>.FirstOrDefault(i => i.Id == id);

		if (oldItem != null)
		{
			var index = Model.<# entry.Field#>.IndexOf(oldItem);

			if (index != -1)
			{
				Model.<# entry.Field#>.RemoveAt(index);

				_changeTracker.Track(
					nameof(Model.<# entry.Field#>),
					() => Model.<# entry.Field#>.Insert(index, oldItem),
					() => Model.<# entry.Field#>.Remove(oldItem));
			}
		}
	}
<#end#>
	public void Dispose()
	{
		<# Definition.Name#>Service.ItemUpdated -= Handle;
	}
}
<#cs SetOutputPath(Definition.IsOwnedType || Definition.IsEnumeration || Definition.IsArray)#>