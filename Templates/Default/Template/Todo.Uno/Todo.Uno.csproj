<Project Sdk="Uno.Sdk/6.4.40">

	<PropertyGroup>
		<TargetFrameworks>net10.0-android;net10.0-browserwasm;net10.0-desktop;net10.0</TargetFrameworks>
		<OutputType>Exe</OutputType>
		<UnoSingleProject>true</UnoSingleProject>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<ApplicationTitle><#cs Write(Project.Namespace)#></ApplicationTitle>
		<ApplicationId>com.temgen.<#cs Write(Project.Namespace.ToLowerInvariant().Replace(".", ""))#></ApplicationId>
		<ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
		<ApplicationVersion>1</ApplicationVersion>
		<ApplicationPublisher>TemGen</ApplicationPublisher>
		<Description><#cs Write(Project.Namespace)#> powered by Uno Platform.</Description>
		<UnoFeatures>
			Material;
			Dsp;
			Hosting;
			Toolkit;
			Logging;
			MVUX;
			Configuration;
			Serialization;
			Localization;
			Authentication;
			Navigation;
			ThemeService;
			SkiaRenderer;
		</UnoFeatures>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)'=='Debug' or '$(IsUiAutomationMappingEnabled)'=='True'">
		<IsUiAutomationMappingEnabled>True</IsUiAutomationMappingEnabled>
		<DefineConstants>$(DefineConstants);USE_UITESTS</DefineConstants>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Uno.Microsoft.Xaml.Behaviors.WinUI.Managed" Version="2.4.2" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\<#cs Write(Project.Namespace)#>.ClientBase\<#cs Write(Project.Namespace)#>.ClientBase.csproj" />
	</ItemGroup>

</Project>
<#cs SetOutputPathAndSkipOtherDefinitions()#>
