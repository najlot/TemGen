<Application x:Class="<#cs Write(Project.Namespace)#>.Uno.App"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:converter="using:<#cs Write(Project.Namespace)#>.Uno.Converter">
	<Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="Styles.xaml" />
			</ResourceDictionary.MergedDictionaries>
			<converter:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
			<converter:BooleanToVisibilityCollapsedConverter x:Key="BooleanToVisibilityCollapsedConverter" />
			<converter:EnumToTranslationConverter x:Key="EnumToTranslationConverter" />
		</ResourceDictionary>
	</Application.Resources>
</Application>
<#cs SetOutputPathAndSkipOtherDefinitions()#>
