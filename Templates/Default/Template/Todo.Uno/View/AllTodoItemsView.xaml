<UserControl x:Class="<#cs Write(Project.Namespace)#>.Uno.View.All<#cs Write(Definition.Name)#>sView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:local="using:<#cs Write(Project.Namespace)#>.Uno.View"
			 xmlns:loc="using:<#cs Write(Project.Namespace)#>.Client.Localisation"
			 xmlns:utu="using:Uno.Toolkit.UI"
			 xmlns:i="using:Microsoft.Xaml.Interactivity"
			 xmlns:core="using:Microsoft.Xaml.Interactions.Core"
			 mc:Ignorable="d"
			 d:DesignHeight="450"
			 d:DesignWidth="800">
	<utu:DockPanel>
		<utu:DockPanel utu:DockPanel.Dock="Top">
			<Button Margin="5" utu:DockPanel.Dock="Left" Command="{Binding NavigateBackCommand}">
				<SymbolIcon Symbol="Back" />
			</Button>

			<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" utu:DockPanel.Dock="Right">
				<Button Margin="5"
						Command="{Binding Refresh<#cs Write(Definition.Name)#>sCommand}"
						ToolTipService.ToolTip="{x:Static loc:CommonLoc.Refresh}">
					<SymbolIcon Symbol="Refresh" />
				</Button>

				<Button Margin="5"
						Command="{Binding Add<#cs Write(Definition.Name)#>Command}"
						ToolTipService.ToolTip="{x:Static loc:CommonLoc.New}">
					<SymbolIcon Symbol="Add" />
				</Button>
			</StackPanel>

			<utu:DockPanel utu:DockPanel.Dock="Left">
				<TextBlock VerticalAlignment="Center" Text="{x:Static loc:CommonLoc.Filter}" Margin="5" />
				<TextBox Margin="5"
						 VerticalAlignment="Center"
						 Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
			</utu:DockPanel>
		</utu:DockPanel>

		<ScrollViewer>
			<ItemsControl ItemsSource="{Binding <#cs Write(Definition.Name)#>sView}">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<StackPanel Margin="5">
<#cs
foreach(var entry in Entries.Where(e => !(e.IsKey || e.IsArray || e.IsReference || e.IsOwnedType)).Take(2))
{
	WriteLine($"							<TextBlock Padding=\"5,5,5,0\" Text=\"{{Binding {entry.Field}}}\">");
	WriteLine("								<i:Interaction.Triggers>");
	WriteLine("									<i:EventTrigger EventName=\"Tapped\">");
	WriteLine($"										<i:InvokeCommandAction Command=\"{{Binding DataContext.Edit{Definition.Name}Command, RelativeSource={{RelativeSource AncestorType=local:All{Definition.Name}sView}}}}\" CommandParameter=\"{{Binding .}}\" />");
	WriteLine("									</i:EventTrigger>");
	WriteLine("								</i:Interaction.Triggers>");
	WriteLine("							</TextBlock>");
}

Result = Result.TrimEnd();
#>
						</StackPanel>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</utu:DockPanel>
</UserControl>
<#cs SetOutputPath(Definition.IsOwnedType || Definition.IsEnumeration || Definition.IsArray)#>
