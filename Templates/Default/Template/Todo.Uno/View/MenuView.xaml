<UserControl x:Class="<#cs Write(Project.Namespace)#>.Uno.View.MenuView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:loc="using:<#cs Write(Project.Namespace)#>.Client.Localisation"
			 xmlns:converter="using:<#cs Write(Project.Namespace)#>.Uno.Converter"
			 xmlns:utu="using:Uno.Toolkit.UI"
			 xmlns:i="using:Microsoft.Xaml.Interactivity"
			 xmlns:core="using:Microsoft.Xaml.Interactions.Core"
			 mc:Ignorable="d"
			 d:DesignHeight="450" d:DesignWidth="800">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
			<Button Command="{Binding ToggleDrawerCommand}" Margin="5">
				<SymbolIcon Symbol="GlobalNavigationButton" />
			</Button>
		</StackPanel>

		<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
			<Button Command="{Binding ManageCommand}" ToolTipService.ToolTip="Manage" Margin="5">
				<SymbolIcon Symbol="People" />
			</Button>
			<Button Command="{Binding LogoutCommand}" ToolTipService.ToolTip="Logout" Margin="5">
				<SymbolIcon Symbol="LeaveChat" />
			</Button>
		</StackPanel>

		<!--  Overlay (visible when drawer is open)  -->
		<Border Background="#80000000"
				Grid.RowSpan="2"
				Visibility="{Binding IsDrawerOpen, Converter={x:Static converter:BooleanToVisibilityConverter.Instance}}"
				Canvas.ZIndex="1">
			<i:Interaction.Behaviors>
				<core:EventTriggerBehavior EventName="Tapped">
					<core:InvokeCommandAction Command="{Binding ToggleDrawerCommand}" />
				</core:EventTriggerBehavior>
			</i:Interaction.Behaviors>
		</Border>

		<!--  Off-Canvas Navigation Drawer  -->
		<Border Width="200"
				Background="White"
				HorizontalAlignment="Left"
				Grid.RowSpan="2"
				Visibility="{Binding IsDrawerOpen, Converter={x:Static converter:BooleanToVisibilityConverter.Instance}}"
				Canvas.ZIndex="2">
			<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
				<StackPanel Margin="5">
					<!--  Drawer Header  -->
					<TextBlock FontSize="20" FontWeight="SemiBold" Text="{x:Static loc:CommonLoc.Navigation}" Margin="5,10" />

					<!--  Navigation Items  -->
<#cs
foreach(var definition in Definitions.Where(d => !d.IsOwnedType
&& !d.IsArray
&& !d.IsEnumeration
&& !d.Name.Equals("user", StringComparison.OrdinalIgnoreCase)))
{
	WriteLine($"					<Button Command=\"{{Binding NavigateTo{definition.Name}s}}\" Margin=\"5\" HorizontalContentAlignment=\"Left\">");
	WriteLine($"						<StackPanel Orientation=\"Horizontal\">");
	WriteLine($"							<SymbolIcon Symbol=\"Note\" Margin=\"0,0,10,0\" />");
	WriteLine($"							<TextBlock VerticalAlignment=\"Center\" Text=\"{{x:Static loc:{definition.Name}Loc.{definition.Name}s}}\" />");
	WriteLine($"						</StackPanel>");
	WriteLine($"					</Button>");
	WriteLine("");
}

Result = Result.TrimEnd();
#>
				</StackPanel>
			</ScrollViewer>
		</Border>
	</Grid>
</UserControl>
<#cs SetOutputPathAndSkipOtherDefinitions()#>
