<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:<#cs Write(Project.Namespace)#>.Avalonia.View"
             xmlns:loc="clr-namespace:<#cs Write(Project.Namespace)#>.Client.Localisation;assembly=<#cs Write(Project.Namespace)#>.Client.Localisation"
             xmlns:converter="clr-namespace:<#cs Write(Project.Namespace)#>.Avalonia.Converter"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d"
             x:Class="<#cs Write(Project.Namespace)#>.Avalonia.View.<#cs Write(Definition.Name)#>View"
             d:DesignHeight="500" d:DesignWidth="600">
	<Grid>
		<DockPanel IsEnabled="{Binding CanEdit}">
			<DockPanel DockPanel.Dock="Top">
				<Button Margin="5"
						DockPanel.Dock="Left"
						Command="{Binding NavigateBackCommand}">
					<materialIcons:MaterialIcon Kind="ArrowLeft" Width="18" Height="18" />
				</Button>

				<WrapPanel HorizontalAlignment="Right" DockPanel.Dock="Right">
					<Button ToolTip.Tip="{x:Static loc:CommonLoc.Undo}" Command="{Binding UndoCommand}" Margin="5">
						<materialIcons:MaterialIcon Kind="Undo" Width="18" Height="18" />
					</Button>
					<Button ToolTip.Tip="{x:Static loc:CommonLoc.Redo}" Command="{Binding RedoCommand}" Margin="5">
						<materialIcons:MaterialIcon Kind="Redo" Width="18" Height="18" />
					</Button>
					<Button ToolTip.Tip="{x:Static loc:CommonLoc.Save}" Command="{Binding SaveCommand}" Margin="5">
						<materialIcons:MaterialIcon Kind="ContentSave" Width="18" Height="18" />
					</Button>
					<Button ToolTip.Tip="{x:Static loc:CommonLoc.Delete}" Command="{Binding DeleteCommand}" Margin="5">
						<materialIcons:MaterialIcon Kind="Delete" Width="18" Height="18" />
					</Button>
				</WrapPanel>
			</DockPanel>
			<ScrollViewer>
				<StackPanel Margin="2,0" MinWidth="400" MinHeight="200"
						HorizontalAlignment="Center" VerticalAlignment="Center">
<#cs
foreach(var entry in Entries)
{
	if (!entry.IsArray && !entry.IsOwnedType)
		WriteLine("					<DockPanel Margin=\"5\">");

	if (entry.EntryType != "bool" && !entry.IsArray && !entry.IsOwnedType)
	{
		WriteLine($"						<Label Content=\"{{x:Static loc:{Definition.Name}Loc.{entry.Field}}}\" MinWidth=\"75\" />");
	}

	if (entry.EntryType == "DateTime")
	{
		WriteLine($"						<CalendarDatePicker SelectedDate=\"{{Binding {entry.Field}}}\" />");
	}
	else if (entry.EntryType == "bool")
	{
		WriteLine($"						<Label Content=\"\" MinWidth=\"75\" />");
		WriteLine($"						<CheckBox IsChecked=\"{{Binding {entry.Field}}}\" Content=\"{{x:Static loc:{Definition.Name}Loc.{entry.Field}}}\" />");
	}
	else if (entry.IsReference)
	{
		var definition  = Definitions.First(d => d.Name == entry.ReferenceType);
		var displayField = definition.Entries.First(e => !(e.IsOwnedType || e.IsKey || e.IsArray || e.IsReference || e.IsEnumeration)).Field;
		WriteLine($"						<ComboBox ItemsSource=\"{{Binding Available{definition.Name}s}}\" SelectedValue=\"{{Binding {entry.Field}Id}}\" SelectedValueBinding=\"{{Binding Id}}\" DisplayMemberBinding=\"{{Binding {displayField}}}\" IsEditable=\"True\" />");
	}
	else if (entry.IsOwnedType)
	{
		WriteLine($"					<Label Content=\"{{x:Static loc:{Definition.Name}Loc.{entry.Field}}}\" Foreground=\"{{StaticResource ForegroundColor}}\" Background=\"{{StaticResource BackgroundColor}}\" />");
		WriteLine($"					<local:{entry.EntryType}View DataContext=\"{{Binding {entry.Field}}}\" />");
	}
	else if (entry.IsEnumeration)
	{
		WriteLine($"\t\t\t\t\t\t<ComboBox ItemsSource=\"{{Binding Available{entry.EntryType}s, Converter={{x:Static converter:EnumToTranslationConverter.Instance}}, ConverterParameter={{x:Type loc:{entry.EntryType}Loc}}}}\" ");
		WriteLine($"\t\t\t\t\t\t\t  SelectedItem=\"{{Binding {entry.Field}, Converter={{x:Static converter:EnumToTranslationConverter.Instance}}, ConverterParameter={{x:Type loc:{entry.EntryType}Loc}}}}\" />");
	}
	else if (entry.IsArray)
	{
		var d = Definitions.First(def => def.Name == entry.EntryType);
		WriteLine("					<DockPanel>");
		WriteLine($"						<DockPanel DockPanel.Dock=\"Top\">");
		WriteLine($"							<Button ToolTip.Tip=\"{{x:Static loc:CommonLoc.New}}\" Command=\"{{Binding Add{entry.EntryType}Command}}\" Margin=\"5\" DockPanel.Dock=\"Right\">");
		WriteLine($"								<materialIcons:MaterialIcon Kind=\"PlusCircle\" Width=\"18\" Height=\"18\" />");
		WriteLine($"							</Button>");
		WriteLine($"");
		WriteLine($"							<TextBlock Text=\"{{x:Static loc:{Definition.Name}Loc.{entry.Field}}}\" Foreground=\"{{StaticResource ForegroundColor}}\" Background=\"{{StaticResource BackgroundColor}}\" Padding=\"5\" Margin=\"0,5\"/>");
		WriteLine($"						</DockPanel>");
		WriteLine($"");
		WriteLine($"						<DataGrid");
		WriteLine($"							Margin=\"0,0,5,0\"");
		WriteLine($"							ItemsSource=\"{{Binding {entry.Field}}}\"");
		WriteLine($"							CanUserSortColumns=\"False\"");
		WriteLine($"							CanUserAddRows=\"False\"");
		WriteLine($"							AutoGenerateColumns=\"False\"");
		WriteLine($"							HorizontalGridLinesBrush=\"LightGray\"");
		WriteLine($"							VerticalGridLinesBrush=\"LightGray\"");
		WriteLine($"							SelectionMode=\"Single\"");
		WriteLine($"							BorderBrush=\"LightGray\">");
		WriteLine($"");
		WriteLine($"							<DataGrid.Columns>");
		foreach(var e in d.Entries.Where(ent => !ent.IsEnumeration))
		{
			if (e.EntryType == "bool")
			{
				WriteLine($"								<DataGridCheckBoxColumn Header=\"{{x:Static loc:{d.Name}Loc.{e.Field}}}\" Binding=\"{{Binding {e.Field}}}\" />");
			}
			else
			{
				WriteLine($"								<DataGridTextColumn Header=\"{{x:Static loc:{d.Name}Loc.{e.Field}}}\" Binding=\"{{Binding {e.Field}}}\" MinWidth=\"100\" />");
			}
			WriteLine($"");
		}

		WriteLine($"								<DataGridTemplateColumn Header=\"Delete\" Width=\"SizeToCells\">");
		WriteLine($"									<DataGridTemplateColumn.CellTemplate>");
		WriteLine($"										<DataTemplate>");
		WriteLine($"											<Button ToolTip.Tip=\"Delete\" Padding=\"2\"");
		WriteLine($"												Command=\"{{Binding DataContext.Delete{entry.EntryType}Command, RelativeSource={{RelativeSource AncestorType=local:{Definition.Name}View}}}}\" CommandParameter=\"{{Binding .}}\">");
		WriteLine($"												<materialIcons:MaterialIcon Kind=\"Delete\" Width=\"14\" Height=\"14\" />");
		WriteLine($"											</Button>");
		WriteLine($"										</DataTemplate>");
		WriteLine($"									</DataGridTemplateColumn.CellTemplate>");
		WriteLine($"								</DataGridTemplateColumn>");
		WriteLine($"							</DataGrid.Columns>");
		WriteLine($"						</DataGrid>");
	}
	else
	{
		WriteLine($"						<TextBox Text=\"{{Binding {entry.Field}}}\" />");
	}

	if (!entry.IsOwnedType)
		WriteLine("					</DockPanel>");
}

Result = Result.TrimEnd();
#>
				</StackPanel>
			</ScrollViewer>
		</DockPanel>

		<local:SaveConfirmationDialogView IsVisible="{Binding SaveDialogViewModel.IsVisible}"
		                                  DataContext="{Binding SaveDialogViewModel}" />
		<local:DeleteConfirmationDialogView IsVisible="{Binding DeleteDialogViewModel.IsVisible}"
		                                    DataContext="{Binding DeleteDialogViewModel}" />
	</Grid>
</UserControl>
<#cs SetOutputPath(Definition.IsEnumeration || Definition.IsOwnedType)#>
