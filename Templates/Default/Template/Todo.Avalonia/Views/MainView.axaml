<UserControl x:Class="<#cs Write(Project.Namespace)#>.Avalonia.Views.MainView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="600"
             d:DesignWidth="800"
             mc:Ignorable="d">
	<Grid RowDefinitions="Auto,Auto,*">
		<Border x:Name="ErrorBorder"
		        Grid.Row="0"
		        Margin="16,8"
		        Padding="12"
		        Background="#FFDDDD"
		        BorderBrush="#CC0000"
		        BorderThickness="1"
		        IsVisible="False">
			<TextBlock x:Name="ErrorText" Foreground="#CC0000" TextWrapping="Wrap" />
		</Border>

		<Border x:Name="SuccessBorder"
		        Grid.Row="1"
		        Margin="16,8"
		        Padding="12"
		        Background="#DDFFDD"
		        BorderBrush="#00CC00"
		        BorderThickness="1"
		        IsVisible="False">
			<TextBlock x:Name="SuccessText" Foreground="#006600" TextWrapping="Wrap" />
		</Border>

		<ContentControl x:Name="ContentHost" Grid.Row="2" />
	</Grid>
</UserControl>
<#cs SetOutputPathAndSkipOtherDefinitions()#>