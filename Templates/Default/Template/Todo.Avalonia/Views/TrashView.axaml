<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="using:<#cs Write(Project.Namespace)#>.Avalonia.Views"
             mc:Ignorable="d"
             d:DesignWidth="1000"
             d:DesignHeight="700"
             x:Class="<#cs Write(Project.Namespace)#>.Avalonia.Views.TrashView">
  <Grid>
    <DockPanel>
      <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto,Auto" Margin="12">
        <Button Grid.Column="0" Margin="0,0,8,0" Command="{Binding NavigateBackCommand}" Content="Back" />
        <TextBox Grid.Column="1" Text="{Binding Filter, Mode=TwoWay}" Watermark="Filter trash" />
        <Button Grid.Column="2" Margin="8,0,0,0" Command="{Binding RefreshTrashCommand}" Content="Refresh" />
        <Button Grid.Column="3" Margin="8,0,0,0" Command="{Binding DeleteAllTrashCommand}" Content="Delete all" />
      </Grid>

      <ScrollViewer Margin="12,0,12,12">
        <ItemsControl ItemsSource="{Binding TrashItemsView}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Margin="0,0,0,8" Padding="12" Background="#FFF5F5F4" BorderBrush="#FFE7E5E4" BorderThickness="1" CornerRadius="10">
                <StackPanel>
                  <DockPanel>
                    <TextBlock DockPanel.Dock="Right" Foreground="#FF78716C" Text="{Binding DeletedAtDisplay}" />
                    <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                  </DockPanel>
                  <TextBlock Margin="0,6,0,0" Text="{Binding Content}" TextWrapping="Wrap" />
                  <TextBlock Margin="0,6,0,0" Foreground="#FF78716C" Text="{Binding TypeDisplay}" />
                  <StackPanel Orientation="Horizontal" Margin="0,8,0,0" Spacing="8">
                    <Button Command="{Binding DataContext.RestoreTrashItemCommand, RelativeSource={RelativeSource AncestorType=local:TrashView}}" CommandParameter="{Binding .}" Content="Restore" />
                    <Button Command="{Binding DataContext.DeleteTrashItemCommand, RelativeSource={RelativeSource AncestorType=local:TrashView}}" CommandParameter="{Binding .}" Content="Delete" />
                  </StackPanel>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </DockPanel>

    <local:DeleteConfirmationDialogView IsVisible="{Binding DeleteDialogViewModel.IsVisible}" DataContext="{Binding DeleteDialogViewModel}" />
  </Grid>
</UserControl>
<#cs SetOutputPathAndSkipOtherDefinitions()#>