<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="using:<#cs Write(Project.Namespace)#>.Avalonia.Views"
             mc:Ignorable="d"
             d:DesignWidth="1000"
             d:DesignHeight="700"
             x:Class="<#cs Write(Project.Namespace)#>.Avalonia.Views.All<#cs Write(Definition.Name)#>sView">
  <DockPanel>
    <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto,Auto" Margin="12">
      <Button Grid.Column="0" Margin="0,0,8,0" Command="{Binding NavigateBackCommand}" Content="Back" />
      <TextBox Grid.Column="1" Text="{Binding Filter, Mode=TwoWay}" Watermark="Filter <#cs Write(Definition.Name)#>s" />
      <Button Grid.Column="2" Margin="8,0,0,0" Command="{Binding Refresh<#cs Write(Definition.Name)#>sCommand}" Content="Refresh" />
      <Button Grid.Column="3" Margin="8,0,0,0" Command="{Binding Add<#cs Write(Definition.Name)#>Command}" Content="New" />
    </Grid>

    <ScrollViewer Margin="12,0,12,12">
      <ItemsControl ItemsSource="{Binding <#cs Write(Definition.Name)#>sView}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Button Margin="0,0,0,8"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    HorizontalContentAlignment="Stretch"
                    Command="{Binding DataContext.Edit<#cs Write(Definition.Name)#>Command, RelativeSource={RelativeSource AncestorType=local:All<#cs Write(Definition.Name)#>sView}}"
                    CommandParameter="{Binding .}">
              <Border Padding="12" Background="#FFF5F5F4" BorderBrush="#FFE7E5E4" BorderThickness="1" CornerRadius="10">
                <StackPanel>
<#csfor entry in Entries.Where(e => !(e.IsKey || e.IsArray || e.IsReference || e.IsOwnedType)).Take(2)
#>                  <TextBlock<#if entry.Field != Entries.Where(e => !(e.IsKey || e.IsArray || e.IsReference || e.IsOwnedType)).Take(2).First().Field
#> Margin="0,4,0,0"<#end#> Text="{Binding <#cs Write(entry.Field)#>}" />
<#end#>                </StackPanel>
              </Border>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</UserControl>
<#cs SetOutputPath(Definition.IsOwnedType || Definition.IsEnumeration || Definition.IsArray)#>