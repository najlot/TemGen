<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="900"
             d:DesignHeight="700"
             x:Class="<#cs Write(Project.Namespace)#>.Avalonia.Views.LoginView">
  <Grid>
    <Border MaxWidth="420"
            Padding="32"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#FFFFFBF5"
            BorderBrush="#FFE7E5E4"
            BorderThickness="1"
            CornerRadius="12">
      <StackPanel>
        <TextBlock Margin="0,0,0,16"
                   HorizontalAlignment="Center"
                   FontSize="24"
                   FontWeight="Bold"
                   Text="Sign in" />

        <StackPanel Margin="0,0,0,16">
          <TextBlock Margin="0,0,0,4" Text="Username" />
          <TextBox Text="{Binding Username, Mode=TwoWay}" />
        </StackPanel>

        <StackPanel Margin="0,0,0,16">
          <TextBlock Margin="0,0,0,4" Text="Password" />
          <TextBox PasswordChar="*" Text="{Binding Password, Mode=TwoWay}" />
        </StackPanel>

        <Button Margin="0,8,0,0"
                HorizontalAlignment="Stretch"
                Command="{Binding LoginCommand}"
                Content="Login" />

        <Button Margin="0,8,0,0"
                HorizontalAlignment="Center"
                Command="{Binding NavigateToRegisterCommand}"
                Content="Create account" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
<#cs SetOutputPathAndSkipOtherDefinitions()#>