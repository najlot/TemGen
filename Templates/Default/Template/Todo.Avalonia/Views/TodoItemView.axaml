<UserControl x:Class="<#cs Write(Project.Namespace)#>.Avalonia.Views.<#cs Write(Definition.Name)#>View"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:contracts="clr-namespace:<#cs Write(Project.Namespace)#>.Contracts;assembly=<#cs Write(Project.Namespace)#>.Contracts"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:<#cs Write(Project.Namespace)#>.Client.Localisation;assembly=<#cs Write(Project.Namespace)#>.Client.Localisation"
             xmlns:local="using:<#cs Write(Project.Namespace)#>.Avalonia.Views"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vms="clr-namespace:<#cs Write(Project.Namespace)#>.ClientBase.ViewModels;assembly=<#cs Write(Project.Namespace)#>.ClientBase"
             d:DesignHeight="750"
             d:DesignWidth="1000"
             x:DataType="vms:<#cs Write(Definition.Name)#>ViewModel"
             mc:Ignorable="d">
	<Grid>
		<Grid IsEnabled="{Binding CanEdit}" RowDefinitions="Auto,*">
			<!--  Header  -->
			<Grid Margin="16" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto">
				<Button Grid.Column="0" Margin="0,0,16,0" Command="{Binding NavigateBackCommand}">
					<materialIcons:MaterialIcon Width="24" Height="24" Kind="ArrowBack" />
				</Button>
				<Button Grid.Column="2" Margin="8,0" Command="{Binding UndoCommand}">
					<materialIcons:MaterialIcon Width="24" Height="24" Kind="Undo" />
				</Button>
				<Button Grid.Column="3" Margin="8,0" Command="{Binding RedoCommand}">
					<materialIcons:MaterialIcon Width="24" Height="24" Kind="Redo" />
				</Button>
				<Button Grid.Column="4" Margin="8,0" Command="{Binding NavigateToHistoryCommand}">
					<materialIcons:MaterialIcon Width="24" Height="24" Kind="History" />
				</Button>
				<Button Grid.Column="5" Margin="8,0" Command="{Binding SaveCommand}">
					<materialIcons:MaterialIcon Width="24" Height="24" Kind="ContentSave" />
				</Button>
				<Button Grid.Column="6" Margin="8,0" Command="{Binding DeleteCommand}">
					<materialIcons:MaterialIcon Width="24" Height="24" Kind="Delete" />
				</Button>
			</Grid>

			<!--  Main Content  -->
			<ScrollViewer Grid.Row="1">
				<StackPanel MinWidth="400"
				            MinHeight="200"
				            Margin="2,0"
				            HorizontalAlignment="Center"
				            VerticalAlignment="Center">
<#for entry in Entries
#><#if !entry.IsArray && !entry.IsOwnedType
#>					<DockPanel Margin="5">
<#end#><#if entry.EntryType != "bool" && !entry.IsArray && !entry.IsOwnedType
#>						<TextBlock MinWidth="75" VerticalAlignment="Center" Text="{x:Static loc:<#cs Write(Definition.Name)#>Loc.<#cs Write(entry.Field)#>}" />
<#end#><#if entry.EntryType == "DateTime"
#>						<StackPanel Orientation="Horizontal">
							<DatePicker SelectedDate="{Binding <#cs Write(entry.Field)#>Date, Mode=TwoWay}" />
							<TimePicker Width="110"
							            Margin="8,0,0,0"
							            ClockIdentifier="24HourClock"
							            SelectedTime="{Binding <#cs Write(entry.Field)#>Time, Mode=TwoWay}" />
						</StackPanel>
<#elseif entry.EntryType == "bool"
#>						<TextBlock MinWidth="75" />
						<CheckBox Content="{x:Static loc:<#cs Write(Definition.Name)#>Loc.<#cs Write(entry.Field)#>}" IsChecked="{Binding <#cs Write(entry.Field)#>}" />
<#elseif entry.IsReference
#>						<ComboBox ItemsSource="{Binding Available<#cs Write(Definitions.First(d => d.Name == entry.ReferenceType).Name)#>s}" SelectedValue="{Binding <#cs Write(entry.Field)#>Id}" SelectedValueBinding="{Binding Id}">
							<ComboBox.ItemTemplate>
								<DataTemplate>
									<TextBlock Text="{Binding <#cs Write(Definitions.First(d => d.Name == entry.ReferenceType).Entries.First(e => !(e.IsOwnedType || e.IsKey || e.IsArray || e.IsReference || e.IsEnumeration)).Field)#>}" />
								</DataTemplate>
							</ComboBox.ItemTemplate>
						</ComboBox>
<#elseif entry.IsEnumeration
#>						<ComboBox ItemsSource="{Binding Available<#cs Write(entry.EntryType)#>s}" SelectedItem="{Binding <#cs Write(entry.Field)#>}" />
<#elseif entry.IsArray
#>					<DockPanel>
						<DockPanel DockPanel.Dock="Top">
							<Button Margin="5" Command="{Binding Add<#cs Write(entry.EntryType)#>Command}" DockPanel.Dock="Right">
								<materialIcons:MaterialIcon Width="18" Height="18" Kind="Add" />
							</Button>

							<Border Margin="0,5" Padding="5" Background="{StaticResource BackgroundColor}">
								<TextBlock Foreground="{StaticResource ForegroundColor}" Text="{x:Static loc:<#cs Write(Definition.Name)#>Loc.<#cs Write(entry.Field)#>}" />
							</Border>
						</DockPanel>

						<ItemsControl ItemsSource="{Binding <#cs Write(entry.Field)#>}">
							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="vms:<#cs Write(entry.EntryType)#>ViewModel">
									<Border Margin="0,0,5,8"
									        Padding="8"
									        BorderBrush="LightGray"
									        BorderThickness="1">
										<StackPanel>
<#for e in Definitions.First(d => d.Name == entry.EntryType).Entries
#><#if !e.IsArray && !e.IsOwnedType
#>											<DockPanel Margin="5">
<#end#><#if e.EntryType != "bool" && !e.IsArray && !e.IsOwnedType
#>												<TextBlock MinWidth="75" VerticalAlignment="Center" Text="{x:Static loc:<#cs Write(entry.EntryType)#>Loc.<#cs Write(e.Field)#>}" />
<#end#><#if e.EntryType == "DateTime"
#>												<StackPanel Orientation="Horizontal">
													<DatePicker SelectedDate="{Binding <#cs Write(e.Field)#>Date, Mode=TwoWay}" />
													<TimePicker Width="110"
													            Margin="8,0,0,0"
													            ClockIdentifier="24HourClock"
													            SelectedTime="{Binding <#cs Write(e.Field)#>Time, Mode=TwoWay}" />
												</StackPanel>
<#elseif e.EntryType == "bool"
#>												<TextBlock MinWidth="75" />
												<CheckBox Content="{x:Static loc:<#cs Write(entry.EntryType)#>Loc.<#cs Write(e.Field)#>}" IsChecked="{Binding <#cs Write(e.Field)#>}" />
<#elseif e.IsEnumeration
#>												<ComboBox ItemsSource="{Binding Available<#cs Write(e.EntryType)#>s}" SelectedItem="{Binding <#cs Write(e.Field)#>}" />
<#else
#>												<TextBox Text="{Binding <#cs Write(e.Field)#>, Mode=TwoWay}" />
<#end#><#if !e.IsArray && !e.IsOwnedType
#>											</DockPanel>
<#end#><#end#>
											<Button HorizontalAlignment="Right"
											        Background="Transparent"
											        BorderThickness="0"
											        Command="{Binding $parent[ItemsControl].((vms:<#cs Write(Definition.Name)#>ViewModel)DataContext).Delete<#cs Write(entry.EntryType)#>Command}"
											        CommandParameter="{Binding .}"
											        Foreground="{StaticResource BackgroundColor}">
												<materialIcons:MaterialIcon Width="14" Height="14" Kind="Delete" />
											</Button>
										</StackPanel>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</DockPanel>
<#else
#>						<TextBox Text="{Binding <#cs Write(entry.Field)#>, Mode=TwoWay}" />
<#end#><#if !entry.IsArray && !entry.IsOwnedType
#>					</DockPanel>
<#end#><#end#>
				</StackPanel>
			</ScrollViewer>
		</Grid>

		<local:SaveConfirmationDialogView DataContext="{Binding $parent[Grid].((vms:<#cs Write(Definition.Name)#>ViewModel)DataContext).SaveDialogViewModel}" IsVisible="{Binding IsVisible}" />
		<local:DeleteConfirmationDialogView DataContext="{Binding $parent[Grid].((vms:<#cs Write(Definition.Name)#>ViewModel)DataContext).DeleteDialogViewModel}" IsVisible="{Binding IsVisible}" />
	</Grid>
</UserControl>
<#cs SetOutputPath(Definition.IsEnumeration || Definition.IsOwnedType || Definition.IsArray)#>