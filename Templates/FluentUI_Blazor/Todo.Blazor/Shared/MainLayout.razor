@using <# Project.Namespace#>.Blazor.Services;
@inherits LayoutComponentBase
@implements IErrorService

<PageTitle><# Project.Namespace#></PageTitle>

<FluentDesignTheme @bind-Mode="_themeMode"
				   StorageName="theme-preference"
				   CustomColor="@ThemeAccentColor">
	<div class="page">
		<div class="sidebar">
			<NavMenu />
		</div>

		<main class="main-shell">
			<div class="top-row app-topbar">
				<ThemeToggle @bind-Mode="_themeMode" />
				<LoginDisplay />
			</div>

			@if (_isErrorActive)
			{
				<FluentMessageBar Intent="MessageIntent.Error"
								  AllowDismiss="false"
								  Title="@_title"
								  Style="margin: 1rem;">
					<span>@_message</span>
					<button type="button" class="fluent-close-button" aria-label="Close" @onclick="HideError">x</button>
				</FluentMessageBar>
			}

			@if (_isSuccessToastActive)
			{
				<div class="toast-region">
					<div class="toast-panel" role="status" aria-live="polite" aria-atomic="true">
						<div>
							<div class="toast-title">@_successTitle</div>
							<div>@_successMessage</div>
						</div>
						<button type="button" class="fluent-close-button fluent-close-button--inverted" aria-label="Close" @onclick="HideSuccess">x</button>
					</div>
				</div>
			}

			<CascadingValue Value="this" Name="ErrorService">
				<div class="content">
					@Body
				</div>
			</CascadingValue>
		</main>
	</div>

	<FluentToastProvider />
	<FluentDialogProvider />
	<FluentTooltipProvider />
	<FluentMessageBarProvider />
	<FluentMenuProvider />
</FluentDesignTheme>

@code {
	private const string ThemeAccentColor = "<#cs Write(Project.GetSetting("AccentColor"))#>";

	private DesignThemeModes _themeMode = DesignThemeModes.Dark;
	private bool _isErrorActive;
	private bool _isSuccessToastActive;
	private string _title = "";
	private string _message = "";
	private string _successTitle = "";
	private string _successMessage = "";
	private int _successToastVersion;

	public void ShowError(string title, string message)
	{
		if (_isSuccessToastActive)
		{
			_successToastVersion++;
			ClearSuccessToast();
		}

		_isErrorActive = true;
		_title = title;
		_message = message;

		_ = InvokeAsync(StateHasChanged);
	}

	public void HideError()
	{
		if (!_isErrorActive)
		{
			return;
		}

		_title = string.Empty;
		_message = string.Empty;
		_isErrorActive = false;

		_ = InvokeAsync(StateHasChanged);
	}

	public void ShowSuccess(string title, string message, int durationMilliseconds = 4000)
	{
		_isSuccessToastActive = true;
		_successTitle = title;
		_successMessage = message;
		_successToastVersion++;

		var successToastVersion = _successToastVersion;

		_ = InvokeAsync(StateHasChanged);
		_ = HideSuccessAfterDelayAsync(successToastVersion, durationMilliseconds);
	}

	public void HideSuccess()
	{
		if (!_isSuccessToastActive)
		{
			return;
		}

		_successToastVersion++;
		ClearSuccessToast();

		_ = InvokeAsync(StateHasChanged);
	}

	private void ClearSuccessToast()
	{
		_isSuccessToastActive = false;
		_successTitle = string.Empty;
		_successMessage = string.Empty;
	}

	private async Task HideSuccessAfterDelayAsync(int successToastVersion, int durationMilliseconds)
	{
		await Task.Delay(durationMilliseconds);

		await InvokeAsync(() =>
		{
			if (successToastVersion != _successToastVersion || !_isSuccessToastActive)
			{
				return;
			}

			_successToastVersion++;
			ClearSuccessToast();
			StateHasChanged();
		});
	}
}<#cs SetOutputPathAndSkipOtherDefinitions()#>
