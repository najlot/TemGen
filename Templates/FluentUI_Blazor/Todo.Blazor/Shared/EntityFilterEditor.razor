@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Routing
@using System.Net
@using System.Text
@using System.Text.Json
@using <# Project.Namespace#>.Blazor.Services
@using <# Project.Namespace#>.Client.Data.Filters
@using <# Project.Namespace#>.Client.Localisation
@using <# Project.Namespace#>.Contracts.Filters
@using <# Project.Namespace#>.Contracts.Shared

@inject ILogger<EntityFilterEditor> Log
@inject IFilterService FilterService
@inject NavigationManager NavigationManager

@implements IDisposable

<div class="entity-filter-editor">
	<details>
		<summary class="filter-summary">
			<span class="app-icon">
				<FluentIcon Value="@(new Icons.Regular.Size20.Filter())" />
			</span>
			<span>@FilterLoc.Filters</span>
		</summary>
		<FluentCard Class="filter-panel" Width="100%">

			<div class="filter-grid">
				<div class="filter-section">
					<label class="fluent-label">@FilterLoc.SavedFilters</label>
					<div class="inline-form">
						<select class="fluent-select fluent-control--small" @bind="selectedNamedFilterName">
							<option value="">@FilterLoc.SelectFilter</option>
							@foreach (var namedFilter in NamedFilters)
							{
								<option value="@namedFilter.Name">@namedFilter.Name</option>
							}
						</select>
						<div class="button-row">
							<button class="fluent-button fluent-button--small fluent-button--accent" @onclick="ApplyNamedFilterAsync" disabled="@(!CanApplyNamedFilter)">@FilterLoc.Apply</button>
							<button class="fluent-button fluent-button--small fluent-button--danger" @onclick="DeleteNamedFilterAsync" disabled="@(!CanDeleteNamedFilter)">@CommonLoc.Delete</button>
						</div>
					</div>
				</div>

				<div class="filter-section">
					<label class="fluent-label">@CommonLoc.Save</label>
					<div class="inline-form">
						<input class="fluent-control fluent-control--small" @bind="saveFilterName" placeholder="@FilterLoc.FilterNamePlaceholder" />
						<div class="button-row">
							<button class="fluent-button fluent-button--small fluent-button--accent" @onclick="SaveCurrentFilterAsync" disabled="@(!CanSaveFilter)">@CommonLoc.Save</button>
						</div>
					</div>
				</div>
			</div>

			<div>
				<div class="filter-heading">
					<label class="fluent-label">@FilterLoc.ActiveConditions</label>
					@if (filterConditions.Count > 0)
					{
						<button class="fluent-button fluent-button--small fluent-button--neutral" @onclick="ClearFiltersAsync" disabled="@IsBusy">@FilterLoc.ClearAll</button>
					}
				</div>

				@if (filterConditions.Count > 0)
				{
					<div class="condition-list">
						@foreach (var condition in filterConditions)
						{
							<div class="condition-card">
								<div class="condition-row">

									<div class="condition-cell condition-cell--auto">
										<select class="fluent-select fluent-control--small" value="@condition.Field" @onchange="e => ChangeConditionField(condition, e.Value?.ToString())">
											@foreach (var field in AvailableFields)
											{
												<option value="@field.Key">@field.Label</option>
											}
										</select>
									</div>

									<div class="condition-cell condition-cell--auto">
										<select class="fluent-select fluent-control--small" value="@condition.Operator" @onchange="e => ChangeConditionOperator(condition, e.Value?.ToString())">
											@foreach (var filterOperator in GetOperators(condition))
											{
												<option value="@filterOperator.Value">@filterOperator.Label</option>
											}
										</select>
									</div>

									<div class="condition-cell condition-cell--grow">
										@if (ShowOptionEditor(condition))
										{
											<select class="fluent-select fluent-control--small" @bind="condition.Value">
												@foreach (var option in GetValues(condition))
												{
													<option value="@option.Value">@option.Label</option>
												}
											</select>
										}
										else if (ShowTextEditor(condition))
										{
											<input class="fluent-control fluent-control--small" type="@GetInputType(condition)" @bind="condition.Value" placeholder="@FilterLoc.Value" />
										}
									</div>

									<div class="condition-cell condition-cell--action">
										<button class="fluent-button fluent-button--small fluent-button--subtle fluent-button--danger-text fluent-button--icon" title="@FilterLoc.RemoveCondition" aria-label="@FilterLoc.RemoveCondition" @onclick="() => RemoveCondition(condition)" disabled="@IsBusy">
											<span class="app-icon">
												<FluentIcon Value="@(new Icons.Regular.Size20.Dismiss())" />
											</span>
										</button>
									</div>

								</div>
							</div>
						}
					</div>
				}
			</div>

			<div class="filter-actions">
				<button class="fluent-button fluent-button--small fluent-button--neutral" @onclick="AddCondition" disabled="@(!CanAddCondition)">@FilterLoc.AddCondition</button>

				<div class="button-row">
					<button class="fluent-button fluent-button--small fluent-button--neutral" @onclick="SetDefaultFilterAsync" disabled="@(!CanSetDefaultFilter)">@FilterLoc.SetAsDefault</button>
					<button class="fluent-button fluent-button--small fluent-button--neutral" @onclick="ClearDefaultFilterAsync" disabled="@(!CanClearDefaultFilter)">@FilterLoc.ClearDefault</button>
					<button class="fluent-button fluent-button--small fluent-button--accent fluent-button--wide" @onclick="SearchAsync" disabled="@IsBusy">@CommonLoc.Search</button>
				</div>
			</div>

		</FluentCard>
	</details>
</div>

@code {
	[CascadingParameter(Name = "ErrorService")]
	protected IErrorService? ErrorService { get; set; }

	[Parameter, EditorRequired]
	public IReadOnlyList<FilterFieldOption> AvailableFields { get; set; } = [];

	[Parameter, EditorRequired]
	public ItemType TargetType { get; set; }

	[Parameter]
	public bool IsBusy { get; set; }

	[Parameter, EditorRequired]
	public EventCallback<EntityFilter> ApplyFilter { get; set; }

	private readonly List<FilterCondition> filterConditions = [];
	private List<Filter> filters = [];
	private EntityFilter appliedFilter = new();

	private string? selectedNamedFilterName;
	private string saveFilterName = string.Empty;

	private ItemType initializedTargetType;
	private string[] initializedFieldKeys = [];
	private string initializedPath = string.Empty;
	private string? suppressedLocation;

	private const string FilterQueryParameterName = "filter";
	private static readonly JsonSerializerOptions FilterSerializerOptions = new(JsonSerializerDefaults.Web);

	// Expression-bodied properties for concise state checks
	private Filter? DefaultFilter => filters.FirstOrDefault(filter => filter.IsDefault);
	private IEnumerable<Filter> NamedFilters => filters.Where(f => !f.IsDefault).OrderBy(f => f.Name, StringComparer.CurrentCultureIgnoreCase);

	private bool HasDefaultFilter => DefaultFilter?.Conditions.Count > 0;
	private bool CanAddCondition => !IsBusy && AvailableFields.Count > 0;
	private bool CanSaveFilter => !IsBusy && filterConditions.Count > 0 && !string.IsNullOrWhiteSpace(saveFilterName);
	private bool CanApplyNamedFilter => !IsBusy && !string.IsNullOrWhiteSpace(selectedNamedFilterName);
	private bool CanDeleteNamedFilter => !IsBusy && !string.IsNullOrWhiteSpace(selectedNamedFilterName);
	private bool CanSetDefaultFilter => !IsBusy && filterConditions.Count > 0;
	private bool CanClearDefaultFilter => !IsBusy && HasDefaultFilter;

	protected override void OnInitialized()
	{
		NavigationManager.LocationChanged += HandleLocationChanged;
	}

	protected override async Task OnParametersSetAsync()
	{
		if (AvailableFields.Count == 0)
		{
			ResetState();
			return;
		}

		if (!NeedsInitialization()) return;

		initializedTargetType = TargetType;
		initializedFieldKeys = [.. AvailableFields.Select(field => field.Key)];
		initializedPath = NavigationManager.ToAbsoluteUri(NavigationManager.Uri).GetLeftPart(UriPartial.Path);

		try
		{
			filters = [.. await FilterService.GetItemsAsync(TargetType)];
			LoadDraftFilter(GetFilterFromUriOrDefault());
			await ApplyFilterAsync(BuildDraftFilter(), updateAppliedFilter: true, updateAddress: false);
		}
		catch (Exception ex)
		{
			Log.LogError(ex, "Error loading filters for {TargetType}.", TargetType);
			ErrorService?.ShowError(CommonLoc.Filter, ex.Message);
		}
	}

	public async Task RefreshAppliedFilterAsync()
	{
		if (!IsBusy)
		{
			await ApplyFilterAsync(CloneFilter(appliedFilter), updateAppliedFilter: false);
		}
	}

	private async void HandleLocationChanged(object? sender, LocationChangedEventArgs args)
	{
		var changedPath = NavigationManager.ToAbsoluteUri(args.Location).GetLeftPart(UriPartial.Path);

		if (!string.Equals(changedPath, initializedPath, StringComparison.OrdinalIgnoreCase))
		{
			return;
		}

		if (string.Equals(args.Location, suppressedLocation, StringComparison.Ordinal))
		{
			suppressedLocation = null;
			return;
		}

		if (AvailableFields.Count == 0)
		{
			return;
		}

		await InvokeAsync(async () =>
		{
			LoadDraftFilter(GetFilterFromUriOrDefault());
			await ApplyFilterAsync(BuildDraftFilter(), updateAppliedFilter: true, updateAddress: false);
			StateHasChanged();
		});
	}

	private bool NeedsInitialization() =>
		!initializedTargetType.Equals(TargetType) ||
		!initializedFieldKeys.SequenceEqual(AvailableFields.Select(f => f.Key));

	private void ResetState()
	{
		initializedFieldKeys = [];
		filters.Clear();
		filterConditions.Clear();
		appliedFilter = new();
		selectedNamedFilterName = null;
		saveFilterName = string.Empty;
	}

	private Task SearchAsync() => ApplyFilterAsync(BuildDraftFilter(), updateAppliedFilter: true, updateAddress: true);

	private Task ClearFiltersAsync()
	{
		LoadDraftFilter(new EntityFilter());
		return ApplyFilterAsync(new EntityFilter(), updateAppliedFilter: true, updateAddress: true);
	}

	private void AddCondition()
	{
		if (!CanAddCondition) return;

		var defaultField = AvailableFields.FirstOrDefault()?.Key ?? string.Empty;
		filterConditions.Add(new FilterCondition { Field = defaultField, Operator = FilterOperator.Equals });
		NormalizeCondition(filterConditions[^1]);
	}

	private void RemoveCondition(FilterCondition condition) => filterConditions.Remove(condition);

	private void ChangeConditionField(FilterCondition condition, string? fieldKey)
	{
		condition.Field = fieldKey ?? string.Empty;
		NormalizeCondition(condition);
	}

	private void ChangeConditionOperator(FilterCondition condition, string? filterOperator)
	{
		if (Enum.TryParse<FilterOperator>(filterOperator, ignoreCase: true, out var parsedOperator))
		{
			condition.Operator = parsedOperator;
			NormalizeCondition(condition);
		}
	}

	private FilterFieldOption? GetField(FilterCondition condition) => AvailableFields.FirstOrDefault(field => field.Key == condition.Field);
	private IReadOnlyList<FilterOperatorOption> GetOperators(FilterCondition condition) => GetField(condition)?.Operators ?? [];
	private IReadOnlyList<FilterValueOption> GetValues(FilterCondition condition) => GetField(condition)?.Values ?? [];

	private bool ShowTextEditor(FilterCondition condition) => condition.Operator.RequiresValue() && GetValues(condition).Count == 0;
	private bool ShowOptionEditor(FilterCondition condition) => condition.Operator.RequiresValue() && GetValues(condition).Count > 0;

	private string GetInputType(FilterCondition condition) => GetField(condition)?.Kind switch
	{
		FilterFieldKind.Number => "number",
		FilterFieldKind.DateTime => "datetime-local",
		_ => "text",
	};

	private void NormalizeCondition(FilterCondition condition)
	{
		var field = GetField(condition);
		if (field is null)
		{
			condition.Field = AvailableFields.FirstOrDefault()?.Key ?? string.Empty;
			field = GetField(condition);
			if (field is null) return;
		}

		if (field.Operators.All(op => op.Value != condition.Operator))
		{
			condition.Operator = field.Operators.FirstOrDefault()?.Value ?? FilterOperator.Equals;
		}

		if (!condition.Operator.RequiresValue())
		{
			condition.Value = null;
			return;
		}

		if (field.Values.Count > 0 && field.Values.All(v => v.Value != condition.Value))
		{
			condition.Value = field.Values.FirstOrDefault()?.Value;
		}
		else
		{
			condition.Value ??= string.Empty;
		}
	}

	private async Task SaveCurrentFilterAsync()
	{
		if (!CanSaveFilter)
		{
			ErrorService?.ShowError(CommonLoc.Filter, "Enter a filter name and add at least one condition before saving.");
			return;
		}

		try
		{
			var filter = BuildDraftFilter();
			var filterName = saveFilterName.Trim();
			var existing = filters.FirstOrDefault(f => !f.IsDefault && string.Equals(f.Name, filterName, StringComparison.OrdinalIgnoreCase));

			if (existing is null)
			{
				var newFilter = new Filter
				{
					Id = Guid.NewGuid(),
					TargetType = TargetType,
					Name = filterName,
					Conditions = CloneConditions(filter.Conditions)
				};
				await FilterService.AddItemAsync(newFilter);
				filters.Add(CloneFilter(newFilter));
				selectedNamedFilterName = newFilter.Name;
			}
			else
			{
				existing.TargetType = TargetType;
				existing.Name = filterName;
				existing.IsDefault = false;
				existing.Conditions = CloneConditions(filter.Conditions);

				await FilterService.UpdateItemAsync(CloneFilter(existing));
				ReplaceFilter(existing);
				selectedNamedFilterName = existing.Name;
			}

			saveFilterName = string.Empty;
		}
		catch (Exception ex)
		{
			Log.LogError(ex, "Error saving filter for {TargetType}.", TargetType);
			ErrorService?.ShowError(CommonLoc.Filter, ex.Message);
		}
	}

	private async Task ApplyNamedFilterAsync()
	{
		if (GetSelectedNamedFilter() is { } namedFilter)
		{
			var filter = ToEntityFilter(namedFilter);
			LoadDraftFilter(filter);
			await ApplyFilterAsync(CloneFilter(filter), updateAppliedFilter: true, updateAddress: true);
		}
	}

	private async Task DeleteNamedFilterAsync()
	{
		if (GetSelectedNamedFilter() is { } namedFilter)
		{
			try
			{
				await FilterService.DeleteItemAsync(namedFilter.Id);
				filters.RemoveAll(f => f.Id == namedFilter.Id);
				selectedNamedFilterName = null;
			}
			catch (Exception ex)
			{
				Log.LogError(ex, "Error deleting filter for {TargetType}.", TargetType);
				ErrorService?.ShowError(CommonLoc.Filter, ex.Message);
			}
		}
	}

	private async Task SetDefaultFilterAsync()
	{
		if (!CanSetDefaultFilter) return;

		try
		{
			var filter = BuildDraftFilter();
			if (DefaultFilter is null)
			{
				var newFilter = new Filter
				{
					Id = Guid.NewGuid(),
					TargetType = TargetType,
					IsDefault = true,
					Conditions = CloneConditions(filter.Conditions)
				};
				await FilterService.AddItemAsync(newFilter);
				filters.Add(CloneFilter(newFilter));
			}
			else
			{
				DefaultFilter.TargetType = TargetType;
				DefaultFilter.IsDefault = true;
				DefaultFilter.Conditions = CloneConditions(filter.Conditions);

				await FilterService.UpdateItemAsync(CloneFilter(DefaultFilter));
				ReplaceFilter(DefaultFilter);
			}
		}
		catch (Exception ex)
		{
			Log.LogError(ex, "Error setting default filter for {TargetType}.", TargetType);
			ErrorService?.ShowError(CommonLoc.Filter, ex.Message);
		}
	}

	private async Task ClearDefaultFilterAsync()
	{
		if (DefaultFilter is { } defaultFilter)
		{
			try
			{
				await FilterService.DeleteItemAsync(defaultFilter.Id);
				filters.RemoveAll(f => f.Id == defaultFilter.Id);
			}
			catch (Exception ex)
			{
				Log.LogError(ex, "Error clearing default filter for {TargetType}.", TargetType);
				ErrorService?.ShowError(CommonLoc.Filter, ex.Message);
			}
		}
	}

	private async Task ApplyFilterAsync(EntityFilter filter, bool updateAppliedFilter, bool updateAddress = false)
	{
		if (updateAppliedFilter)
		{
			appliedFilter = CloneFilter(filter);
		}

		if (updateAddress)
		{
			UpdateFilterUri(filter);
		}

		await ApplyFilter.InvokeAsync(CloneFilter(filter));
	}

	private EntityFilter BuildDraftFilter() => new()
	{
		Conditions =
		[
			.. filterConditions
				.Where(c => AvailableFields.Any(f => f.Key == c.Field))
				.Where(c => !c.Operator.RequiresValue() || !string.IsNullOrWhiteSpace(c.Value))
				.Select(c => new FilterCondition { Field = c.Field, Operator = c.Operator, Value = c.Value })
		]
	};

	private void LoadDraftFilter(EntityFilter filter)
	{
		var knownFieldKeys = AvailableFields.Select(f => f.Key).ToHashSet(StringComparer.Ordinal);

		filterConditions.Clear();

		filterConditions.AddRange(filter.Conditions
			.Where(c => knownFieldKeys.Contains(c.Field))
			.Select(c => new FilterCondition { Field = c.Field, Operator = c.Operator, Value = c.Value }));

		foreach (var condition in filterConditions)
		{
			NormalizeCondition(condition);
		}
	}

	private Filter? GetSelectedNamedFilter() =>
		NamedFilters.FirstOrDefault(f => string.Equals(f.Name, selectedNamedFilterName, StringComparison.OrdinalIgnoreCase));

	private void ReplaceFilter(Filter filter)
	{
		var index = filters.FindIndex(existing => existing.Id == filter.Id);
		if (index >= 0) filters[index] = CloneFilter(filter);
		else filters.Add(CloneFilter(filter));
	}

	private static Filter CloneFilter(Filter filter) => new()
	{
		Id = filter.Id,
		TargetType = filter.TargetType,
		Name = filter.Name,
		IsDefault = filter.IsDefault,
		Conditions = CloneConditions(filter.Conditions),
	};

	private static List<FilterCondition> CloneConditions(IEnumerable<FilterCondition> conditions) =>
		[.. conditions.Select(c => new FilterCondition { Field = c.Field, Operator = c.Operator, Value = c.Value })];

	private static EntityFilter ToEntityFilter(Filter filter) => new() { Conditions = CloneConditions(filter.Conditions) };
	private static EntityFilter CloneFilter(EntityFilter filter) => new() { Conditions = CloneConditions(filter.Conditions) };

	private EntityFilter GetFilterFromUriOrDefault()
	{
		if (TryReadFilterFromUri(out var filter))
		{
			return filter;
		}

		return DefaultFilter is { } defaultFilter ? ToEntityFilter(defaultFilter) : new EntityFilter();
	}

	private bool TryReadFilterFromUri(out EntityFilter filter)
	{
		var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);

		if (!TryGetQueryValue(uri.Query, FilterQueryParameterName, out var encodedFilter) || string.IsNullOrWhiteSpace(encodedFilter))
		{
			filter = new EntityFilter();
			return false;
		}

		try
		{
			var json = Encoding.UTF8.GetString(DecodeBase64Url(encodedFilter));
			filter = JsonSerializer.Deserialize<EntityFilter>(json, FilterSerializerOptions) ?? new EntityFilter();
			return true;
		}
		catch (Exception ex)
		{
			Log.LogWarning(ex, "Error reading filter from URL.");
			filter = new EntityFilter();
			return true;
		}
	}

	private void UpdateFilterUri(EntityFilter filter)
	{
		var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
		var query = ParseQuery(uri.Query)
			.Where(parameter => !string.Equals(parameter.Key, FilterQueryParameterName, StringComparison.OrdinalIgnoreCase))
			.ToList();

		if (filter.Conditions.Count > 0)
		{
			query.Add(new KeyValuePair<string, string>(FilterQueryParameterName, EncodeFilter(filter)));
		}

		var nextUri = BuildUri(uri.GetLeftPart(UriPartial.Path), query, uri.Fragment);

		if (string.Equals(nextUri, NavigationManager.Uri, StringComparison.Ordinal))
		{
			return;
		}

		suppressedLocation = nextUri;
		NavigationManager.NavigateTo(nextUri);
	}

	private static string EncodeFilter(EntityFilter filter)
	{
		var json = JsonSerializer.Serialize(filter, FilterSerializerOptions);
		return Convert.ToBase64String(Encoding.UTF8.GetBytes(json))
			.TrimEnd('=')
			.Replace('+', '-')
			.Replace('/', '_');
	}

	private static byte[] DecodeBase64Url(string value)
	{
		var padded = value.Replace('-', '+').Replace('_', '/');
		var padding = padded.Length % 4;

		if (padding == 2)
		{
			padded += "==";
		}
		else if (padding == 3)
		{
			padded += "=";
		}

		return Convert.FromBase64String(padded);
	}

	private static bool TryGetQueryValue(string query, string key, out string value)
	{
		foreach (var parameter in ParseQuery(query))
		{
			if (string.Equals(parameter.Key, key, StringComparison.OrdinalIgnoreCase))
			{
				value = parameter.Value;
				return true;
			}
		}

		value = string.Empty;
		return false;
	}

	private static List<KeyValuePair<string, string>> ParseQuery(string query)
	{
		if (string.IsNullOrWhiteSpace(query))
		{
			return [];
		}

		return query.TrimStart('?')
			.Split('&', StringSplitOptions.RemoveEmptyEntries)
			.Select(segment => segment.Split('=', 2))
			.Select(parts => new KeyValuePair<string, string>(
				WebUtility.UrlDecode(parts[0]) ?? string.Empty,
				parts.Length > 1 ? WebUtility.UrlDecode(parts[1]) ?? string.Empty : string.Empty))
			.ToList();
	}

	private static string BuildUri(string path, IReadOnlyList<KeyValuePair<string, string>> query, string fragment)
	{
		if (query.Count == 0)
		{
			return $"{path}{fragment}";
		}

		var encodedQuery = string.Join("&", query.Select(parameter =>
			$"{Uri.EscapeDataString(parameter.Key)}={Uri.EscapeDataString(parameter.Value)}"));

		return $"{path}?{encodedQuery}{fragment}";
	}

	public void Dispose()
	{
		NavigationManager.LocationChanged -= HandleLocationChanged;
	}
}
<#cs SetOutputPathAndSkipOtherDefinitions()#>
