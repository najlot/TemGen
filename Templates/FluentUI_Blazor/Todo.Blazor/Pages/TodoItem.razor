								 ValueExpression="@(() => Model.<# entry.Field#>Id)">
						@foreach (var value in _<# entry.ReferenceTypeLow#>s)
						{
							<option value="@value.Id">@value.DisplayText</option>
						}
						</InputSelect>
<#else
#><# entry.EntryType#> ???<#end
#>						</div>
<#end
#>					</div>
				</div>
			</div>
<#for entry in Entries.Where(e => e.IsArray)
#>			<FluentCard Class="fluent-card--section" Width="100%">
				<div class="section-header">
					<h2 class="section-title">@<# Definition.Name#>Loc.<# entry.Field#></h2>
					<IconButton Icon="Icons.Regular.Size20.Add"
								ButtonClass="fluent-button fluent-button--success fluent-button--icon"
								Execute="Add<# entry.Field#>Entry"
								Title="@CommonLoc.New" />
				</div>
				<div class="table-shell">
					<table class="data-table data-table--striped">
						<thead>
							<tr>
<#for e in Definitions.First(definition => definition.Name == entry.EntryType).Entries
#>								<th>@<# entry.EntryType#>Loc.<# e.Field#></th>
<#end#>								<th class="table-cell-actions">@CommonLoc.Delete</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var entry in Model.<# entry.Field#>)
							{
								<tr scope="row">
<#for e in Definitions.First(definition => definition.Name == entry.EntryType).Entries
#><#if e.EntryType.ToLower() == "bool"
#>									<td><input type="checkbox" class="fluent-checkbox" checked="@entry.<# e.Field#>" @onchange="@(ev => _changeTracker.TrackChange(entry, nameof(entry.<# e.Field#>), entry.<# e.Field#>, (bool)(ev.Value ?? false)))" /></td>
<#elseif e.EntryType.ToLower() == "string"
#>									<td><input type="text" class="fluent-control" value="@entry.<# e.Field#>" @onchange="@(ev => _changeTracker.TrackChange(entry, nameof(entry.<# e.Field#>), entry.<# e.Field#>, ev.Value?.ToString() ?? string.Empty))" /></td>
<#elseif e.EntryType.ToLower() == "int"
#>									<td><input type="number" class="fluent-control" value="@entry.<# e.Field#>" @onchange="@(ev => _changeTracker.TrackChange(entry, nameof(entry.<# e.Field#>), entry.<# e.Field#>, int.TryParse(ev.Value?.ToString(), out var parsedValue) ? parsedValue : entry.<# e.Field#>))" /></td>
<#elseif e.EntryType.ToLower() == "long"
#>									<td><input type="number" class="fluent-control" value="@entry.<# e.Field#>" @onchange="@(ev => _changeTracker.TrackChange(entry, nameof(entry.<# e.Field#>), entry.<# e.Field#>, long.TryParse(ev.Value?.ToString(), out var parsedValue) ? parsedValue : entry.<# e.Field#>))" /></td>
<#elseif e.EntryType.ToLower() == "double"
#>									<td><input type="number" step="any" class="fluent-control" value="@entry.<# e.Field#>" @onchange="@(ev => _changeTracker.TrackChange(entry, nameof(entry.<# e.Field#>), entry.<# e.Field#>, double.TryParse(ev.Value?.ToString(), out var parsedValue) ? parsedValue : entry.<# e.Field#>))" /></td>
<#elseif e.EntryType.ToLower() == "datetime"
#>									<td><input type="date" class="fluent-control" value="@entry.<# e.Field#>.ToString(\"yyyy-MM-dd\")" @onchange="@(ev => _changeTracker.TrackChange(entry, nameof(entry.<# e.Field#>), entry.<# e.Field#>, DateTime.TryParse(ev.Value?.ToString(), out var parsedValue) ? parsedValue : entry.<# e.Field#>))" /></td>
<#elseif e.IsEnumeration
#>									<td>
										<select class="fluent-select" value="@entry.<# e.Field#>" @onchange="@(ev => _changeTracker.TrackChange(entry, nameof(entry.<# e.Field#>), entry.<# e.Field#>, Enum.TryParse<<# e.EntryType#>>(ev.Value?.ToString(), out var parsedValue) ? parsedValue : entry.<# e.Field#>))">
											@foreach (var item in Enum.GetValues(typeof(<# e.EntryType#>)))
											{
												<option value="@item">@(((<# e.EntryType#>)item) == <# e.EntryType#>.None ? CommonLoc.NothingSelected : item.ToString())</option>
