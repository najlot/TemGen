@page "/"
@using Microsoft.AspNetCore.Components.Web
@namespace Todo.Blazor.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<base href="~/" />
	<script>
		window.themePreference = {
			storageKey: "theme-preference",
			defaultTheme: "dark",
			getStoredTheme: function () {
				try {
					var theme = window.localStorage.getItem(this.storageKey);
					return theme === "light" || theme === "dark" ? theme : null;
				}
				catch (error) {
					return null;
				}
			},
			getTheme: function () {
				return this.getStoredTheme() || this.defaultTheme;
			},
			setTheme: function (theme) {
				var resolvedTheme = theme === "light" ? "light" : "dark";
				document.documentElement.setAttribute("data-bs-theme", resolvedTheme);
				try {
					window.localStorage.setItem(this.storageKey, resolvedTheme);
				}
				catch (error) {
				}
				return resolvedTheme;
			},
			toggleTheme: function () {
				return this.setTheme(this.getTheme() === "dark" ? "light" : "dark");
			}
		};

		window.themePreference.setTheme(window.themePreference.getTheme());
	</script>
	<link rel="stylesheet" href="css/bootstrap/bootstrap.min.css" asp-append-version="true" />
	<link href="css/site.css" rel="stylesheet" asp-append-version="true" />
	<link href="Todo.Blazor.styles.css" rel="stylesheet" asp-append-version="true" />
	<link rel="icon" type="image/png" href="favicon.png"/>
	<component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
</head>
<body>
	<component type="typeof(App)" render-mode="Server" />

	<div id="blazor-error-ui">
		<environment include="Staging,Production">
			An error has occurred. This application may no longer respond until reloaded.
		</environment>
		<environment include="Development">
			An unhandled exception has occurred. See browser dev tools for details.
		</environment>
		<a href="" class="reload">Reload</a>
		<a class="dismiss">🗙</a>
	</div>

	<script src="_framework/blazor.server.js"></script>
</body>
</html>
