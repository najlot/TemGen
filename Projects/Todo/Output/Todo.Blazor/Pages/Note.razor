@page "/Note/{id:guid}"
@using Microsoft.AspNetCore.Components.Routing;
@using Microsoft.Extensions.Localization;
@using Todo.Blazor.Identity;
@using Todo.Blazor.Services;
@using Todo.Client.Data;
@using Todo.Client.Data.Favorites;
@using Todo.Client.Data.Notes;@using Todo.Client.Localisation;
@using Todo.Contracts.Notes;
@using Todo.Contracts.Shared;
@inject ILogger<Note> Log
@inject Najlot.Map.IMap Map;
@inject INoteService NoteService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<PredefinedColorLoc> PredefinedColorLocalizer

@attribute [Authorize]
@implements IDisposable

@if (isNew)
{
	<PageTitle>@NoteLoc.CreateNote</PageTitle>
}
else
{
	<PageTitle>@NoteLoc.EditNote</PageTitle>
}

@if (Model == null)
{
	<p><em>@CommonLoc.Loading...</em></p>
}
else
{
	<section class="d-grid">
		<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-1">
			<div>
				@if (isNew)
				{
					<h1 class="mb-1">@NoteLoc.CreateNote</h1>
				}
				else
				{
					<h1 class="mb-1">@NoteLoc.EditNote</h1>
				}
			</div>
			<div class="d-flex flex-wrap gap-2">
				<IconButton Icon="Undo"
							ButtonClass="btn btn-secondary"
							CanExecute="() => _changeTracker.CanUndo"
							Execute="_changeTracker.Undo" />
				<IconButton Icon="Redo"
							ButtonClass="btn btn-secondary"
							CanExecute="() => _changeTracker.CanRedo"
							Execute="_changeTracker.Redo" />
				@if (!isNew)
				{
					<ToggleFavoriteButton TargetType="ItemType.Note"
									  ItemId="@Model.Id"
									  CanToggle="@(!isNew)" />

					<IconButton Icon="history"
								ButtonClass="btn btn-secondary"
								Execute="NavigateToHistory"
								Title="@CommonLoc.History" />
				}
				<IconButton Icon="Save"
							ButtonClass="btn btn-success"
							Execute="Save"
							Title="@CommonLoc.Save" />
				<IconButton Icon="Delete"
							ButtonClass="btn btn-danger"
							CanExecute="() => !isDeleteRequested"
							Execute="() => isDeleteRequested = true"
							Title="@CommonLoc.Delete" />
			</div>
		</div>

		<EditForm Model="@Model" OnValidSubmit="@Save">
			<div>
				<div>
					<DataAnnotationsValidator />
					<ValidationSummary class="alert alert-danger mb-4" />
					<div class="row g-3">

						<!-- Title input -->
						<div class="col-12 col-md-6">
							<label class="form-label" for="TitleInput">@NoteLoc.Title</label>
							<InputText type="text" id="TitleInput" class="form-control"
							   Value="@Model.Title"
							   ValueChanged="@((string v) => _changeTracker.TrackChange(Model, nameof(Model.Title), Model.Title, v))"
							   ValueExpression="@(() => Model.Title)" />
						</div>

						<!-- Content input -->
						<div class="col-12 col-md-6">
							<label class="form-label" for="ContentInput">@NoteLoc.Content</label>
							<InputText type="text" id="ContentInput" class="form-control"
							   Value="@Model.Content"
							   ValueChanged="@((string v) => _changeTracker.TrackChange(Model, nameof(Model.Content), Model.Content, v))"
							   ValueExpression="@(() => Model.Content)" />
						</div>

						<!-- Color input -->
						<div class="col-12 col-md-6">
							<label class="form-label" for="ColorInput">@NoteLoc.Color</label>
							<InputSelect id="ColorInput" class="form-select"
								 Value="@Model.Color"
								 ValueChanged="@((PredefinedColor v) => _changeTracker.TrackChange(Model, nameof(Model.Color), Model.Color, v))"
								 ValueExpression="@(() => Model.Color)" >
						@foreach (var value in Enum.GetValues(typeof(PredefinedColor)))
						{
							<option value="@value">@PredefinedColorLocalizer[$"{@value}"]</option>
						}
						</InputSelect>
						</div>
					</div>
				</div>
			</div>

		</EditForm>
	</section>

	<SaveConfirmationDialog @ref="_saveConfirmationDialog" />
	<DeleteConfirmationDialog @bind-IsVisible="isDeleteRequested" Remove="Remove" />
}

@code {
	[CascadingParameter(Name = "ErrorService")]
	protected IErrorService? ErrorService { get; set; }

	[Parameter]
	public Guid Id { get; set; }

	private bool isNew = false;
	private bool isDeleteRequested = false;
	private NoteModel? Model;
	private readonly ChangeTracker _changeTracker = new();
	private SaveConfirmationDialog? _saveConfirmationDialog;
	private IDisposable? _locationChangingRegistration;
	private bool _ignoreLocationChanging;
	private bool _isSaveConfirmationVisible;


	private void NavigateToHistory()
	{
		if (Model is null || isNew)
		{
			return;
		}

		NavigationManager.NavigateTo($"/history/{Model.Id}?entityName=Note");
	}

	protected override void OnAfterRender(bool firstRender)
	{
		if (firstRender)
		{
			_locationChangingRegistration = NavigationManager.RegisterLocationChangingHandler(HandleLocationChangingAsync);
		}
	}

	private async ValueTask HandleLocationChangingAsync(LocationChangingContext context)
	{
		if (_ignoreLocationChanging)
		{
			_ignoreLocationChanging = false;
			return;
		}

		if (!await CanNavigateAsync())
		{
			context.PreventNavigation();
		}
	}

	private async Task<bool> CanNavigateAsync()
	{
		if (_isSaveConfirmationVisible || isDeleteRequested)
		{
			return false;
		}

		if (!_changeTracker.HasChanges || _saveConfirmationDialog is null)
		{
			return true;
		}

		_isSaveConfirmationVisible = true;

		try
		{
			var saveDialogResult = await _saveConfirmationDialog.ShouldSave();

			switch (saveDialogResult)
			{
				case SaveConfirmationDialog.SaveDialogResult.Save:
					return await TrySaveAsync(navigateAfterCreate: false);
				case SaveConfirmationDialog.SaveDialogResult.Discard:
					return true;
				default:
					return false;
			}
		}
		finally
		{
			_isSaveConfirmationVisible = false;
		}
	}

	private void NavigateWithoutSaveConfirmation(string url, bool forceLoad = false, bool replace = false)
	{
		_ignoreLocationChanging = true;
		NavigationManager.NavigateTo(url, forceLoad, replace);
	}

	protected override async Task OnInitializedAsync()
	{
		try
		{
			if (Id == Guid.Empty)
			{
				Model = NoteService.CreateNote();
				isNew = true;
			}
			else
			{
				Model = await NoteService.GetItemAsync(Id);
			}


			NoteService.ItemUpdated += Handle;
			_changeTracker.StateChanged += () => InvokeAsync(StateHasChanged);

			await NoteService.StartEventListener();
		}
		catch (Todo.Client.Data.Identity.SessionUnavailableException)
		{
			var url = NavigationManager.BuildReturnUrl("/login");
			NavigateWithoutSaveConfirmation(url);
		}
		catch (Exception ex)
		{
			Log.LogError(ex, "Error loading Note.");
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorCouldNotLoad);
		}
	}

	private Task Save() => TrySaveAsync();

	private async Task<bool> TrySaveAsync(bool navigateAfterCreate = true)
	{
		if (Model is null)
		{
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorModelIsNullReload);
			return false;
		}

		try
		{
			if (isNew)
			{
				await NoteService.AddItemAsync(Model);
				Id = Model.Id;
				isNew = false;
				_changeTracker.Clear();

				if (navigateAfterCreate)
				{
					NavigateWithoutSaveConfirmation($"/Note/{Model.Id}", false, true);
				}
			}
			else
			{
				await NoteService.UpdateItemAsync(Model);
				_changeTracker.Clear();
			}

			ErrorService?.HideError();
			ErrorService?.ShowSuccess(CommonLoc.Save, CommonLoc.ChangesRecorded);

			return true;
		}
		catch (Todo.Client.Data.Identity.SessionUnavailableException)
		{
			var url = NavigationManager.BuildReturnUrl("/login");
			NavigateWithoutSaveConfirmation(url);
		}
		catch (Exception ex)
		{
			Log.LogError(ex, "Error saving Note.");
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorCouldNotSave);
		}

		return false;
	}

	private async Task Remove()
	{
		if (Model is null)
		{
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorModelIsNullReload);
			return;
		}

		try
		{
			if (!isNew)
			{
				await NoteService.DeleteItemAsync(Model.Id);
			}

			_changeTracker.Clear();
			NavigateWithoutSaveConfirmation(GetReturnToListUrl());
		}
		catch (Todo.Client.Data.Identity.SessionUnavailableException)
		{
			var url = NavigationManager.BuildReturnUrl("/login");
			NavigateWithoutSaveConfirmation(url);
		}
		catch (Exception ex)
		{
			Log.LogError(ex, "Error deleting Note.");
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorDeleting);
		}
	}

	private async Task Handle(object? sender, NoteUpdated message)
	{
		if (Model is null || Model.Id != message.Id)
		{
			return;
		}

		Map.From(message).To(Model);
		_changeTracker.Clear();

		await InvokeAsync(StateHasChanged);
	}

	private string GetReturnToListUrl()
	{
		if (NavigationManager.TryGetReturnUrl(out var returnUrl) && !string.IsNullOrWhiteSpace(returnUrl))
		{
			return "/" + returnUrl.TrimStart('/');
		}

		return "/Notes";
	}

	public void Dispose()
	{
		NoteService.ItemUpdated -= Handle;
		_locationChangingRegistration?.Dispose();
	}
}
