@page "/TodoItems"
@using Humanizer
@using Microsoft.AspNetCore.Components
@using Todo.Blazor.Services
@using Todo.Client.Data
@using Todo.Client.Data.Filters
@using Todo.Client.Data.Favorites
@using Todo.Client.Data.TodoItems
@using Todo.Client.Data.Users
@using Todo.Client.Localisation
@using Todo.Contracts.Filters
@using Todo.Contracts.Shared
@using Todo.Contracts.TodoItems

@inject ILogger<TodoItems> Log
@inject Najlot.Map.IMap Map
@inject ITodoItemService TodoItemService
@inject IFavoriteService FavoriteService
@inject IUserService UserService
@inject NavigationManager NavigationManager

@attribute [Authorize]
@implements IDisposable

<PageTitle>@TodoItemLoc.TodoItems</PageTitle>

<section class="d-grid gap-3">
	<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
		<h1 class="mb-0">@TodoItemLoc.TodoItems</h1>
		<a href="@GetEditorHref(Guid.Empty)" class="btn btn-success material-symbols-sharp">add</a>
	</div>

	<EntityFilterEditor @ref="filterEditor"
						AvailableFields="availableFilterFields"
						TargetType="ItemType.TodoItem"
						IsBusy="isLoading"
						ApplyFilter="HandleFilterAppliedAsync" />

	@if (todoItems is null)
	{
		<p><em>@CommonLoc.Loading...</em></p>
	}
	else
	{
		<div class="card shadow-sm border-0">
			<div class="table-responsive">
				<table class="table table-hover align-middle mb-0">
					<thead class="bg-body-tertiary">
						<tr>
							<th class="text-center" style="width: 1%;">
								<span class="material-symbols-sharp text-warning" title="Favorite" aria-label="Favorite">star</span>
							</th>
							<th>@TodoItemLoc.Title</th>
							<th>@TodoItemLoc.Content</th>
							<th class="text-end">@CommonLoc.Edit</th>
						</tr>
					</thead>
					<tbody>
						@foreach (var todoItem in todoItems)
						{
							<tr scope="row">
								<td class="text-center">
									@if (IsFavorite(todoItem.Id))
									{
										<span class="material-symbols-sharp text-warning" title="Favorite" aria-label="Favorite">star</span>
									}
								</td>
								<td class="text-break">@todoItem.Title.Truncate(75)</td>
								<td class="text-break">@todoItem.Content.Truncate(75)</td>
								<td class="text-end"><a href="@GetEditorHref(todoItem.Id)" class="btn btn-outline-primary btn-sm">@CommonLoc.Edit</a></td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		</div>
	}
</section>

@code {
	[CascadingParameter(Name = "ErrorService")]
	protected IErrorService? ErrorService { get; set; }

	private EntityFilterEditor? filterEditor;
	private List<TodoItemListItemModel>? todoItems;
	private HashSet<Guid> _favoriteIds = [];
	private IReadOnlyList<FilterFieldOption> availableFilterFields = [];
	private bool isLoading;
	private EntityFilter? _lastFilter;

	protected override async Task OnInitializedAsync()
	{
		try
		{
			var users = await UserService.GetItemsAsync();
			availableFilterFields = BuildFilterFieldOptions(users);

			TodoItemService.ItemCreated += Handle;
			TodoItemService.ItemUpdated += Handle;
			TodoItemService.ItemDeleted += Handle;
			FavoriteService.ItemCreated += HandleFavoriteCreated;
			FavoriteService.ItemDeleted += HandleFavoriteDeleted;

			await Task.WhenAll(
				TodoItemService.StartEventListener(),
				FavoriteService.StartEventListener());
		}
		catch (Todo.Client.Data.Identity.SessionUnavailableException)
		{
			var url = NavigationManager.BuildReturnUrl("/login");
			NavigationManager.NavigateTo(url);
		}
		catch (Exception ex)
		{
			Log.LogError(ex, "Error loading TodoItems.");
			todoItems = [];
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorCouldNotLoad);
		}
	}

	private Task HandleFilterAppliedAsync(EntityFilter filter)
		=> LoadItemsAsync(filter);

	private async Task RefreshAppliedFilterAsync()
	{
		if (filterEditor is null || isLoading)
		{
			return;
		}

		await filterEditor.RefreshAppliedFilterAsync();
	}

	private async Task LoadItemsAsync(EntityFilter filter)
	{
		try
		{
			isLoading = true;
			_lastFilter = filter;

			var itemsTask = filter.Conditions.Count == 0
				? TodoItemService.GetItemsAsync()
				: TodoItemService.GetItemsAsync(filter);
			var favoritesTask = FavoriteService.GetItemsAsync(ItemType.TodoItem);

			var items = await itemsTask.ConfigureAwait(false);
			var favorites = await favoritesTask.ConfigureAwait(false);

			todoItems = [.. items];
			_favoriteIds = [.. favorites.Select(item => item.ItemId)];
		}
		catch (Todo.Client.Data.Identity.SessionUnavailableException)
		{
			var url = NavigationManager.BuildReturnUrl("/login");
			NavigationManager.NavigateTo(url);
		}
		catch (Exception ex)
		{
			Log.LogError(ex, "Error loading filtered TodoItems.");
			ErrorService?.ShowError(ErrorLoc.Error, ex.Message);
		}
		finally
		{
			isLoading = false;
		}

		await InvokeAsync(StateHasChanged);
	}

	private bool IsFavorite(Guid itemId)
		=> _favoriteIds.Contains(itemId);

	private string GetEditorHref(Guid id)
		=> NavigationManager.BuildReturnUrl($"/TodoItem/{id}");

	private IReadOnlyList<FilterFieldOption> BuildFilterFieldOptions(UserListItemModel[] users)
	{
		return
		[
			new FilterFieldOption
			{
				Key = "Title",
				Label = TodoItemLoc.Title,
				Kind = FilterFieldKind.Text,
				Operators = FilterOperatorCatalog.CreateTextOptions(),
				Values = [],
			},
			new FilterFieldOption
			{
				Key = "Content",
				Label = TodoItemLoc.Content,
				Kind = FilterFieldKind.Text,
				Operators = FilterOperatorCatalog.CreateTextOptions(),
				Values = [],
			},
			new FilterFieldOption
			{
				Key = "AssignedToId",
				Label = TodoItemLoc.AssignedTo,
				Kind = FilterFieldKind.Option,
				Operators = FilterOperatorCatalog.CreateEqualityOptions(false),
				Values = [.. users.Select(item => new FilterValueOption
				{
					Value = item.Id.ToString(),
					Label = item.DisplayText,
				})],
			},
			new FilterFieldOption
			{
				Key = "Status",
				Label = TodoItemLoc.Status,
				Kind = FilterFieldKind.Option,
				Operators = FilterOperatorCatalog.CreateEqualityOptions(false),
				Values = [.. Enum.GetValues<TodoItemStatus>().Select(value => new FilterValueOption
				{
					Value = value.ToString(),
					Label = value == TodoItemStatus.None ? CommonLoc.NothingSelected : value.ToString(),
				})],
			},
			new FilterFieldOption
			{
				Key = "DueDate",
				Label = TodoItemLoc.DueDate,
				Kind = FilterFieldKind.DateTime,
				Operators = FilterOperatorCatalog.CreateComparableOptions(false),
				Values = [],
			},
			new FilterFieldOption
			{
				Key = "Priority",
				Label = TodoItemLoc.Priority,
				Kind = FilterFieldKind.Text,
				Operators = FilterOperatorCatalog.CreateTextOptions(),
				Values = [],
			},
		];
	}

	private async Task Handle(object? sender, TodoItemCreated message)
	{
		if (todoItems is null || _lastFilter is { Conditions.Count: > 0 })
		{
			return;
		}

		var item = Map.From(message).To<TodoItemListItemModel>();

		todoItems.Insert(0, item);

		await InvokeAsync(StateHasChanged);
	}

	private async Task Handle(object? sender, TodoItemUpdated message)
	{
		if (todoItems is null)
		{
			return;
		}

		var entry = todoItems.FirstOrDefault(t => t.Id == message.Id);

		if (entry is not null)
		{
			Map.From(message).To(entry);
		}

		await InvokeAsync(StateHasChanged);
	}

	private async Task Handle(object? sender, TodoItemDeleted message)
	{
		if (todoItems is null)
		{
			return;
		}

		var entry = todoItems.FirstOrDefault(t => t.Id == message.Id);

		if (entry is null)
		{
			return;
		}

		todoItems.Remove(entry);

		await InvokeAsync(StateHasChanged);
	}

	private async Task HandleFavoriteCreated(object? sender, Todo.Contracts.Favorites.FavoriteCreated message)
	{
		if (message.TargetType != ItemType.TodoItem)
		{
			return;
		}

		_favoriteIds.Add(message.ItemId);

		await InvokeAsync(StateHasChanged);
	}

	private async Task HandleFavoriteDeleted(object? sender, Todo.Contracts.Favorites.FavoriteDeleted message)
	{
		if (message.TargetType != ItemType.TodoItem)
		{
			return;
		}

		_favoriteIds.Remove(message.ItemId);

		await InvokeAsync(StateHasChanged);
	}

	public void Dispose()
	{
		TodoItemService.ItemCreated -= Handle;
		TodoItemService.ItemUpdated -= Handle;
		TodoItemService.ItemDeleted -= Handle;
		FavoriteService.ItemCreated -= HandleFavoriteCreated;
		FavoriteService.ItemDeleted -= HandleFavoriteDeleted;
	}
}
