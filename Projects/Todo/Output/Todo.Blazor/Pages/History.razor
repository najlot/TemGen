@page "/history/{id:guid}"
@using System.Linq
@using Todo.Blazor.Pages;
@using Todo.Blazor.Services;
@using Todo.Client.Data.History;
@using Todo.Client.Localisation;
@using Todo.Contracts.History
@inject ILogger<History> Log
@inject IHistoryService HistoryService
@inject NavigationManager NavigationManager
@attribute [Authorize]

<PageTitle>@CommonLoc.History</PageTitle>

<section class="d-grid gap-2">
	<div class="card border-0">
		<div class="card-body">
			@if (isHistoryLoading)
			{
				<div class="text-body-secondary">@CommonLoc.Loading...</div>
			}
			else if (historyEntries.Length == 0)
			{
				<p class="mb-0 text-body-secondary">@CommonLoc.NoHistoryEntries</p>
			}
			else
			{
				<div class="d-grid gap-3">
					@foreach (var historyEntry in historyEntries)
					{
						<section class="pb-3">
							<div class="d-flex flex-column flex-md-row justify-content-between gap-2">
								<div>
									<div class="fw-semibold text-body">@FormatUsername(historyEntry.Username)</div>
									<div class="small text-body-secondary">@FormatHistoryTimestamp(historyEntry.TimeStamp)</div>
								</div>
								<div class="small text-body-secondary text-md-end">@historyEntry.Changes.Length @CommonLoc.ChangesRecorded</div>
							</div>

							<div class="table-responsive mt-2">
								<table class="table table-sm align-middle mb-0">
									<thead class="bg-body-tertiary">
										<tr>
											<th>@CommonLoc.Field</th>
											<th>@CommonLoc.Before</th>
											<th>@CommonLoc.After</th>
										</tr>
									</thead>
									<tbody>
										@foreach (var change in historyEntry.Changes)
										{
											<tr>
												<td class="fw-semibold text-break">@change.Path</td>
												<td class="text-break"><pre class="mb-0 text-wrap small">@change.OldValue</pre></td>
												<td class="text-break"><pre class="mb-0 text-wrap small">@change.NewValue</pre></td>
											</tr>
										}
									</tbody>
								</table>
							</div>
						</section>
					}
				</div>
			}
		</div>
	</div>
</section>

@code {
	[CascadingParameter(Name = "ErrorService")]
	protected IErrorService? ErrorService { get; set; }

	[Parameter]
	public Guid Id { get; set; }

	[SupplyParameterFromQuery(Name = "entityName")]
	public string? EntityName { get; set; }

	private Guid _lastEntityId;
	private string? _lastEntityName;
	private bool isHistoryLoading;
	private HistoryEntry[] historyEntries = [];

	protected override async Task OnParametersSetAsync()
	{
		if (_lastEntityId == Id && _lastEntityName == EntityName)
		{
			return;
		}

		_lastEntityId = Id;
		_lastEntityName = EntityName;
		isHistoryLoading = false;
		historyEntries = [];

		await LoadHistoryIfNeededAsync();
	}

	private async Task LoadHistoryIfNeededAsync()
	{
		if (Id == Guid.Empty || isHistoryLoading)
		{
			return;
		}

		try
		{
			isHistoryLoading = true;
			historyEntries = await HistoryService.GetItemsAsync(Id, EntityName ?? string.Empty);
		}
		catch (Todo.Client.Data.Identity.SessionUnavailableException)
		{
			var url = NavigationManager.BuildReturnUrl("/login");
			NavigationManager.NavigateTo(url);
		}
		catch (Exception ex)
		{
			Log.LogError(ex, "Error loading history for entity {EntityId}.", Id);
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorCouldNotLoad);
			historyEntries = [];
		}
		finally
		{
			isHistoryLoading = false;
		}
	}

	private static string FormatHistoryTimestamp(DateTime timeStamp)
		=> timeStamp.ToLocalTime().ToString("g");

	private static string FormatUsername(string? username)
		=> string.IsNullOrWhiteSpace(username) ? "-" : username;
}
