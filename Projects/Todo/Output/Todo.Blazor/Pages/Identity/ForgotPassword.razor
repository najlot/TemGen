@page "/ForgotPassword"

@using System.ComponentModel.DataAnnotations;
@using Todo.Blazor.Identity;
@using Todo.Blazor.Services;
@using Todo.Client.Data.Identity;
@using Todo.Client.Localisation;

@inject IAuthenticationService AuthenticationService
@inject IPasswordResetService PasswordResetService
@inject NavigationManager NavigationManager
@inject ILogger<ForgotPassword> Logger

<PageTitle>@UserLoc.ForgotPassword</PageTitle>

<EditForm Model="@Input" OnValidSubmit="@RequestResetCode">
	<section class="w-100 p-4 d-flex justify-content-center pb-4">
		<div>
			<h1>@UserLoc.ForgotPassword</h1>
			<br />
			<DataAnnotationsValidator />
			<ValidationSummary />

			<div class="form-outline mb-4">
				<label class="form-label" for="EmailInput">@UserLoc.EmailAddress</label>
				<InputText type="email" id="EmailInput" class="form-control" @bind-Value="Input.EMail" />
			</div>

			<div class="form-outline mb-4">
				<button type="submit" class="btn btn-primary w-100">@UserLoc.SendResetCode</button>
			</div>

			<div class="form-outline mb-4">
				<a href="/Login" class="btn btn-link w-100">@UserLoc.Login</a>
			</div>
		</div>
	</section>
</EditForm>

@code {
	private class InputModel
	{
		[Required]
		[EmailAddress]
		public string EMail { get; set; } = string.Empty;
	}

	private InputModel Input = new();

	[CascadingParameter(Name = "ErrorService")]
	protected IErrorService? ErrorService { get; set; }

	protected override async Task OnInitializedAsync()
	{
		ErrorService?.HideError();
		await AuthenticationService.LogoutAsync();
		await base.OnInitializedAsync();
	}

	private async Task RequestResetCode()
	{
		try
		{
			var result = await PasswordResetService.RequestPasswordReset(Input.EMail);

			if (!result.IsSuccess)
			{
				ErrorService?.ShowError(UserLoc.ForgotPassword, result.ErrorMessage);
				return;
			}

			ErrorService?.HideError();
			NavigationManager.NavigateTo($"/ResetPassword?email={System.Uri.EscapeDataString(Input.EMail.Trim())}");
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Error requesting password reset code.");
			ErrorService?.ShowError(UserLoc.ForgotPassword, ErrorLoc.ErrorCouldNotLoad);
		}
	}
}