@page "/TodoItem/{id:guid}"
@using Microsoft.Extensions.Localization;
@using Todo.Blazor.Identity;
@using Todo.Blazor.Services;
@using Todo.Client.Data;
@using Todo.Client.Data.TodoItems;
@using Todo.Client.Data.Users;
@using Todo.Client.Localisation;
@using Todo.Contracts.TodoItems;

@inject ILogger<TodoItem> Log
@inject Najlot.Map.IMap Map;
@inject ITodoItemService TodoItemService
@inject IUserService UserService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<TodoItemStatusLoc> TodoItemStatusLocalizer

@attribute [Authorize]
@implements IDisposable

@if (isNew)
{
	<PageTitle>@TodoItemLoc.CreateTodoItem</PageTitle>
}
else
{
	<PageTitle>@TodoItemLoc.EditTodoItem</PageTitle>
}

@if (Model == null)
{
	<p><em>@CommonLoc.Loading...</em></p>
}
else
{
	<section class="d-grid gap-4">
		<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3">
			<div>
				@if (isNew)
				{
					<h1 class="mb-1">@TodoItemLoc.CreateTodoItem</h1>
				}
				else
				{
					<h1 class="mb-1">@TodoItemLoc.EditTodoItem</h1>
				}
			</div>
			<div class="d-flex flex-wrap gap-2">
				<IconButton Icon="Undo"
							ButtonClass="btn btn-outline-secondary"
							CanExecute="() => _changeTracker.CanUndo"
							Execute="_changeTracker.Undo" />
				<IconButton Icon="Redo"
							ButtonClass="btn btn-outline-secondary"
							CanExecute="() => _changeTracker.CanRedo"
							Execute="_changeTracker.Redo" />
				@if (!isNew)
				{
					<IconButton Icon="history"
								ButtonClass="btn btn-outline-secondary"
								Execute="NavigateToHistory"
								Title="@CommonLoc.History" />
				}
				<IconButton Icon="Save"
							ButtonClass="btn btn-success"
							Execute="Save"
							Title="@CommonLoc.Save" />
				<IconButton Icon="Delete"
							ButtonClass="btn btn-danger"
							CanExecute="() => !isDeleteRequested"
							Execute="() => isDeleteRequested = true"
							Title="@CommonLoc.Delete" />
			</div>
		</div>

		<EditForm Model="@Model" OnValidSubmit="@Save">
			<div class="card shadow-sm border-0">
				<div class="card-body">
					<DataAnnotationsValidator />
					<ValidationSummary class="alert alert-danger mb-4" />
					<div class="row g-3">

						<!-- Title input -->
						<div class="col-12 col-md-6">
							<label class="form-label" for="TitleInput">@TodoItemLoc.Title</label>
							<InputText type="text" id="TitleInput" class="form-control"
							   Value="@Model.Title"
							   ValueChanged="@((string v) => _changeTracker.TrackChange(Model, nameof(Model.Title), Model.Title, v))"
							   ValueExpression="@(() => Model.Title)" />
						</div>

						<!-- Content input -->
						<div class="col-12 col-md-6">
							<label class="form-label" for="ContentInput">@TodoItemLoc.Content</label>
							<InputText type="text" id="ContentInput" class="form-control"
							   Value="@Model.Content"
							   ValueChanged="@((string v) => _changeTracker.TrackChange(Model, nameof(Model.Content), Model.Content, v))"
							   ValueExpression="@(() => Model.Content)" />
						</div>

						<!-- CreatedAt input -->
						<div class="col-12 col-md-6">
							<label class="form-label" for="CreatedAtInput">@TodoItemLoc.CreatedAt</label>
							<InputDate id="CreatedAtInput" class="form-control"
							   Value="@Model.CreatedAt"
							   ValueChanged="@((DateTime v) => _changeTracker.TrackChange(Model, nameof(Model.CreatedAt), Model.CreatedAt, v))"
							   ValueExpression="@(() => Model.CreatedAt)" ParsingErrorMessage="@ErrorLoc.ParsingErrorMustBeDate" />
						</div>

						<!-- CreatedBy input -->
						<div class="col-12 col-md-6">
							<label class="form-label" for="CreatedByInput">@TodoItemLoc.CreatedBy</label>
							<InputText type="text" id="CreatedByInput" class="form-control"
							   Value="@Model.CreatedBy"
							   ValueChanged="@((string v) => _changeTracker.TrackChange(Model, nameof(Model.CreatedBy), Model.CreatedBy, v))"
							   ValueExpression="@(() => Model.CreatedBy)" />
						</div>

						<!-- AssignedTo input -->
						<div class="col-12 col-md-6">
							<label class="form-label" for="AssignedToInput">@TodoItemLoc.AssignedTo</label>
							<InputSelect id="AssignedToInput" class="form-select"
								 Value="@Model.AssignedToId"
								 ValueChanged="@((Guid v) => _changeTracker.TrackChange(Model, nameof(Model.AssignedToId), Model.AssignedToId, v))"
								 ValueExpression="@(() => Model.AssignedToId)">
						@foreach (var value in _users)
						{
							<option value="@value.Id">@value.Username</option>
						}
						</InputSelect>
						</div>

						<!-- Status input -->
						<div class="col-12 col-md-6">
							<label class="form-label" for="StatusInput">@TodoItemLoc.Status</label>
							<InputSelect id="StatusInput" class="form-select"
								 Value="@Model.Status"
								 ValueChanged="@((TodoItemStatus v) => _changeTracker.TrackChange(Model, nameof(Model.Status), Model.Status, v))"
								 ValueExpression="@(() => Model.Status)" >
						@foreach (var value in Enum.GetValues(typeof(TodoItemStatus)))
						{
							<option value="@value">@TodoItemStatusLocalizer[$"{@value}"]</option>
						}
						</InputSelect>
						</div>

						<!-- ChangedAt input -->
						<div class="col-12 col-md-6">
							<label class="form-label" for="ChangedAtInput">@TodoItemLoc.ChangedAt</label>
							<InputDate id="ChangedAtInput" class="form-control"
							   Value="@Model.ChangedAt"
							   ValueChanged="@((DateTime v) => _changeTracker.TrackChange(Model, nameof(Model.ChangedAt), Model.ChangedAt, v))"
							   ValueExpression="@(() => Model.ChangedAt)" ParsingErrorMessage="@ErrorLoc.ParsingErrorMustBeDate" />
						</div>

						<!-- ChangedBy input -->
						<div class="col-12 col-md-6">
							<label class="form-label" for="ChangedByInput">@TodoItemLoc.ChangedBy</label>
							<InputText type="text" id="ChangedByInput" class="form-control"
							   Value="@Model.ChangedBy"
							   ValueChanged="@((string v) => _changeTracker.TrackChange(Model, nameof(Model.ChangedBy), Model.ChangedBy, v))"
							   ValueExpression="@(() => Model.ChangedBy)" />
						</div>

						<!-- Priority input -->
						<div class="col-12 col-md-6">
							<label class="form-label" for="PriorityInput">@TodoItemLoc.Priority</label>
							<InputText type="text" id="PriorityInput" class="form-control"
							   Value="@Model.Priority"
							   ValueChanged="@((string v) => _changeTracker.TrackChange(Model, nameof(Model.Priority), Model.Priority, v))"
							   ValueExpression="@(() => Model.Priority)" />
						</div>
					</div>
				</div>
			</div>
			<div class="card shadow-sm border-0">
				<div class="card-header bg-body-tertiary d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
					<h2 class="h5 mb-0">@TodoItemLoc.Checklist</h2>
					<IconButton Icon="Add"
								ButtonClass="btn btn-success"
								Execute="AddChecklistEntry"
								Title="@CommonLoc.New" />
				</div>
				<div class="table-responsive">
					<table class="table table-striped align-middle mb-0">
						<thead class="table-light">
							<tr>
								<th>@ChecklistTaskLoc.IsDone</th>
								<th>@ChecklistTaskLoc.Description</th>
								<th class="text-end">@CommonLoc.Delete</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var entry in Model.Checklist)
							{
								<tr scope="row">
									<td><input type="checkbox" class="form-check-input" checked="@entry.IsDone" @onchange="@(ev => _changeTracker.TrackChange(entry, nameof(entry.IsDone), entry.IsDone, (bool)(ev.Value ?? false)))" /></td>
									<td><input type="text" class="form-control" value="@entry.Description" @onchange="@(ev => _changeTracker.TrackChange(entry, nameof(entry.Description), entry.Description, ev.Value?.ToString() ?? string.Empty))" /></td>
									<td class="text-end">
										<IconButton Icon="Delete"
													ButtonClass="btn btn-danger"
													Execute="() => RemoveChecklistEntry(entry.Id)"
													Title="@CommonLoc.Delete" />
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			</div>
			
		</EditForm>
	</section>

	<DeleteConfirmationDialog @bind-IsVisible="isDeleteRequested" Remove="Remove" />
}

@code {
	[CascadingParameter(Name = "ErrorService")]
	protected IErrorService? ErrorService { get; set; }

	[Parameter]
	public Guid Id { get; set; }

	private bool isNew = false;
	private bool isDeleteRequested = false;
	private TodoItemModel? Model;
	private readonly ChangeTracker _changeTracker = new();

	private IEnumerable<UserListItemModel> _users = [];

	private void NavigateToHistory()
	{
		if (Model is null || isNew)
		{
			return;
		}

		NavigationManager.NavigateTo($"/history/{Model.Id}");
	}

	protected override async Task OnInitializedAsync()
	{
		try
		{
			if (Id == Guid.Empty)
			{
				Model = TodoItemService.CreateTodoItem();
				isNew = true;
			}
			else
			{
				Model = await TodoItemService.GetItemAsync(Id);
			}

			_users = await UserService.GetItemsAsync();

			TodoItemService.ItemUpdated += Handle;
			_changeTracker.StateChanged += () => InvokeAsync(StateHasChanged);

			await TodoItemService.StartEventListener();
		}
		catch (Todo.Client.Data.Identity.SessionUnavailableException)
		{
			var url = NavigationManager.BuildReturnUrl("/login");
			NavigationManager.NavigateTo(url);
		}
		catch (Exception ex)
		{
			Log.LogError(ex, "Error loading TodoItem.");
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorCouldNotLoad);
		}
	}

	private async Task Save()
	{
		if (Model is null)
		{
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorModelIsNullReload);
			return;
		}

		try
		{
			if (isNew)
			{
				await TodoItemService.AddItemAsync(Model);
				Id = Model.Id;
				NavigationManager.NavigateTo($"/todoitem/{Model.Id}", false, true);
				isNew = false;
			}
			else
			{
				await TodoItemService.UpdateItemAsync(Model);
			}

			_changeTracker.Clear();
		}
		catch (Todo.Client.Data.Identity.SessionUnavailableException)
		{
			var url = NavigationManager.BuildReturnUrl("/login");
			NavigationManager.NavigateTo(url);
		}
		catch (Exception ex)
		{
			Log.LogError(ex, "Error saving TodoItem.");
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorCouldNotSave);
		}
	}

	private async Task Remove()
	{
		if (Model is null)
		{
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorModelIsNullReload);
			return;
		}

		try
		{
			if (!isNew)
			{
				await TodoItemService.DeleteItemAsync(Model.Id);
			}

			_changeTracker.Clear();
			NavigationManager.NavigateTo("/todoitems");
		}
		catch (Todo.Client.Data.Identity.SessionUnavailableException)
		{
			var url = NavigationManager.BuildReturnUrl("/login");
			NavigationManager.NavigateTo(url);
		}
		catch (Exception ex)
		{
			Log.LogError(ex, "Error deleting TodoItem.");
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorDeleting);
		}
	}

	private async Task Handle(object? sender, TodoItemUpdated message)
	{
		if (Model is null || Model.Id != message.Id)
		{
			return;
		}

		Map.From(message).To(Model);
		_changeTracker.Clear();

		await InvokeAsync(StateHasChanged);
	}

	private void AddChecklistEntry()
	{
		if (Model is null)
		{
			return;
		}

		var max = 0;

		if (Model.Checklist.Count > 0)
		{
			max = Model.Checklist.Max(e => e.Id) + 1;
		}

		var model = new ChecklistTaskModel() { Id = max };

		Model.Checklist.Add(model);

		_changeTracker.Track(
			nameof(Model.Checklist),
			() => Model.Checklist.Remove(model),
			() => Model.Checklist.Add(model));
	}

	private void RemoveChecklistEntry(int id)
	{
		if (Model is null)
		{
			return;
		}

		var oldItem = Model.Checklist.FirstOrDefault(i => i.Id == id);

		if (oldItem != null)
		{
			var index = Model.Checklist.IndexOf(oldItem);

			if (index != -1)
			{
				Model.Checklist.RemoveAt(index);

				_changeTracker.Track(
					nameof(Model.Checklist),
					() => Model.Checklist.Insert(index, oldItem),
					() => Model.Checklist.Remove(oldItem));
			}
		}
	}

	public void Dispose()
	{
		TodoItemService.ItemUpdated -= Handle;
	}
}
