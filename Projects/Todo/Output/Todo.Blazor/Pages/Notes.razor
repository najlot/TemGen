@page "/Notes"
@using Humanizer
@using Microsoft.AspNetCore.Components
@using Todo.Blazor.Services
@using Todo.Client.Data
@using Todo.Client.Data.Filters
@using Todo.Client.Data.Favorites
@using Todo.Client.Data.Notes
@using Todo.Client.Localisation
@using Todo.Contracts.Filters
@using Todo.Contracts.Shared
@using Todo.Contracts.Notes

@inject ILogger<Notes> Log
@inject Najlot.Map.IMap Map
@inject INoteService NoteService
@inject IFavoriteService FavoriteService
@inject NavigationManager NavigationManager

@attribute [Authorize]
@implements IDisposable

<PageTitle>@NoteLoc.Notes</PageTitle>

<section class="d-grid gap-3">
	<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
		<h1 class="mb-0">@NoteLoc.Notes</h1>
		<a href="/Note/@Guid.Empty" class="btn btn-success material-symbols-sharp">add</a>
	</div>

	<EntityFilterEditor @ref="filterEditor"
						AvailableFields="availableFilterFields"
						TargetType="ItemType.Note"
						IsBusy="isLoading"
						ApplyFilter="HandleFilterAppliedAsync" />

	@if (notes is null)
	{
		<p><em>@CommonLoc.Loading...</em></p>
	}
	else
	{
		<div class="card shadow-sm border-0">
			<div class="table-responsive">
				<table class="table table-hover align-middle mb-0">
					<thead class="bg-body-tertiary">
						<tr>
							<th class="text-center" style="width: 1%;">
								<span class="material-symbols-sharp text-warning" title="Favorite" aria-label="Favorite">star</span>
							</th>
							<th>@NoteLoc.Title</th>
							<th>@NoteLoc.Content</th>
							<th class="text-end">@CommonLoc.Edit</th>
						</tr>
					</thead>
					<tbody>
						@foreach (var note in notes)
						{
							<tr scope="row">
								<td class="text-center">
									@if (IsFavorite(note.Id))
									{
										<span class="material-symbols-sharp text-warning" title="Favorite" aria-label="Favorite">star</span>
									}
								</td>
								<td class="text-break">@note.Title.Truncate(75)</td>
								<td class="text-break">@note.Content.Truncate(75)</td>
								<td class="text-end"><a href="/Note/@note.Id" class="btn btn-outline-primary btn-sm">@CommonLoc.Edit</a></td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		</div>
	}
</section>

@code {
	[CascadingParameter(Name = "ErrorService")]
	protected IErrorService? ErrorService { get; set; }

	private EntityFilterEditor? filterEditor;
	private List<NoteListItemModel>? notes;
	private HashSet<Guid> _favoriteIds = [];
	private IReadOnlyList<FilterFieldOption> availableFilterFields = [];
	private bool isLoading;
	private EntityFilter? _lastFilter;

	protected override async Task OnInitializedAsync()
	{
		try
		{
			availableFilterFields = BuildFilterFieldOptions();

			NoteService.ItemCreated += Handle;
			NoteService.ItemUpdated += Handle;
			NoteService.ItemDeleted += Handle;
			FavoriteService.ItemCreated += HandleFavoriteCreated;
			FavoriteService.ItemDeleted += HandleFavoriteDeleted;

			await Task.WhenAll(
				NoteService.StartEventListener(),
				FavoriteService.StartEventListener());
		}
		catch (Todo.Client.Data.Identity.SessionUnavailableException)
		{
			var url = NavigationManager.BuildReturnUrl("/login");
			NavigationManager.NavigateTo(url);
		}
		catch (Exception ex)
		{
			Log.LogError(ex, "Error loading Notes.");
			notes = [];
			ErrorService?.ShowError(ErrorLoc.Error, ErrorLoc.ErrorCouldNotLoad);
		}
	}

	private Task HandleFilterAppliedAsync(EntityFilter filter)
		=> LoadItemsAsync(filter);

	private async Task RefreshAppliedFilterAsync()
	{
		if (filterEditor is null || isLoading)
		{
			return;
		}

		await filterEditor.RefreshAppliedFilterAsync();
	}

	private async Task LoadItemsAsync(EntityFilter filter)
	{
		try
		{
			isLoading = true;
			_lastFilter = filter;

			var itemsTask = filter.Conditions.Count == 0
				? NoteService.GetItemsAsync()
				: NoteService.GetItemsAsync(filter);
			var favoritesTask = FavoriteService.GetItemsAsync(ItemType.Note);

			var items = await itemsTask.ConfigureAwait(false);
			var favorites = await favoritesTask.ConfigureAwait(false);

			notes = [.. items];
			_favoriteIds = [.. favorites.Select(item => item.ItemId)];
		}
		catch (Todo.Client.Data.Identity.SessionUnavailableException)
		{
			var url = NavigationManager.BuildReturnUrl("/login");
			NavigationManager.NavigateTo(url);
		}
		catch (Exception ex)
		{
			Log.LogError(ex, "Error loading filtered Notes.");
			ErrorService?.ShowError(ErrorLoc.Error, ex.Message);
		}
		finally
		{
			isLoading = false;
		}

		await InvokeAsync(StateHasChanged);
	}

	private bool IsFavorite(Guid itemId)
		=> _favoriteIds.Contains(itemId);

	private IReadOnlyList<FilterFieldOption> BuildFilterFieldOptions()
	{
		return
		[
			new FilterFieldOption
			{
				Key = "Title",
				Label = NoteLoc.Title,
				Kind = FilterFieldKind.Text,
				Operators = FilterOperatorCatalog.CreateTextOptions(),
				Values = [],
			},
			new FilterFieldOption
			{
				Key = "Content",
				Label = NoteLoc.Content,
				Kind = FilterFieldKind.Text,
				Operators = FilterOperatorCatalog.CreateTextOptions(),
				Values = [],
			},
			new FilterFieldOption
			{
				Key = "Color",
				Label = NoteLoc.Color,
				Kind = FilterFieldKind.Option,
				Operators = FilterOperatorCatalog.CreateEqualityOptions(false),
				Values = [.. Enum.GetValues<PredefinedColor>().Select(value => new FilterValueOption
				{
					Value = value.ToString(),
					Label = value == PredefinedColor.None ? CommonLoc.NothingSelected : value.ToString(),
				})],
			},
		];
	}

	private async Task Handle(object? sender, NoteCreated message)
	{
		if (notes is null || _lastFilter is { Conditions.Count: > 0 })
		{
			return;
		}

		var item = Map.From(message).To<NoteListItemModel>();

		notes.Insert(0, item);

		await InvokeAsync(StateHasChanged);
	}

	private async Task Handle(object? sender, NoteUpdated message)
	{
		if (notes is null)
		{
			return;
		}

		var entry = notes.FirstOrDefault(t => t.Id == message.Id);

		if (entry is not null)
		{
			Map.From(message).To(entry);
		}

		await InvokeAsync(StateHasChanged);
	}

	private async Task Handle(object? sender, NoteDeleted message)
	{
		if (notes is null)
		{
			return;
		}

		var entry = notes.FirstOrDefault(t => t.Id == message.Id);

		if (entry is null)
		{
			return;
		}

		notes.Remove(entry);

		await InvokeAsync(StateHasChanged);
	}

	private async Task HandleFavoriteCreated(object? sender, Todo.Contracts.Favorites.FavoriteCreated message)
	{
		if (message.TargetType != ItemType.Note)
		{
			return;
		}

		_favoriteIds.Add(message.ItemId);

		await InvokeAsync(StateHasChanged);
	}

	private async Task HandleFavoriteDeleted(object? sender, Todo.Contracts.Favorites.FavoriteDeleted message)
	{
		if (message.TargetType != ItemType.Note)
		{
			return;
		}

		_favoriteIds.Remove(message.ItemId);

		await InvokeAsync(StateHasChanged);
	}

	public void Dispose()
	{
		NoteService.ItemCreated -= Handle;
		NoteService.ItemUpdated -= Handle;
		NoteService.ItemDeleted -= Handle;
		FavoriteService.ItemCreated -= HandleFavoriteCreated;
		FavoriteService.ItemDeleted -= HandleFavoriteDeleted;
	}
}
