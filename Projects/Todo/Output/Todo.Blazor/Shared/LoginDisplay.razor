@using Todo.Blazor.Identity;
@using Todo.Client.Localisation;
@inject IAuthenticationService AuthenticationService
@inject NavigationManager NavigationManager

<AuthorizeView>
	<Authorized>
		<div class="nav-item pt-1">
			<a class="nav-link material-symbols-sharp mt-1" href="global-search">search</a>
		</div>
		<div class="nav-item pe-3">
			<a class="nav-link" href="Manage">@CommonLoc.Hello, @context.User.Identity?.Name!</a>
		</div>
		<div class="nav-item">
			<button class="nav-link" type="button" @onclick="Logout">@UserLoc.Logout</button>
		</div>
	</Authorized>
	<NotAuthorized>
		<div class="nav-item">
			<a class="nav-link" href="Register">@UserLoc.Register</a>
		</div>
		<div class="nav-item">
			<a class="nav-link" href="Login">@UserLoc.Login</a>
		</div>
	</NotAuthorized>
</AuthorizeView>

@code {
	private async Task Logout()
	{
		await AuthenticationService.LogoutAsync();
		NavigationManager.NavigateTo("/");
	}
}