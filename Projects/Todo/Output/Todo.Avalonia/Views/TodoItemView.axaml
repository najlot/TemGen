<UserControl x:Class="Todo.Avalonia.Views.TodoItemView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:contracts="clr-namespace:Todo.Contracts;assembly=Todo.Contracts"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:Todo.Client.Localisation;assembly=Todo.Client.Localisation"
             xmlns:local="using:Todo.Avalonia.Views"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vms="clr-namespace:Todo.ClientBase.TodoItems;assembly=Todo.ClientBase"
             d:DesignHeight="750"
             d:DesignWidth="1000"
             x:DataType="vms:TodoItemViewModel"
             mc:Ignorable="d">
	<Grid>
		<Grid IsEnabled="{Binding CanEdit}" RowDefinitions="Auto,*">
			<!--  Header  -->
			<Grid Margin="16" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto">
				<Button Grid.Column="0" Margin="0,0,16,0" Command="{Binding NavigateBackCommand}">
					<materialIcons:MaterialIcon Width="24" Height="24" Kind="ArrowBack" />
				</Button>
				<Button Grid.Column="2" Margin="8,0" Command="{Binding UndoCommand}">
					<materialIcons:MaterialIcon Width="24" Height="24" Kind="Undo" />
				</Button>
				<Button Grid.Column="3" Margin="8,0" Command="{Binding RedoCommand}">
					<materialIcons:MaterialIcon Width="24" Height="24" Kind="Redo" />
				</Button>
				<Button Grid.Column="4" Margin="8,0" Command="{Binding NavigateToHistoryCommand}">
					<materialIcons:MaterialIcon Width="24" Height="24" Kind="History" />
				</Button>
				<Button Grid.Column="5" Margin="8,0" Command="{Binding SaveCommand}">
					<materialIcons:MaterialIcon Width="24" Height="24" Kind="ContentSave" />
				</Button>
				<Button Grid.Column="6" Margin="8,0" Command="{Binding DeleteCommand}">
					<materialIcons:MaterialIcon Width="24" Height="24" Kind="Delete" />
				</Button>
			</Grid>

			<!--  Main Content  -->
			<ScrollViewer Grid.Row="1">
				<StackPanel MinWidth="400"
				            MinHeight="200"
				            Margin="2,0"
				            HorizontalAlignment="Center"
				            VerticalAlignment="Center">
					<TextBlock Text="{x:Static loc:TodoItemLoc.Title}" />
					<TextBox Margin="0,0,0,8" VerticalAlignment="Stretch" Text="{Binding Title, Mode=TwoWay}" />
					<TextBlock Text="{x:Static loc:TodoItemLoc.Content}" />
					<TextBox Margin="0,0,0,8" VerticalAlignment="Stretch" Text="{Binding Content, Mode=TwoWay}" />
					<TextBlock Text="{x:Static loc:TodoItemLoc.CreatedAt}" />
					<DatePicker Margin="0,0,0,8" SelectedDate="{Binding CreatedAtDate, Mode=TwoWay}" />
					<TimePicker ClockIdentifier="24HourClock" Margin="0,0,0,8"
							    SelectedTime="{Binding CreatedAtTime, Mode=TwoWay}" />
					<TextBlock Text="{x:Static loc:TodoItemLoc.CreatedBy}" />
					<TextBox Margin="0,0,0,8" VerticalAlignment="Stretch" Text="{Binding CreatedBy, Mode=TwoWay}" />
					<TextBlock Text="{x:Static loc:TodoItemLoc.AssignedTo}" />
					<ComboBox Margin="0,0,0,8" ItemsSource="{Binding AvailableUsers}" SelectedValue="{Binding AssignedToId}" SelectedValueBinding="{Binding Id}">
						<ComboBox.ItemTemplate>
							<DataTemplate>
								<TextBlock Text="{Binding Username}" />
							</DataTemplate>
						</ComboBox.ItemTemplate>
					</ComboBox>
					<TextBlock Text="{x:Static loc:TodoItemLoc.Status}" />
					<ComboBox Margin="0,0,0,8" ItemsSource="{Binding AvailableTodoItemStatus}" SelectedItem="{Binding Status}" />
					<TextBlock Text="{x:Static loc:TodoItemLoc.ChangedAt}" />
					<DatePicker Margin="0,0,0,8" SelectedDate="{Binding ChangedAtDate, Mode=TwoWay}" />
					<TimePicker ClockIdentifier="24HourClock" Margin="0,0,0,8"
							    SelectedTime="{Binding ChangedAtTime, Mode=TwoWay}" />
					<TextBlock Text="{x:Static loc:TodoItemLoc.ChangedBy}" />
					<TextBox Margin="0,0,0,8" VerticalAlignment="Stretch" Text="{Binding ChangedBy, Mode=TwoWay}" />
					<TextBlock Text="{x:Static loc:TodoItemLoc.Priority}" />
					<TextBox Margin="0,0,0,8" VerticalAlignment="Stretch" Text="{Binding Priority, Mode=TwoWay}" />
					<DockPanel DockPanel.Dock="Top">
						<Button Margin="5" Command="{Binding AddChecklistTaskCommand}" DockPanel.Dock="Right">
							<materialIcons:MaterialIcon Width="24" Height="24" Kind="Add" />
						</Button>

						<Border Margin="0,8" Padding="5" Background="{StaticResource BackgroundColor}">
							<TextBlock Foreground="{StaticResource ForegroundColor}" Text="{x:Static loc:TodoItemLoc.Checklist}" />
						</Border>
					</DockPanel>

					<ItemsControl ItemsSource="{Binding Checklist}">
						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="vms:ChecklistTaskViewModel">
								<Border Margin="0,0,5,8"
										Padding="8"
										BorderBrush="LightGray"
										BorderThickness="1">
									<StackPanel>
											<DockPanel Margin="5">
												<TextBlock MinWidth="75" />
												<CheckBox Content="{x:Static loc:ChecklistTaskLoc.IsDone}" IsChecked="{Binding IsDone}" />
											</DockPanel>
											<DockPanel Margin="5">
												<TextBlock MinWidth="75" VerticalAlignment="Center" Text="{x:Static loc:ChecklistTaskLoc.Description}" />
												<TextBox Text="{Binding Description, Mode=TwoWay}" />
											</DockPanel>

											<Button HorizontalAlignment="Right"
													Background="Transparent"
													BorderThickness="0"
													Command="{Binding $parent[ItemsControl].((vms:TodoItemViewModel)DataContext).DeleteChecklistTaskCommand}"
													CommandParameter="{Binding .}"
													Foreground="{StaticResource BackgroundColor}">
												<materialIcons:MaterialIcon Width="24" Height="24" Kind="Delete" />
											</Button>
									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

				</StackPanel>
			</ScrollViewer>
		</Grid>

		<local:SaveConfirmationDialogView DataContext="{Binding $parent[Grid].((vms:TodoItemViewModel)DataContext).SaveDialogViewModel}" IsVisible="{Binding IsVisible}" />
		<local:DeleteConfirmationDialogView DataContext="{Binding $parent[Grid].((vms:TodoItemViewModel)DataContext).DeleteDialogViewModel}" IsVisible="{Binding IsVisible}" />
	</Grid>
</UserControl>
