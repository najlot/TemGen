<UserControl x:Class="Todo.Avalonia.Views.NoteView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:contracts="clr-namespace:Todo.Contracts;assembly=Todo.Contracts"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:Todo.Client.Localisation;assembly=Todo.Client.Localisation"
             xmlns:local="using:Todo.Avalonia.Views"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vms="clr-namespace:Todo.ClientBase.Notes;assembly=Todo.ClientBase"
             d:DesignHeight="750"
             d:DesignWidth="1000"
             x:DataType="vms:NoteViewModel"
             mc:Ignorable="d">
	<Grid>
		<Grid IsEnabled="{Binding CanEdit}" RowDefinitions="Auto,*">
			<!--  Header  -->
			<Grid Margin="16" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto">
				<Button Grid.Column="0" Margin="0,0,16,0" Command="{Binding NavigateBackCommand}">
					<materialIcons:MaterialIcon Width="24" Height="24" Kind="ArrowBack" />
				</Button>
				<Button Grid.Column="2" Margin="8,0" Command="{Binding UndoCommand}">
					<materialIcons:MaterialIcon Width="24" Height="24" Kind="Undo" />
				</Button>
				<Button Grid.Column="3" Margin="8,0" Command="{Binding RedoCommand}">
					<materialIcons:MaterialIcon Width="24" Height="24" Kind="Redo" />
				</Button>
				<Button Grid.Column="4" Margin="8,0" Command="{Binding NavigateToHistoryCommand}">
					<materialIcons:MaterialIcon Width="24" Height="24" Kind="History" />
				</Button>
				<Button Grid.Column="5" Margin="8,0" Command="{Binding SaveCommand}">
					<materialIcons:MaterialIcon Width="24" Height="24" Kind="ContentSave" />
				</Button>
				<Button Grid.Column="6" Margin="8,0" Command="{Binding DeleteCommand}">
					<materialIcons:MaterialIcon Width="24" Height="24" Kind="Delete" />
				</Button>
			</Grid>

			<!--  Main Content  -->
			<ScrollViewer Grid.Row="1">
				<StackPanel MinWidth="400"
				            MinHeight="200"
				            Margin="2,0"
				            HorizontalAlignment="Center"
				            VerticalAlignment="Center">
					<TextBlock Text="{x:Static loc:NoteLoc.Title}" />
					<TextBox Margin="0,0,0,8" VerticalAlignment="Stretch" Text="{Binding Title, Mode=TwoWay}" />
					<TextBlock Text="{x:Static loc:NoteLoc.Content}" />
					<TextBox Margin="0,0,0,8" VerticalAlignment="Stretch" Text="{Binding Content, Mode=TwoWay}" />
					<TextBlock Text="{x:Static loc:NoteLoc.Color}" />
					<ComboBox Margin="0,0,0,8" ItemsSource="{Binding AvailablePredefinedColors}" SelectedItem="{Binding Color}" />

				</StackPanel>
			</ScrollViewer>
		</Grid>

		<local:SaveConfirmationDialogView DataContext="{Binding $parent[Grid].((vms:NoteViewModel)DataContext).SaveDialogViewModel}" IsVisible="{Binding IsVisible}" />
		<local:DeleteConfirmationDialogView DataContext="{Binding $parent[Grid].((vms:NoteViewModel)DataContext).DeleteDialogViewModel}" IsVisible="{Binding IsVisible}" />
	</Grid>
</UserControl>
