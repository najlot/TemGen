<UserControl x:Class="Todo.Avalonia.Views.DeleteConfirmationDialogView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:Todo.Client.Localisation;assembly=Todo.Client.Localisation"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vms="clr-namespace:Todo.ClientBase.ViewModels;assembly=Todo.ClientBase"
             x:DataType="vms:DeleteConfirmationDialogViewModel"
             mc:Ignorable="d">
	<Grid Background="#80000000" IsVisible="{Binding IsVisible}">
		<Border MinWidth="300"
		        Padding="20"
		        HorizontalAlignment="Center"
		        VerticalAlignment="Center"
		        Background="{StaticResource ForegroundColor}"
		        BorderBrush="{StaticResource BackgroundColor}"
		        BorderThickness="1">
			<StackPanel>
				<TextBlock Margin="0,0,0,10"
				           FontSize="16"
				           FontWeight="Bold"
				           Text="{Binding Title}" />
				<TextBlock Margin="0,0,0,20" Text="{Binding Description}" TextWrapping="Wrap" />
				<StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
					<Button Margin="5" Command="{Binding DeleteCommand}" Content="{x:Static loc:CommonLoc.Delete}" />
					<Button Margin="5" Command="{Binding CancelCommand}" Content="{x:Static loc:CommonLoc.Cancel}" />
				</StackPanel>
			</StackPanel>
		</Border>
	</Grid>
</UserControl>
