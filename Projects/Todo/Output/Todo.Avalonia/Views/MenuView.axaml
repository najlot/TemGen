<UserControl x:Class="Todo.Avalonia.Views.MenuView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:Todo.Client.Localisation;assembly=Todo.Client.Localisation"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vms="clr-namespace:Todo.ClientBase.Shared;assembly=Todo.ClientBase"
             d:DesignHeight="700"
             d:DesignWidth="1000"
             x:DataType="vms:MenuViewModel"
             mc:Ignorable="d">

	<UserControl.Styles>
		<!--  Style for navigation menu buttons  -->
		<Style Selector="Button.NavMenuItem">
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="HorizontalContentAlignment" Value="Left" />
			<Setter Property="Padding" Value="16,12" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="CornerRadius" Value="0" />
			<Setter Property="Margin" Value="0,0,0,4" />
		</Style>
	</UserControl.Styles>

	<Grid>
		<Grid RowDefinitions="Auto,*">
			<!--  Header  -->
			<Grid Grid.Row="0"
			      Margin="16"
			      Background="White"
			      ColumnDefinitions="Auto,*,Auto,Auto,Auto">
				<Button Grid.Column="0" Command="{Binding ToggleDrawerCommand}">
					<materialIcons:MaterialIcon Width="24" Height="24" Kind="Menu" />
				</Button>
				<Button Grid.Column="2" Margin="0,0,8,0" Command="{Binding NavigateToGlobalSearch}">
					<materialIcons:MaterialIcon Width="24" Height="24" Kind="Search" />
				</Button>
				<Button Grid.Column="3" Margin="0,0,8,0" Command="{Binding ManageCommand}">
					<materialIcons:MaterialIcon Width="24" Height="24" Kind="User" />
				</Button>
				<Button Grid.Column="4" Command="{Binding LogoutCommand}">
					<materialIcons:MaterialIcon Width="24" Height="24" Kind="DoorOpen" />
				</Button>
			</Grid>
		</Grid>

		<!--  Overlay (visible when drawer is open)  -->
		<Border Background="#80000000"
		        IsVisible="{Binding IsDrawerOpen}"
		        PointerPressed="OnOverlayPointerPressed"
		        ZIndex="1" />

		<!--  Off-Canvas Navigation Drawer  -->
		<Border Width="280"
		        HorizontalAlignment="Left"
		        Background="White"
		        IsVisible="{Binding IsDrawerOpen}"
		        ZIndex="2">
			<ScrollViewer>
				<StackPanel Spacing="0">
					<!--  Drawer Header  -->
					<Border Padding="16">
						<TextBlock FontSize="20" FontWeight="SemiBold" Text="Navigation" />
					</Border>

					<!--  Navigation Items  -->
					<Button Classes="NavMenuItem" Command="{Binding NavigateToNotes}">
						<Grid ColumnDefinitions="Auto,*">
							<materialIcons:MaterialIcon Grid.Column="0"
							                            Width="24"
							                            Height="24"
							                            Margin="0,0,12,0"
							                            Kind="Note" />
							<TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Static loc:NoteLoc.Notes}" />
						</Grid>
					</Button>
					<Button Classes="NavMenuItem" Command="{Binding NavigateToTodoItems}">
						<Grid ColumnDefinitions="Auto,*">
							<materialIcons:MaterialIcon Grid.Column="0"
							                            Width="24"
							                            Height="24"
							                            Margin="0,0,12,0"
							                            Kind="Note" />
							<TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Static loc:TodoItemLoc.TodoItems}" />
						</Grid>
					</Button>
					<Button Classes="NavMenuItem" Command="{Binding NavigateToTrash}">
						<Grid ColumnDefinitions="Auto,*">
							<materialIcons:MaterialIcon Grid.Column="0"
							                            Width="24"
							                            Height="24"
							                            Margin="0,0,12,0"
							                            Kind="Delete" />
							<TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Static loc:TrashLoc.Trash}" />
						</Grid>
					</Button>
				</StackPanel>
			</ScrollViewer>
		</Border>
	</Grid>
</UserControl>
