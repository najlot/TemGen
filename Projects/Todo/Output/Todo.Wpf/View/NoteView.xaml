<UserControl x:Class="Todo.Wpf.View.NoteView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:local="clr-namespace:Todo.Wpf.View"
			 xmlns:loc="clr-namespace:Todo.Client.Localisation;assembly=Todo.Client.Localisation"
			 xmlns:converter="clr-namespace:Todo.Wpf.Converter"
			 xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
			 mc:Ignorable="d"
			 d:DesignHeight="500" d:DesignWidth="600">
	<Grid>
		<DockPanel IsEnabled="{Binding CanEdit}">
			<DockPanel DockPanel.Dock="Top">
				<Button Margin="5"
						DockPanel.Dock="Left"
						Command="{Binding NavigateBackCommand}">
					<Button.Content>
						<materialIcons:MaterialIcon Kind="ArrowLeft" Width="18" Height="18" />
					</Button.Content>
				</Button>

				<WrapPanel HorizontalAlignment="Right" DockPanel.Dock="Right">
					<Button ToolTip="{x:Static loc:CommonLoc.Undo}" Command="{Binding UndoCommand}" Margin="5">
						<Button.Content>
							<materialIcons:MaterialIcon Kind="Undo" Width="18" Height="18" />
						</Button.Content>
					</Button>
					<Button ToolTip="{x:Static loc:CommonLoc.Redo}" Command="{Binding RedoCommand}" Margin="5">
						<Button.Content>
							<materialIcons:MaterialIcon Kind="Redo" Width="18" Height="18" />
						</Button.Content>
					</Button>
					<Button ToolTip="{x:Static loc:CommonLoc.Save}" Command="{Binding SaveCommand}" Margin="5">
						<Button.Content>
							<materialIcons:MaterialIcon Kind="ContentSave" Width="18" Height="18" />
						</Button.Content>
					</Button>
					<Button ToolTip="{x:Static loc:CommonLoc.Delete}" Command="{Binding DeleteCommand}" Margin="5">
						<Button.Content>
							<materialIcons:MaterialIcon Kind="Delete" Width="18" Height="18" />
						</Button.Content>
					</Button>
				</WrapPanel>
			</DockPanel>
			<ScrollViewer>
				<StackPanel Margin="2,0" MinWidth="400" MinHeight="200"
						HorizontalAlignment="Center" VerticalAlignment="Center">
					<DockPanel Margin="5">
						<Label Content="{x:Static loc:NoteLoc.Title}" MinWidth="75" />
						<TextBox Text="{Binding Title}" />
					</DockPanel>
					<DockPanel Margin="5">
						<Label Content="{x:Static loc:NoteLoc.Content}" MinWidth="75" />
						<TextBox Text="{Binding Content}" />
					</DockPanel>
					<DockPanel Margin="5">
						<Label Content="{x:Static loc:NoteLoc.Color}" MinWidth="75" />
						<ComboBox ItemsSource="{Binding AvailablePredefinedColors, Converter={x:Static converter:EnumToTranslationConverter.Instance}, ConverterParameter={x:Type loc:PredefinedColorLoc}}"
								  SelectedItem="{Binding Color, Converter={x:Static converter:EnumToTranslationConverter.Instance}, ConverterParameter={x:Type loc:PredefinedColorLoc}}" />
					</DockPanel>
				</StackPanel>
			</ScrollViewer>
		</DockPanel>

		<local:SaveConfirmationDialogView Visibility="{Binding SaveDialogViewModel.IsVisible, Converter={x:Static converter:BooleanToVisibilityConverter.Instance}}"
							  DataContext="{Binding SaveDialogViewModel}" />
		<local:DeleteConfirmationDialogView Visibility="{Binding DeleteDialogViewModel.IsVisible, Converter={x:Static converter:BooleanToVisibilityConverter.Instance}}"
							  DataContext="{Binding DeleteDialogViewModel}" />
	</Grid>
</UserControl>