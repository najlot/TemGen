<UserControl x:Class="Todo.Wpf.View.MenuView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:local="clr-namespace:Todo.Wpf.View"
			 xmlns:loc="clr-namespace:Todo.Client.Localisation;assembly=Todo.Client.Localisation"
			 xmlns:converter="clr-namespace:Todo.Wpf.Converter"
			 xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
			 mc:Ignorable="d"
			 d:DesignHeight="450" d:DesignWidth="800">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
			<Button Command="{Binding ToggleDrawerCommand}" Margin="5">
				<materialIcons:MaterialIcon Kind="Menu" Width="18" Height="18" />
			</Button>
		</StackPanel>
		
		<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
			<Button Command="{Binding NavigateToGlobalSearch}" ToolTip="{x:Static loc:GlobalSearchLoc.GlobalSearch}" Margin="5">
				<Button.Content>
					<materialIcons:MaterialIcon Kind="Magnify" Width="18" Height="18" />
				</Button.Content>
			</Button>
			<Button Command="{Binding ManageCommand}" ToolTip="Manage" Margin="5">
				<Button.Content>
					<materialIcons:MaterialIcon Kind="User" Width="18" Height="18" />
				</Button.Content>
			</Button>
			<Button Command="{Binding LogoutCommand}" ToolTip="Logout" Margin="5">
				<Button.Content>
					<materialIcons:MaterialIcon Kind="Logout" Width="18" Height="18" />
				</Button.Content>
			</Button>
		</StackPanel>

		<!--  Overlay (visible when drawer is open)  -->
		<Border Background="#80000000"
				Grid.RowSpan="2"
		        Visibility="{Binding IsDrawerOpen, Converter={x:Static converter:BooleanToVisibilityConverter.Instance}}"
		        Panel.ZIndex="1" >
			<Border.InputBindings>
				<MouseBinding MouseAction="LeftClick" Command="{Binding ToggleDrawerCommand}" />
			</Border.InputBindings>
		</Border>

		<!--  Off-Canvas Navigation Drawer  -->
		<Border Width="200"
				Background="White"
		        HorizontalAlignment="Left"
				Grid.RowSpan="2"
		        Visibility="{Binding IsDrawerOpen, Converter={x:Static converter:BooleanToVisibilityConverter.Instance}}"
		        Panel.ZIndex="2">
			<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
				<StackPanel Margin="5">
					<!--  Drawer Header  -->
					<TextBlock FontSize="20" FontWeight="SemiBold" Text="{x:Static loc:CommonLoc.Navigation}" Margin="5,10" />

					<!--  Navigation Items  -->
					<Button Command="{Binding NavigateToNotes}" Margin="5" HorizontalContentAlignment="Left">
						<Grid ColumnDefinitions="Auto,*">
							<materialIcons:MaterialIcon Width="18" Height="18" Margin="0,0,10,0" Kind="Note" />
							<TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Static loc:NoteLoc.Notes}" />
						</Grid>
					</Button>
					<Button Command="{Binding NavigateToTodoItems}" Margin="5" HorizontalContentAlignment="Left">
						<Grid ColumnDefinitions="Auto,*">
							<materialIcons:MaterialIcon Width="18" Height="18" Margin="0,0,10,0" Kind="Note" />
							<TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Static loc:TodoItemLoc.TodoItems}" />
						</Grid>
					</Button>
					<Button Command="{Binding NavigateToGlobalSearch}" Margin="5,20,5,5" HorizontalContentAlignment="Left">
						<Grid ColumnDefinitions="Auto,*">
							<materialIcons:MaterialIcon Width="18" Height="18" Margin="0,0,10,0" Kind="Magnify" />
							<TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Static loc:GlobalSearchLoc.GlobalSearch}" />
						</Grid>
					</Button>
					<Button Command="{Binding NavigateToTrash}" Margin="5" HorizontalContentAlignment="Left">
						<Grid ColumnDefinitions="Auto,*">
							<materialIcons:MaterialIcon Width="18" Height="18" Margin="0,0,10,0" Kind="Delete" />
							<TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Static loc:TrashLoc.Trash}" />
						</Grid>
					</Button>
				</StackPanel>
			</ScrollViewer>
		</Border>
	</Grid>
</UserControl>
