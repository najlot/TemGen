<UserControl x:Class="Todo.Wpf.Views.MenuView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:local="clr-namespace:Todo.Wpf.Views"
			 xmlns:loc="clr-namespace:Todo.Client.Localisation;assembly=Todo.Client.Localisation"
			 xmlns:converter="clr-namespace:Todo.Wpf.Converters"
			 xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
			 mc:Ignorable="d"
			 d:DesignHeight="450" d:DesignWidth="800">
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<Border Grid.Column="0"
				Background="White"
				BorderBrush="#14000000"
				BorderThickness="0,0,1,0">
			<Border.Style>
				<Style TargetType="Border">
					<Setter Property="Width" Value="50" />
					<Style.Triggers>
						<DataTrigger Binding="{Binding IsDrawerOpen}" Value="True">
							<Setter Property="Width" Value="200" />
						</DataTrigger>
					</Style.Triggers>
				</Style>
			</Border.Style>
			<ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
				<StackPanel Margin="5">
					<Button Command="{Binding ToggleDrawerCommand}" Margin="0,0,0,12" HorizontalContentAlignment="Left" ToolTip="{x:Static loc:CommonLoc.Navigation}">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<materialIcons:MaterialIcon Kind="Menu" Width="18" Height="18" Margin="1,0" />
							<TextBlock Grid.Column="1"
									   VerticalAlignment="Center"
									   Margin="12,0,0,0"
									   Text="{x:Static loc:CommonLoc.Navigation}"
									   Visibility="{Binding IsDrawerOpen, Converter={x:Static converter:BooleanToVisibilityConverter.Instance}}" />
						</Grid>
					</Button>

					<!--  Navigation Items  -->
					<Button Command="{Binding NavigateToNotes}" Margin="0,0,0,8" HorizontalContentAlignment="Left" ToolTip="{x:Static loc:NoteLoc.Notes}">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<materialIcons:MaterialIcon Width="18" Height="18" Margin="1,0" Kind="Note" />
							<TextBlock Grid.Column="1"
									   VerticalAlignment="Center"
									   Margin="12,0,0,0"
									   Text="{x:Static loc:NoteLoc.Notes}"
									   Visibility="{Binding IsDrawerOpen, Converter={x:Static converter:BooleanToVisibilityConverter.Instance}}" />
						</Grid>
					</Button>
					<Button Command="{Binding NavigateToTodoItems}" Margin="0,0,0,8" HorizontalContentAlignment="Left" ToolTip="{x:Static loc:TodoItemLoc.TodoItems}">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<materialIcons:MaterialIcon Width="18" Height="18" Margin="1,0" Kind="Note" />
							<TextBlock Grid.Column="1"
									   VerticalAlignment="Center"
									   Margin="12,0,0,0"
									   Text="{x:Static loc:TodoItemLoc.TodoItems}"
									   Visibility="{Binding IsDrawerOpen, Converter={x:Static converter:BooleanToVisibilityConverter.Instance}}" />
						</Grid>
					</Button>
					<Button Command="{Binding NavigateToTrash}" Margin="0,0,0,8" HorizontalContentAlignment="Left" ToolTip="{x:Static loc:TrashLoc.Trash}">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<materialIcons:MaterialIcon Width="18" Height="18" Margin="1,0" Kind="Delete" />
							<TextBlock Grid.Column="1"
									   VerticalAlignment="Center"
									   Margin="12,0,0,0"
									   Text="{x:Static loc:TrashLoc.Trash}"
									   Visibility="{Binding IsDrawerOpen, Converter={x:Static converter:BooleanToVisibilityConverter.Instance}}" />
						</Grid>
					</Button>
				</StackPanel>
			</ScrollViewer>
		</Border>

		<Grid Grid.Column="1">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="12,8,12,0">
				<Button Command="{Binding NavigateToGlobalSearch}" ToolTip="{x:Static loc:GlobalSearchLoc.GlobalSearch}" Margin="5">
					<Button.Content>
						<materialIcons:MaterialIcon Kind="Magnify" Width="18" Height="18" />
					</Button.Content>
				</Button>
				<Button Command="{Binding ManageCommand}" ToolTip="Manage" Margin="5">
					<Button.Content>
						<materialIcons:MaterialIcon Kind="User" Width="18" Height="18" />
					</Button.Content>
				</Button>
				<Button Command="{Binding LogoutCommand}" ToolTip="Logout" Margin="5">
					<Button.Content>
						<materialIcons:MaterialIcon Kind="Logout" Width="18" Height="18" />
					</Button.Content>
				</Button>
			</StackPanel>
		</Grid>
	</Grid>
</UserControl>
