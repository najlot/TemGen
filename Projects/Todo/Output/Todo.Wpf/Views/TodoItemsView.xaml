<UserControl x:Class="Todo.Wpf.Views.TodoItemsView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
			 xmlns:loc="clr-namespace:Todo.Client.Localisation;assembly=Todo.Client.Localisation"
			 xmlns:local="clr-namespace:Todo.Wpf.Views"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
			 d:DesignHeight="450"
			 d:DesignWidth="800"
			 mc:Ignorable="d">
	<DockPanel>
		<DockPanel DockPanel.Dock="Top">
			<Button Margin="5" DockPanel.Dock="Left" Command="{Binding NavigateBackCommand}">
				<Button.Content>
					<materialIcons:MaterialIcon Kind="ArrowLeft" Width="18" Height="18" />
				</Button.Content>
			</Button>

			<WrapPanel HorizontalAlignment="Right" DockPanel.Dock="Right">
				<Button Margin="5"
						Command="{Binding RefreshTodoItemsCommand}"
						ToolTip="{x:Static loc:CommonLoc.Refresh}">
					<Button.Content>
						<materialIcons:MaterialIcon Kind="Refresh" Width="18" Height="18" />
					</Button.Content>
				</Button>

				<Button Margin="5"
						Command="{Binding AddTodoItemCommand}"
						ToolTip="{x:Static loc:CommonLoc.New}">
					<Button.Content>
						<materialIcons:MaterialIcon Kind="Add" Width="18" Height="18" />
					</Button.Content>
				</Button>
			</WrapPanel>

			<DockPanel DockPanel.Dock="Left">
				<Label VerticalAlignment="Center" Content="{x:Static loc:CommonLoc.Filter}" />
				<TextBox Margin="5"
						 VerticalAlignment="Center"
						 Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" />
			</DockPanel>
		</DockPanel>

		<ScrollViewer>
			<ItemsControl ItemsSource="{Binding TodoItemsView}">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<StackPanel Margin="5">
							<TextBlock Padding="5,5,5,0" Text="{Binding Title}">
								<i:Interaction.Triggers>
									<i:EventTrigger EventName="MouseLeftButtonUp">
										<i:InvokeCommandAction Command="{Binding DataContext.EditTodoItemCommand, RelativeSource={RelativeSource AncestorType=local:TodoItemsView}}" CommandParameter="{Binding .}" />
									</i:EventTrigger>
								</i:Interaction.Triggers>
							</TextBlock>
							<TextBlock Padding="5,5,5,0" Text="{Binding Content}">
								<i:Interaction.Triggers>
									<i:EventTrigger EventName="MouseLeftButtonUp">
										<i:InvokeCommandAction Command="{Binding DataContext.EditTodoItemCommand, RelativeSource={RelativeSource AncestorType=local:TodoItemsView}}" CommandParameter="{Binding .}" />
									</i:EventTrigger>
								</i:Interaction.Triggers>
							</TextBlock>
						</StackPanel>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</DockPanel>
</UserControl>