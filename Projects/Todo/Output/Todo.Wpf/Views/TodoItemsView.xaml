<UserControl x:Class="Todo.Wpf.Views.TodoItemsView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:controls="clr-namespace:Todo.Wpf.Controls"
			 xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
			 xmlns:loc="clr-namespace:Todo.Client.Localisation;assembly=Todo.Client.Localisation"
			 xmlns:local="clr-namespace:Todo.Wpf.Views"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
			 d:DesignHeight="700"
			 d:DesignWidth="1000"
			 mc:Ignorable="d">
	<DockPanel>
		<DockPanel DockPanel.Dock="Top" Margin="5,0">
			<Button Margin="5" DockPanel.Dock="Left" Command="{Binding NavigateBackCommand}">
				<Button.Content>
					<materialIcons:MaterialIcon Kind="ArrowLeft" Width="18" Height="18" />
				</Button.Content>
			</Button>

			<Button Margin="5"
					DockPanel.Dock="Right"
					Command="{Binding AddTodoItemCommand}"
					ToolTip="{x:Static loc:CommonLoc.New}">
				<Button.Content>
					<materialIcons:MaterialIcon Kind="Add" Width="18" Height="18" />
				</Button.Content>
			</Button>

			<TextBlock Margin="10,0,0,0"
						VerticalAlignment="Center"
						FontSize="18"
						FontWeight="Bold"
						Text="{x:Static loc:TodoItemLoc.TodoItems}" />
		</DockPanel>

		<ScrollViewer>
			<StackPanel>
				<controls:EntityFilterEditorView DataContext="{Binding Filters}" Margin="0,8,0,0" />

				<ItemsControl ItemsSource="{Binding TodoItems}">
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<StackPanel Margin="5">
								<TextBlock Padding="5,5,5,0" Text="{Binding Title}">
									<i:Interaction.Triggers>
										<i:EventTrigger EventName="MouseLeftButtonUp">
											<i:InvokeCommandAction Command="{Binding DataContext.EditTodoItemCommand, RelativeSource={RelativeSource AncestorType=local:TodoItemsView}}" CommandParameter="{Binding .}" />
										</i:EventTrigger>
									</i:Interaction.Triggers>
								</TextBlock>
								<TextBlock Padding="5,5,5,0" Text="{Binding Content}">
									<i:Interaction.Triggers>
										<i:EventTrigger EventName="MouseLeftButtonUp">
											<i:InvokeCommandAction Command="{Binding DataContext.EditTodoItemCommand, RelativeSource={RelativeSource AncestorType=local:TodoItemsView}}" CommandParameter="{Binding .}" />
										</i:EventTrigger>
									</i:Interaction.Triggers>
								</TextBlock>
							</StackPanel>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</StackPanel>
		</ScrollViewer>
	</DockPanel>
</UserControl>