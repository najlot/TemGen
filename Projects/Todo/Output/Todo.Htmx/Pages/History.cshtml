@page "/history/{id:guid}"
@using Todo.Client.Localisation
@model Todo.Htmx.Pages.HistoryModel
@{
	ViewData["Title"] = CommonLoc.History;
}

<section class="d-grid gap-4">
	<h1 class="mb-0">@CommonLoc.History</h1>

	<div class="card shadow-sm border-0">
		<div class="card-body">
			@if (Model.IsLoading)
			{
				<div class="text-body-secondary">@CommonLoc.Loading...</div>
			}
			else if (Model.Entries.Length == 0)
			{
				<p class="mb-0 text-body-secondary">@CommonLoc.NoHistoryEntries</p>
			}
			else
			{
				<div class="d-grid gap-3">
					@foreach (var entry in Model.Entries)
					{
						<section class="border-bottom pb-3">
							<div class="d-flex flex-column flex-md-row justify-content-between gap-2">
								<div>
									<div class="fw-semibold text-body">@(string.IsNullOrWhiteSpace(entry.Username) ? "-" : entry.Username)</div>
									<div class="small text-body-secondary">@entry.TimeStamp.ToLocalTime().ToString("g")</div>
								</div>
								<div class="small text-body-secondary text-md-end">@entry.Changes.Length @CommonLoc.ChangesRecorded</div>
							</div>

							<div class="table-responsive mt-2">
								<table class="table table-sm align-middle mb-0">
									<thead class="table-light">
										<tr>
											<th>@CommonLoc.Field</th>
											<th>@CommonLoc.Before</th>
											<th>@CommonLoc.After</th>
										</tr>
									</thead>
									<tbody>
										@foreach (var change in entry.Changes)
										{
											<tr>
												<td class="fw-semibold text-break">@change.Path</td>
												<td class="text-break"><pre class="mb-0 text-wrap small">@change.OldValue</pre></td>
												<td class="text-break"><pre class="mb-0 text-wrap small">@change.NewValue</pre></td>
											</tr>
										}
									</tbody>
								</table>
							</div>
						</section>
					}
				</div>
			}
		</div>
	</div>
</section>

