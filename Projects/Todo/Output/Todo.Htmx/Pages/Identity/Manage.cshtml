@page
@using Todo.Client.Localisation
@model Todo.Htmx.Pages.Identity.ManageModel
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@{
	ViewData["Title"] = UserLoc.UserManagement;
	Layout = "_Layout";
}

<section class="w-100 p-4 d-flex justify-content-center">
	<div style="min-width: 320px; max-width: 420px; width: 100%;">
		<h1>@UserLoc.UserManagement</h1>
		<br />

		@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
		{
			<div class="alert alert-danger">@Model.ErrorMessage</div>
		}

		@if (Model.Saved)
		{
			<div class="alert alert-success">@CommonLoc.ChangesRecorded</div>
		}

		<form method="post">
			<div class="mb-4">
				<label class="form-label" for="PasswordInput">@UserLoc.NewPassword</label>
				<input type="password" id="PasswordInput" name="Input.Password" class="form-control" autocomplete="new-password" />
			</div>
			<div class="mb-4">
				<label class="form-label" for="PasswordConfirmInput">@UserLoc.ConfirmNewPassword</label>
				<input type="password" id="PasswordConfirmInput" name="Input.PasswordConfirm" class="form-control" autocomplete="new-password" />
			</div>
			<div class="mb-4">
				<button type="submit" class="btn btn-primary w-100">@UserLoc.ChangePassword</button>
			</div>
		</form>
	</div>
</section>

