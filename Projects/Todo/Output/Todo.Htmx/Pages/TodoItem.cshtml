@page "/todoitem/{id:guid}"
@using Todo.Client.Localisation
@using Todo.Contracts.TodoItems
@model Todo.Htmx.Pages.TodoItemModel
@{
	ViewData["Title"] = Model.IsNew ? (string)TodoItemLoc.CreateTodoItem : (string)TodoItemLoc.EditTodoItem;
	var liveDetailUrl = (Model.Model is not null && !Model.IsNew) ? $"{Request.Path}{Request.QueryString}" : null;
	var liveDetailSelect = liveDetailUrl is not null ? "#detail-container" : null;
	var liveDetailTarget = liveDetailUrl is not null ? "this" : null;
	var liveDetailSwap = liveDetailUrl is not null ? "outerHTML" : null;
	var liveDetailTrigger = liveDetailUrl is not null
		? "live-refresh-all from:body queue:last, sse:TodoItemUpdated queue:last, sse:TodoItemDeleted queue:last"
		: null;
	var liveDetailBeforeRequest = liveDetailUrl is not null
		? "const hasOtherRequestInFlight = document.querySelector('.htmx-request') && !this.classList.contains('htmx-request'); if (document.visibilityState !== 'visible' || hasOtherRequestInFlight) { document.body.dataset.liveRefreshPending = 'true'; event.preventDefault(); return; } const form = this.querySelector('form[data-live-dirty-form=\"true\"]'); if (form && (form.dataset.liveDirty === 'true' || form.contains(document.activeElement))) { event.preventDefault(); }"
		: null;
}

<div id="detail-container"
	 hx-get="@liveDetailUrl"
	 hx-select="@liveDetailSelect"
	 hx-target="@liveDetailTarget"
	 hx-swap="@liveDetailSwap"
	 hx-trigger="@liveDetailTrigger"
	 hx-on::before-request="@liveDetailBeforeRequest">
	@if (Model.Model == null)
	{
		<p><em>@CommonLoc.Loading...</em></p>
	}
	else
	{
		<section class="d-grid gap-4">
		<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3">
			<h1 class="mb-1">@ViewData["Title"]</h1>
			<div class="d-flex flex-wrap gap-2">
				@if (!Model.IsNew)
				{
					<a href="/history/@Model.Model.Id?entityName=TodoItem" class="btn btn-outline-secondary"><span class="material-symbols-sharp me-1" style="font-size:1.1rem;vertical-align:middle;">history</span> @CommonLoc.History</a>
					@await Html.PartialAsync("_TodoItemFavoriteToggle", Model)
				}
				<button type="submit" form="edit-form" class="btn btn-success"><span class="material-symbols-sharp me-1" style="font-size:1.1rem;vertical-align:middle;">save</span> @CommonLoc.Save</button>
				@if (!Model.IsNew)
				{
					<button type="button" class="btn btn-danger"
							hx-post="/todoitem/@Model.Model.Id?handler=Delete"
							hx-confirm="@CommonLoc.DeleteConfirmationDescription"
							hx-target="body"
							hx-push-url="true">
						<span class="material-symbols-sharp me-1" style="font-size:1.1rem;vertical-align:middle;">delete</span> @CommonLoc.Delete
					</button>
				}
			</div>
		</div>

		@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
		{
			<div class="alert alert-danger">@Model.ErrorMessage</div>
		}

		<form id="edit-form"
			  method="post"
			  data-live-dirty-form="true"
			  data-live-dirty="@((!ViewData.ModelState.IsValid || !string.IsNullOrWhiteSpace(Model.ErrorMessage)) ? "true" : "false")"
			  hx-on:input="this.dataset.liveDirty = 'true'"
			  hx-on:change="this.dataset.liveDirty = 'true'">
			<div class="card shadow-sm border-0">
				<div class="card-body">
					<div class="row g-3">

						<!-- Title -->
						<div class="col-12 col-md-6">
							<label class="form-label" for="TitleInput">@TodoItemLoc.Title</label>
							<input type="text" id="TitleInput" name="Model.Title"
								   class="form-control" value="@Model.Model.Title" />
						</div>

						<!-- Content -->
						<div class="col-12 col-md-6">
							<label class="form-label" for="ContentInput">@TodoItemLoc.Content</label>
							<input type="text" id="ContentInput" name="Model.Content"
								   class="form-control" value="@Model.Model.Content" />
						</div>

						<!-- AssignedTo -->
						<div class="col-12 col-md-6">
							<label class="form-label" for="AssignedToInput">@TodoItemLoc.AssignedTo</label>
							<select id="AssignedToInput" name="Model.AssignedToId" class="form-select">
								@foreach (var value in Model.users)
								{
									<option value="@value.Id" selected="@(Model.Model.AssignedToId == value.Id ? "selected" : null)">
										@value.DisplayText
									</option>
								}
							</select>
						</div>

						<!-- Status -->
						<div class="col-12 col-md-6">
							<label class="form-label" for="StatusInput">@TodoItemLoc.Status</label>
							<select id="StatusInput" name="Model.Status" class="form-select">
								@foreach (var value in Enum.GetValues(typeof(TodoItemStatus)))
								{
									<option value="@value" selected="@(Model.Model.Status.Equals(value) ? "selected" : null)">@((value.Equals(TodoItemStatus.None) ? CommonLoc.NothingSelected : value.ToString()))</option>
								}
							</select>
						</div>

						<!-- DueDate -->
						<div class="col-12 col-md-6">
							<label class="form-label" for="DueDateInput">@TodoItemLoc.DueDate</label>
							<input type="date" id="DueDateInput" name="Model.DueDate"
								   class="form-control" value="@Model.Model.DueDate.ToString("yyyy-MM-dd")" />
						</div>

						<!-- Priority -->
						<div class="col-12 col-md-6">
							<label class="form-label" for="PriorityInput">@TodoItemLoc.Priority</label>
							<input type="text" id="PriorityInput" name="Model.Priority"
								   class="form-control" value="@Model.Model.Priority" />
						</div>
					</div>
				</div>
			</div>

			<div class="card shadow-sm border-0 mt-3">
				<div class="card-header bg-body-tertiary d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
					<h2 class="h5 mb-0">@TodoItemLoc.Checklist</h2>
					<button type="submit" name="action" value="add_checklist"
							class="btn btn-success btn-sm" formnovalidate>
						&#x2b; @CommonLoc.New
					</button>
				</div>
				<div class="table-responsive">
					<table class="table table-striped align-middle mb-0">
						<thead class="bg-body-tertiary">
							<tr>
								<th>@ChecklistTaskLoc.IsDone</th>
								<th>@ChecklistTaskLoc.Description</th>
								<th class="text-end">@CommonLoc.Delete</th>
							</tr>
						</thead>
						<tbody>
							@for (var i = 0; i < Model.Model.Checklist.Count; i++)
							{
								var entryItem = Model.Model.Checklist[i];
								<tr>
									<td>
										<input type="hidden" name="Model.Checklist[@i].IsDone" value="false" />
										<input type="checkbox" class="form-check-input"
											   name="Model.Checklist[@i].IsDone"
											   value="true" @(entryItem.IsDone ? "checked" : "") />
									</td>
									<td>
										<input type="text" class="form-control form-control-sm"
											   name="Model.Checklist[@i].Description"
											   value="@entryItem.Description" />
									</td>
									<td class="text-end">
										<button type="submit" name="action"
												value="remove_checklist_@(entryItem.Id)"
												class="btn btn-danger btn-sm" formnovalidate>
											&#x1F5D1;
										</button>
									</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			</div>

		</form>
	</section>
	}
</div>

