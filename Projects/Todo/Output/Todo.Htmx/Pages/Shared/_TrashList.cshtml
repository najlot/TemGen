@using Todo.Client.Localisation
@using Todo.Contracts.Trash
@using Todo.Contracts.Shared
@model Todo.Htmx.Pages.TrashModel

@if (Model.Items.Count == 0)
{
	<div id="trash-list">
		<div class="alert alert-light border mb-0">@TrashLoc.TrashEmpty</div>
	</div>
}
else
{
	<div id="trash-list" class="row g-3">
		@foreach (var item in Model.Items)
		{
			<div class="col-12">
				<div class="card shadow-sm border-0 h-100">
					<div class="card-body">
						<div class="d-flex justify-content-between align-items-start gap-3">
							<div class="flex-grow-1">
								<div class="fw-semibold text-break">@(string.IsNullOrWhiteSpace(item.Title) ? CommonLoc.Untitled : item.Title)</div>
								@if (!string.IsNullOrWhiteSpace(item.Content))
								{
									<div class="text-muted text-break mt-1">@item.Content</div>
								}
								<div class="d-flex flex-wrap gap-2 mt-3">
									<a href="@TrashModel.GetItemHref(item)" class="btn btn-sm btn-outline-primary">@CommonLoc.Edit</a>
									<form method="post" action="/Trash?handler=Restore"
										  hx-post="/Trash?handler=Restore"
										  hx-target="#trash-list"
										  hx-swap="outerHTML"
										  class="d-inline">
										<input type="hidden" name="type" value="@item.Type" />
										<input type="hidden" name="id" value="@item.Id" />
										<button type="submit" class="btn btn-sm btn-outline-success">@TrashLoc.Restore</button>
									</form>
									<form method="post" action="/Trash?handler=Delete"
										  hx-post="/Trash?handler=Delete"
										  hx-target="#trash-list"
										  hx-swap="outerHTML"
										  hx-confirm="@TrashLoc.PermanentDeleteConfirmationDescription"
										  class="d-inline">
										<input type="hidden" name="type" value="@item.Type" />
										<input type="hidden" name="id" value="@item.Id" />
										<button type="submit" class="btn btn-sm btn-outline-danger">@CommonLoc.Delete</button>
									</form>
								</div>
							</div>
							<div class="text-end text-nowrap small text-secondary">
								<div>@item.Type</div>
								<div>@item.DeletedAt?.ToLocalTime().ToString("g")</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		}
	</div>
}

