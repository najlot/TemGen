<UserControl x:Class="Todo.Uno.View.TodoItemView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:local="using:Todo.Uno.View"
			 mc:Ignorable="d"
			 x:Name="Root"
			 d:DesignHeight="500" d:DesignWidth="600">
	<Grid IsEnabled="{Binding CanEdit}">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<Grid Grid.Row="0" Margin="5">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>

			<Button Grid.Column="0" Margin="5" Command="{Binding NavigateBackCommand}">
				<SymbolIcon Symbol="Back" />
			</Button>

			<StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
				<Button ToolTipService.ToolTip="Undo" Command="{Binding UndoCommand}" Margin="5">
					<SymbolIcon Symbol="Undo" />
				</Button>
				<Button ToolTipService.ToolTip="Redo" Command="{Binding RedoCommand}" Margin="5">
					<SymbolIcon Symbol="Redo" />
				</Button>
				<Button ToolTipService.ToolTip="Save" Command="{Binding SaveCommand}" Margin="5">
					<SymbolIcon Symbol="Save" />
				</Button>
				<Button ToolTipService.ToolTip="Delete" Command="{Binding DeleteCommand}" Margin="5">
					<SymbolIcon Symbol="Delete" />
				</Button>
			</StackPanel>
		</Grid>

		<ScrollViewer Grid.Row="1">
			<StackPanel Margin="2,0" MinWidth="400" MinHeight="200"
						HorizontalAlignment="Center" VerticalAlignment="Center">
					<StackPanel Orientation="Horizontal" Margin="5">
						<TextBlock Text="Title" MinWidth="75" VerticalAlignment="Center" />
						<TextBox Text="{Binding Title, Mode=TwoWay}" MinWidth="200" />
					</StackPanel>
					<StackPanel Orientation="Horizontal" Margin="5">
						<TextBlock Text="Content" MinWidth="75" VerticalAlignment="Center" />
						<TextBox Text="{Binding Content, Mode=TwoWay}" MinWidth="200" />
					</StackPanel>
					<StackPanel Orientation="Horizontal" Margin="5">
						<TextBlock Text="CreatedAt" MinWidth="75" VerticalAlignment="Center" />
						<DatePicker Date="{Binding CreatedAt, Mode=TwoWay}" />
					</StackPanel>
					<StackPanel Orientation="Horizontal" Margin="5">
						<TextBlock Text="CreatedBy" MinWidth="75" VerticalAlignment="Center" />
						<TextBox Text="{Binding CreatedBy, Mode=TwoWay}" MinWidth="200" />
					</StackPanel>
					<StackPanel Orientation="Horizontal" Margin="5">
						<TextBlock Text="AssignedTo" MinWidth="75" VerticalAlignment="Center" />
						<ComboBox ItemsSource="{Binding AvailableUsers}" SelectedValue="{Binding AssignedToId, Mode=TwoWay}" SelectedValuePath="Id" DisplayMemberPath="Username" IsEditable="True" />
					</StackPanel>
					<StackPanel Orientation="Horizontal" Margin="5">
						<TextBlock Text="Status" MinWidth="75" VerticalAlignment="Center" />
						<ComboBox ItemsSource="{Binding AvailableTodoItemStatus}" SelectedItem="{Binding Status, Mode=TwoWay}" />
					</StackPanel>
					<StackPanel Orientation="Horizontal" Margin="5">
						<TextBlock Text="ChangedAt" MinWidth="75" VerticalAlignment="Center" />
						<DatePicker Date="{Binding ChangedAt, Mode=TwoWay}" />
					</StackPanel>
					<StackPanel Orientation="Horizontal" Margin="5">
						<TextBlock Text="ChangedBy" MinWidth="75" VerticalAlignment="Center" />
						<TextBox Text="{Binding ChangedBy, Mode=TwoWay}" MinWidth="200" />
					</StackPanel>
					<StackPanel Orientation="Horizontal" Margin="5">
						<TextBlock Text="Priority" MinWidth="75" VerticalAlignment="Center" />
						<TextBox Text="{Binding Priority, Mode=TwoWay}" MinWidth="200" />
					</StackPanel>
					<StackPanel>
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<TextBlock Grid.Column="0" Text="Checklist" Foreground="{StaticResource AppForegroundColor}" Background="{StaticResource AppBackgroundColor}" Padding="5" Margin="0,5" VerticalAlignment="Center"/>
							<Button Grid.Column="1" ToolTipService.ToolTip="New" Command="{Binding AddChecklistTaskCommand}" Margin="5">
								<SymbolIcon Symbol="Add" />
							</Button>
						</Grid>

						<ListView
							Margin="0,0,5,0"
							ItemsSource="{Binding Checklist}"
							SelectionMode="None">

							<ListView.ItemTemplate>
								<DataTemplate>
									<StackPanel>
										<StackPanel Orientation="Horizontal" Margin="2">
											<TextBlock Text="IsDone" MinWidth="100" VerticalAlignment="Center" />
											<CheckBox IsChecked="{Binding IsDone, Mode=TwoWay}" />
										</StackPanel>
										<StackPanel Orientation="Horizontal" Margin="2">
											<TextBlock Text="Description" MinWidth="100" VerticalAlignment="Center" />
											<TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MinWidth="150" />
										</StackPanel>
										<Button ToolTipService.ToolTip="Delete" Padding="2"
											Command="{Binding ElementName=Root, Path=DataContext.DeleteChecklistTaskCommand}" CommandParameter="{Binding .}">
											<SymbolIcon Symbol="Delete" />
										</Button>
									</StackPanel>
								</DataTemplate>
							</ListView.ItemTemplate>
						</ListView>
					</StackPanel>
			</StackPanel>
		</ScrollViewer>

		<local:SaveConfirmationDialogView Visibility="{Binding SaveDialogViewModel.IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
									  DataContext="{Binding SaveDialogViewModel}" />
		<local:DeleteConfirmationDialogView Visibility="{Binding DeleteDialogViewModel.IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
									  DataContext="{Binding DeleteDialogViewModel}" />
	</Grid>
</UserControl>

