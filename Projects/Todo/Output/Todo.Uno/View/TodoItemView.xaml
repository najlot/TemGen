<UserControl x:Class="Todo.Uno.View.TodoItemView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:local="using:Todo.Uno.View"
			 xmlns:loc="using:Todo.Client.Localisation"
			 xmlns:converter="using:Todo.Uno.Converter"
			 xmlns:utu="using:Uno.Toolkit.UI"
			 mc:Ignorable="d"
			 d:DesignHeight="500" d:DesignWidth="600">
	<Grid>
		<utu:DockPanel IsEnabled="{Binding CanEdit}">
			<utu:DockPanel utu:DockPanel.Dock="Top">
				<Button Margin="5"
						utu:DockPanel.Dock="Left"
						Command="{Binding NavigateBackCommand}">
					<SymbolIcon Symbol="Back" />
				</Button>

				<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" utu:DockPanel.Dock="Right">
					<Button ToolTipService.ToolTip="{x:Static loc:CommonLoc.Undo}" Command="{Binding UndoCommand}" Margin="5">
						<SymbolIcon Symbol="Undo" />
					</Button>
					<Button ToolTipService.ToolTip="{x:Static loc:CommonLoc.Redo}" Command="{Binding RedoCommand}" Margin="5">
						<SymbolIcon Symbol="Redo" />
					</Button>
					<Button ToolTipService.ToolTip="{x:Static loc:CommonLoc.Save}" Command="{Binding SaveCommand}" Margin="5">
						<SymbolIcon Symbol="Save" />
					</Button>
					<Button ToolTipService.ToolTip="{x:Static loc:CommonLoc.Delete}" Command="{Binding DeleteCommand}" Margin="5">
						<SymbolIcon Symbol="Delete" />
					</Button>
				</StackPanel>
			</utu:DockPanel>
			<ScrollViewer>
				<StackPanel Margin="2,0" MinWidth="400" MinHeight="200"
						HorizontalAlignment="Center" VerticalAlignment="Center">
					<StackPanel Orientation="Horizontal" Margin="5">
						<TextBlock Text="{x:Static loc:TodoItemLoc.Title}" MinWidth="75" VerticalAlignment="Center" />
						<TextBox Text="{Binding Title, Mode=TwoWay}" MinWidth="200" />
					</StackPanel>
					<StackPanel Orientation="Horizontal" Margin="5">
						<TextBlock Text="{x:Static loc:TodoItemLoc.Content}" MinWidth="75" VerticalAlignment="Center" />
						<TextBox Text="{Binding Content, Mode=TwoWay}" MinWidth="200" />
					</StackPanel>
					<StackPanel Orientation="Horizontal" Margin="5">
						<TextBlock Text="{x:Static loc:TodoItemLoc.CreatedAt}" MinWidth="75" VerticalAlignment="Center" />
						<DatePicker Date="{Binding CreatedAt, Mode=TwoWay}" />
					</StackPanel>
					<StackPanel Orientation="Horizontal" Margin="5">
						<TextBlock Text="{x:Static loc:TodoItemLoc.CreatedBy}" MinWidth="75" VerticalAlignment="Center" />
						<TextBox Text="{Binding CreatedBy, Mode=TwoWay}" MinWidth="200" />
					</StackPanel>
					<StackPanel Orientation="Horizontal" Margin="5">
						<TextBlock Text="{x:Static loc:TodoItemLoc.AssignedTo}" MinWidth="75" VerticalAlignment="Center" />
						<ComboBox ItemsSource="{Binding AvailableUsers}" SelectedValue="{Binding AssignedToId, Mode=TwoWay}" SelectedValuePath="Id" DisplayMemberPath="Username" IsEditable="True" />
					</StackPanel>
					<StackPanel Orientation="Horizontal" Margin="5">
						<TextBlock Text="{x:Static loc:TodoItemLoc.Status}" MinWidth="75" VerticalAlignment="Center" />
						<ComboBox ItemsSource="{Binding AvailableTodoItemStatus, Converter={x:Static converter:EnumToTranslationConverter.Instance}, ConverterParameter={x:Type loc:TodoItemStatusLoc}}"
							  SelectedItem="{Binding Status, Mode=TwoWay, Converter={x:Static converter:EnumToTranslationConverter.Instance}, ConverterParameter={x:Type loc:TodoItemStatusLoc}}" />
					</StackPanel>
					<StackPanel Orientation="Horizontal" Margin="5">
						<TextBlock Text="{x:Static loc:TodoItemLoc.ChangedAt}" MinWidth="75" VerticalAlignment="Center" />
						<DatePicker Date="{Binding ChangedAt, Mode=TwoWay}" />
					</StackPanel>
					<StackPanel Orientation="Horizontal" Margin="5">
						<TextBlock Text="{x:Static loc:TodoItemLoc.ChangedBy}" MinWidth="75" VerticalAlignment="Center" />
						<TextBox Text="{Binding ChangedBy, Mode=TwoWay}" MinWidth="200" />
					</StackPanel>
					<StackPanel Orientation="Horizontal" Margin="5">
						<TextBlock Text="{x:Static loc:TodoItemLoc.Priority}" MinWidth="75" VerticalAlignment="Center" />
						<TextBox Text="{Binding Priority, Mode=TwoWay}" MinWidth="200" />
					</StackPanel>
					<StackPanel>
						<utu:DockPanel>
							<Button ToolTipService.ToolTip="{x:Static loc:CommonLoc.New}" Command="{Binding AddChecklistTaskCommand}" Margin="5" utu:DockPanel.Dock="Right">
								<SymbolIcon Symbol="Add" />
							</Button>
							<TextBlock Text="{x:Static loc:TodoItemLoc.Checklist}" Foreground="{StaticResource AppForegroundColor}" Background="{StaticResource AppBackgroundColor}" Padding="5" Margin="0,5" VerticalAlignment="Center"/>
						</utu:DockPanel>

						<ListView
							Margin="0,0,5,0"
							ItemsSource="{Binding Checklist}"
							SelectionMode="None">

							<ListView.ItemTemplate>
								<DataTemplate>
									<StackPanel>
										<StackPanel Orientation="Horizontal" Margin="2">
											<TextBlock Text="{x:Static loc:ChecklistTaskLoc.IsDone}" MinWidth="100" VerticalAlignment="Center" />
											<CheckBox IsChecked="{Binding IsDone, Mode=TwoWay}" />
										</StackPanel>
										<StackPanel Orientation="Horizontal" Margin="2">
											<TextBlock Text="{x:Static loc:ChecklistTaskLoc.Description}" MinWidth="100" VerticalAlignment="Center" />
											<TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MinWidth="150" />
										</StackPanel>
										<Button ToolTipService.ToolTip="Delete" Padding="2"
											Command="{Binding DataContext.DeleteChecklistTaskCommand, RelativeSource={RelativeSource AncestorType=local:TodoItemView}}" CommandParameter="{Binding .}">
											<SymbolIcon Symbol="Delete" />
										</Button>
									</StackPanel>
								</DataTemplate>
							</ListView.ItemTemplate>
						</ListView>
					</StackPanel>
				</StackPanel>
			</ScrollViewer>
		</utu:DockPanel>

		<local:SaveConfirmationDialogView Visibility="{Binding SaveDialogViewModel.IsVisible, Converter={x:Static converter:BooleanToVisibilityConverter.Instance}}"
							  DataContext="{Binding SaveDialogViewModel}" />
		<local:DeleteConfirmationDialogView Visibility="{Binding DeleteDialogViewModel.IsVisible, Converter={x:Static converter:BooleanToVisibilityConverter.Instance}}"
							  DataContext="{Binding DeleteDialogViewModel}" />
	</Grid>
</UserControl>

