<UserControl x:Class="Todo.Uno.View.AllTodoItemsView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:local="using:Todo.Uno.View"
			 xmlns:loc="using:Todo.Client.Localisation"
			 xmlns:utu="using:Uno.Toolkit.UI"
			 xmlns:i="using:Microsoft.Xaml.Interactivity"
			 xmlns:core="using:Microsoft.Xaml.Interactions.Core"
			 mc:Ignorable="d"
			 d:DesignHeight="450"
			 d:DesignWidth="800">
	<utu:DockPanel>
		<utu:DockPanel utu:DockPanel.Dock="Top">
			<Button Margin="5" utu:DockPanel.Dock="Left" Command="{Binding NavigateBackCommand}">
				<SymbolIcon Symbol="Back" />
			</Button>

			<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" utu:DockPanel.Dock="Right">
				<Button Margin="5"
						Command="{Binding RefreshTodoItemsCommand}"
						ToolTipService.ToolTip="{x:Static loc:CommonLoc.Refresh}">
					<SymbolIcon Symbol="Refresh" />
				</Button>

				<Button Margin="5"
						Command="{Binding AddTodoItemCommand}"
						ToolTipService.ToolTip="{x:Static loc:CommonLoc.New}">
					<SymbolIcon Symbol="Add" />
				</Button>
			</StackPanel>

			<utu:DockPanel utu:DockPanel.Dock="Left">
				<TextBlock VerticalAlignment="Center" Text="{x:Static loc:CommonLoc.Filter}" Margin="5" />
				<TextBox Margin="5"
						 VerticalAlignment="Center"
						 Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
			</utu:DockPanel>
		</utu:DockPanel>

		<ScrollViewer>
			<ItemsControl ItemsSource="{Binding TodoItemsView}">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<StackPanel Margin="5">
							<TextBlock Padding="5,5,5,0" Text="{Binding Title}">
								<i:Interaction.Triggers>
									<i:EventTrigger EventName="Tapped">
										<i:InvokeCommandAction Command="{Binding DataContext.EditTodoItemCommand, RelativeSource={RelativeSource AncestorType=local:AllTodoItemsView}}" CommandParameter="{Binding .}" />
									</i:EventTrigger>
								</i:Interaction.Triggers>
							</TextBlock>
							<TextBlock Padding="5,5,5,0" Text="{Binding Content}">
								<i:Interaction.Triggers>
									<i:EventTrigger EventName="Tapped">
										<i:InvokeCommandAction Command="{Binding DataContext.EditTodoItemCommand, RelativeSource={RelativeSource AncestorType=local:AllTodoItemsView}}" CommandParameter="{Binding .}" />
									</i:EventTrigger>
								</i:Interaction.Triggers>
							</TextBlock>
						</StackPanel>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</utu:DockPanel>
</UserControl>

