<UserControl x:Class="Todo.Uno.View.MenuView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:loc="using:Todo.Client.Localisation"
			 xmlns:converter="using:Todo.Uno.Converter"
			 xmlns:utu="using:Uno.Toolkit.UI"
			 xmlns:i="using:Microsoft.Xaml.Interactivity"
			 xmlns:core="using:Microsoft.Xaml.Interactions.Core"
			 mc:Ignorable="d"
			 d:DesignHeight="450" d:DesignWidth="800">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
			<Button Command="{Binding ToggleDrawerCommand}" Margin="5">
				<SymbolIcon Symbol="GlobalNavigationButton" />
			</Button>
		</StackPanel>

		<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
			<Button Command="{Binding ManageCommand}" ToolTipService.ToolTip="Manage" Margin="5">
				<SymbolIcon Symbol="People" />
			</Button>
			<Button Command="{Binding LogoutCommand}" ToolTipService.ToolTip="Logout" Margin="5">
				<SymbolIcon Symbol="LeaveChat" />
			</Button>
		</StackPanel>

		<!--  Overlay (visible when drawer is open)  -->
		<Border Background="#80000000"
				Grid.RowSpan="2"
				Visibility="{Binding IsDrawerOpen, Converter={x:Static converter:BooleanToVisibilityConverter.Instance}}"
				Canvas.ZIndex="1">
			<i:Interaction.Behaviors>
				<core:EventTriggerBehavior EventName="Tapped">
					<core:InvokeCommandAction Command="{Binding ToggleDrawerCommand}" />
				</core:EventTriggerBehavior>
			</i:Interaction.Behaviors>
		</Border>

		<!--  Off-Canvas Navigation Drawer  -->
		<Border Width="200"
				Background="White"
				HorizontalAlignment="Left"
				Grid.RowSpan="2"
				Visibility="{Binding IsDrawerOpen, Converter={x:Static converter:BooleanToVisibilityConverter.Instance}}"
				Canvas.ZIndex="2">
			<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
				<StackPanel Margin="5">
					<!--  Drawer Header  -->
					<TextBlock FontSize="20" FontWeight="SemiBold" Text="{x:Static loc:CommonLoc.Navigation}" Margin="5,10" />

					<!--  Navigation Items  -->
					<Button Command="{Binding NavigateToTodoItems}" Margin="5" HorizontalContentAlignment="Left">
						<StackPanel Orientation="Horizontal">
							<SymbolIcon Symbol="Note" Margin="0,0,10,0" />
							<TextBlock VerticalAlignment="Center" Text="{x:Static loc:TodoItemLoc.TodoItems}" />
						</StackPanel>
					</Button>

					<Button Command="{Binding NavigateToNotes}" Margin="5" HorizontalContentAlignment="Left">
						<StackPanel Orientation="Horizontal">
							<SymbolIcon Symbol="Note" Margin="0,0,10,0" />
							<TextBlock VerticalAlignment="Center" Text="{x:Static loc:NoteLoc.Notes}" />
						</StackPanel>
					</Button>
				</StackPanel>
			</ScrollViewer>
		</Border>
	</Grid>
</UserControl>

