<UserControl x:Class="Todo.Uno.View.MenuView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 mc:Ignorable="d"
			 x:Name="Root"
			 d:DesignHeight="450" d:DesignWidth="800">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<Grid Grid.Row="0" Margin="8">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>

			<Button Grid.Column="0" Command="{Binding ToggleDrawerCommand}" Margin="0,0,8,0">
				<SymbolIcon Symbol="GlobalNavigationButton" />
			</Button>

			<TextBlock Grid.Column="1"
					   VerticalAlignment="Center"
					   FontSize="18"
					   FontWeight="SemiBold"
					   Text="Navigation" />

			<StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
				<Button Command="{Binding ManageCommand}" ToolTipService.ToolTip="Manage" Margin="5">
					<SymbolIcon Symbol="People" />
				</Button>
				<Button Command="{Binding LogoutCommand}" ToolTipService.ToolTip="Logout" Margin="5">
					<SymbolIcon Symbol="LeaveChat" />
				</Button>
			</StackPanel>
		</Grid>

		<Button Background="#80000000"
				BorderThickness="0"
				Padding="0"
				Grid.RowSpan="2"
				Visibility="{Binding IsDrawerOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
				Canvas.ZIndex="1"
				Command="{Binding ToggleDrawerCommand}" />

		<Border Width="200"
				Background="White"
				HorizontalAlignment="Left"
				Grid.RowSpan="2"
				Visibility="{Binding IsDrawerOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
				Canvas.ZIndex="2">
			<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
				<StackPanel Margin="5">
					<TextBlock FontSize="20" FontWeight="SemiBold" Text="Navigation" Margin="5,10" />

					<Button Command="{Binding NavigateToNotes}" Margin="5" HorizontalContentAlignment="Left">
						<StackPanel Orientation="Horizontal">
							<SymbolIcon Symbol="Document" Margin="0,0,10,0" />
							<TextBlock VerticalAlignment="Center" Text="Notes" />
						</StackPanel>
					</Button>

					<Button Command="{Binding NavigateToTodoItems}" Margin="5" HorizontalContentAlignment="Left">
						<StackPanel Orientation="Horizontal">
							<SymbolIcon Symbol="Document" Margin="0,0,10,0" />
							<TextBlock VerticalAlignment="Center" Text="TodoItems" />
						</StackPanel>
					</Button>
				</StackPanel>
			</ScrollViewer>
		</Border>
	</Grid>
</UserControl>

