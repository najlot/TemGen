<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 xmlns:loc="clr-namespace:Todo.Client.Localisation;assembly=Todo.Client.Localisation"
			 xmlns:material="clr-namespace:Material.Icons.Maui;assembly=Material.Icons.Maui"
			 xmlns:converter="clr-namespace:Todo.Maui.Converter"
			 xmlns:local="clr-namespace:Todo.Maui.View"
			 x:Class="Todo.Maui.View.TodoItemView">
	<Grid>
		<Grid IsEnabled="{Binding CanEdit}">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>

			<Grid Grid.Row="0">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>

				<Button Grid.Column="0"
						Margin="5"
						Command="{Binding NavigateBackCommand}">
					<Button.ImageSource>
						<FontImageSource Glyph="{x:Static material:MaterialIconsRegular.ArrowBack}"
										 FontFamily="MaterialIcons"
										 Size="18" />
					</Button.ImageSource>
				</Button>

				<HorizontalStackLayout Grid.Column="2" HorizontalOptions="End">
					<Button ToolTipProperties.Text="{x:Static loc:CommonLoc.Undo}" Command="{Binding UndoCommand}" Margin="5">
						<Button.ImageSource>
							<FontImageSource Glyph="{x:Static material:MaterialIconsRegular.Undo}"
											 FontFamily="MaterialIcons"
											 Size="18" />
						</Button.ImageSource>
					</Button>
					<Button ToolTipProperties.Text="{x:Static loc:CommonLoc.Redo}" Command="{Binding RedoCommand}" Margin="5">
						<Button.ImageSource>
							<FontImageSource Glyph="{x:Static material:MaterialIconsRegular.Redo}"
											 FontFamily="MaterialIcons"
											 Size="18" />
						</Button.ImageSource>
					</Button>
					<Button ToolTipProperties.Text="{x:Static loc:CommonLoc.Save}" Command="{Binding SaveCommand}" Margin="5">
						<Button.ImageSource>
							<FontImageSource Glyph="{x:Static material:MaterialIconsRegular.Save}"
											 FontFamily="MaterialIcons"
											 Size="18" />
						</Button.ImageSource>
					</Button>
					<Button ToolTipProperties.Text="{x:Static loc:CommonLoc.Delete}" Command="{Binding DeleteCommand}" Margin="5">
						<Button.ImageSource>
							<FontImageSource Glyph="{x:Static material:MaterialIconsRegular.Delete}"
											 FontFamily="MaterialIcons"
											 Size="18" />
						</Button.ImageSource>
					</Button>
				</HorizontalStackLayout>
			</Grid>

			<ScrollView Grid.Row="1">
				<VerticalStackLayout Margin="2,0" MinimumWidthRequest="300"
									 HorizontalOptions="Center">
					<Grid Margin="5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Label Grid.Column="0" VerticalOptions="Center" MinimumWidthRequest="75" Text="{x:Static loc:TodoItemLoc.Title}" />
						<Entry Grid.Column="1" Text="{Binding Title}" />
					</Grid>
					<Grid Margin="5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Label Grid.Column="0" VerticalOptions="Center" MinimumWidthRequest="75" Text="{x:Static loc:TodoItemLoc.Content}" />
						<Entry Grid.Column="1" Text="{Binding Content}" />
					</Grid>
					<Grid Margin="5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Label Grid.Column="0" VerticalOptions="Center" MinimumWidthRequest="75" Text="{x:Static loc:TodoItemLoc.CreatedAt}" />
						<DatePicker Grid.Column="1" Date="{Binding CreatedAt}" />
					</Grid>
					<Grid Margin="5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Label Grid.Column="0" VerticalOptions="Center" MinimumWidthRequest="75" Text="{x:Static loc:TodoItemLoc.CreatedBy}" />
						<Entry Grid.Column="1" Text="{Binding CreatedBy}" />
					</Grid>
					<Grid Margin="5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Label Grid.Column="0" VerticalOptions="Center" MinimumWidthRequest="75" Text="{x:Static loc:TodoItemLoc.AssignedTo}" />
						<Picker Grid.Column="1"
								ItemsSource="{Binding AvailableUsers}"
								SelectedItem="{Binding AssignedToId}"
								ItemDisplayBinding="{Binding Username}" />
					</Grid>
					<Grid Margin="5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Label Grid.Column="0" VerticalOptions="Center" MinimumWidthRequest="75" Text="{x:Static loc:TodoItemLoc.Status}" />
						<Picker Grid.Column="1"
								ItemsSource="{Binding AvailableTodoItemStatus, Converter={x:Static converter:EnumToTranslationConverter.Instance}, ConverterParameter={x:Type loc:TodoItemStatusLoc}}"
								SelectedItem="{Binding Status, Converter={x:Static converter:EnumToTranslationConverter.Instance}, ConverterParameter={x:Type loc:TodoItemStatusLoc}}" />
					</Grid>
					<Grid Margin="5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Label Grid.Column="0" VerticalOptions="Center" MinimumWidthRequest="75" Text="{x:Static loc:TodoItemLoc.ChangedAt}" />
						<DatePicker Grid.Column="1" Date="{Binding ChangedAt}" />
					</Grid>
					<Grid Margin="5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Label Grid.Column="0" VerticalOptions="Center" MinimumWidthRequest="75" Text="{x:Static loc:TodoItemLoc.ChangedBy}" />
						<Entry Grid.Column="1" Text="{Binding ChangedBy}" />
					</Grid>
					<Grid Margin="5">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Label Grid.Column="0" VerticalOptions="Center" MinimumWidthRequest="75" Text="{x:Static loc:TodoItemLoc.Priority}" />
						<Entry Grid.Column="1" Text="{Binding Priority}" />
					</Grid>
					<Grid Margin="5">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>
						<Grid Grid.Row="0">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<Label Grid.Column="0" VerticalOptions="Center" Text="{x:Static loc:TodoItemLoc.Checklist}" TextColor="{StaticResource ForegroundColor}" BackgroundColor="{StaticResource BackgroundColor}" Padding="5" />
							<Button Grid.Column="1"
									ToolTipProperties.Text="{x:Static loc:CommonLoc.New}"
									Command="{Binding AddChecklistTaskCommand}"
									Margin="5">
								<Button.ImageSource>
									<FontImageSource Glyph="{x:Static material:MaterialIconsRegular.AddCircleOutline}"
													 FontFamily="MaterialIcons"
													 Size="18" />
								</Button.ImageSource>
							</Button>
						</Grid>
						<CollectionView Grid.Row="1" ItemsSource="{Binding Checklist}">
							<CollectionView.ItemTemplate>
								<DataTemplate>
									<Grid Margin="0,2" ColumnSpacing="5">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*" />
											<ColumnDefinition Width="*" />
											<ColumnDefinition Width="Auto" />
										</Grid.ColumnDefinitions>
										<CheckBox Grid.Column="0" IsChecked="{Binding IsDone}" />
										<Entry Grid.Column="1" Text="{Binding Description, Mode=TwoWay}" Placeholder="{x:Static loc:ChecklistTaskLoc.Description}" />
										<Button Grid.Column="2"
												ToolTipProperties.Text="Delete"
												Margin="2"
												Command="{Binding Source={RelativeSource AncestorType={x:Type local:TodoItemView}}, Path=BindingContext.DeleteChecklistTaskCommand}"
												CommandParameter="{Binding .}">
											<Button.ImageSource>
												<FontImageSource Glyph="{x:Static material:MaterialIconsRegular.Delete}"
																 FontFamily="MaterialIcons"
																 Size="14" />
											</Button.ImageSource>
										</Button>
									</Grid>
								</DataTemplate>
							</CollectionView.ItemTemplate>
						</CollectionView>
					</Grid>
				</VerticalStackLayout>
			</ScrollView>
		</Grid>

		<local:SaveConfirmationDialogView IsVisible="{Binding SaveDialogViewModel.IsVisible}"
										  BindingContext="{Binding SaveDialogViewModel}" />
		<local:DeleteConfirmationDialogView IsVisible="{Binding DeleteDialogViewModel.IsVisible}"
											BindingContext="{Binding DeleteDialogViewModel}" />
	</Grid>
</ContentView>
